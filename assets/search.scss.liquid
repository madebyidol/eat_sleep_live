.template-search {
	
	h1 {
	
		font-family: "Jenna Sue", "Proxima Nova", sans-serif;
		margin-top: 50px;
	    font-size: 60px;
	    font-weight: 300;
      
      	@media screen and (max-width: 480px) {
        	font-size: 45px;
        	margin-bottom: 45px;
        }

	}

	h3 {

		a {
			color: #759193;
			transition: 0.15s;
			-webkit-transition: 0.15s;
			-moz-transition: 0.15s;
			-ms-transition: 0.15s;
			&:hover {
				color: #537071;
			}
		}

	}

	p {

		span {
			font-weight: 700;
		}

	}

	img {
		transition: 0.15s;
		-webkit-transition: 0.15s;
		-moz-transition: 0.15s;
		-ms-transition: 0.15s;
		&:hover {
			opacity: 0.8;
		}
	}

	.search-bar {
 
 		.input-group-btn {
 			button {
				border-radius: 0 23px 23px 0 !important;
				background-color: #759193;
				transition: 0.15s;
				-webkit-transition: 0.15s;
				-moz-transition: 0.15s;
				-ms-transition: 0.15s;
				&:hover {
					background-color: #537071;
				}
        	}
        }
        .input-group-field {
			border-radius: 23px 0px 0px 23px !important;
			outline: none;
		}

	}
  
  	@media screen and (max-width: 480px) {
        .search-image {

            margin-bottom: 10px;
            img {
                width: 100% !important; 
            }
          
        }
    }

	.pagination {
	
		span {
		
			&.current {
				font-weight: 700;
			}
			a {
				transition: 0.15s;
				-webkit-transition: 0.15s;
				-moz-transition: 0.15s;
				-ms-transition: 0.15s;
			}

		}

	}

}