$small: 480px;
$medium: 768px;
$large: 769px;

@mixin prefix($name, $argument) {
  -webkit-#{$name}: #{$argument};
  -ms-#{$name}: #{$argument};
  -moz-#{$name}: #{$argument};
  -o-#{$name}: #{$argument};
  #{$name}: #{$argument};
}

*{
	outline: none;
}

.constrained{
	max-width: 1200px;
    margin: 0 auto;
}

.parallax-mirror{
	-webkit-transition: -webkit-transform 0.4s cubic-bezier(0.46, 0.01, 0.32, 1);
	transition: -webkit-transform 0.4s cubic-bezier(0.46, 0.01, 0.32, 1);
	transition: transform 0.4s cubic-bezier(0.46, 0.01, 0.32, 1);
	transition: transform 0.4s cubic-bezier(0.46, 0.01, 0.32, 1), -webkit-transform 0.4s cubic-bezier(0.46, 0.01, 0.32, 1);

	&.pushed-left{
		-webkit-transform: translateX(300px) !important;
		    -ms-transform: translateX(300px) !important;
		        transform: translateX(300px) !important;
	}

	&.pushed-right{
		-webkit-transform: translateX(-300px) !important;
		    -ms-transform: translateX(-300px) !important;
		        transform: translateX(-300px) !important;
	}
}

.flexbox{
	display: -webkit-box;
	display: -webkit-flex;
	display: -ms-flexbox;
	display: flex;
}

@media screen and (max-width: 480px) {
	/*
	.template-index.wrapper {
		padding: 0 15px !important;
		margin-top:2px !important;
	}
	.wrapper{
		margin-top:116px;
	}
	*/
}

.nav-bar{
	background: transparent;
}

.template-index .site-nav{
	a{
		color:#f0f0f0
	}
}

.site-nav{
	margin: 0;
	a{
		color: #333;
		font-size: 13px;
		font-weight: 300;
	}
	/*
	> li{
		position: initial;
		&:first-child {
			//padding-left: 30px;
        }
    }
    */
  	&.text-right {
      > li {
       	&:last-child {
         	//git apadding-right: 30px;
        }
      }
  	}
}

.site-nav__dropdown{
	left: 0;
    padding-top: 20px;
    width: 100%;
    padding-left: 35px;
    padding-right: 35px;
    z-index: 99999;
    opacity: 0;

    a{
    	background: transparent !important;
    }

	.dropdown-inner{
		background: rgba(0, 0, 0, 0.81);
		padding: 40px 0;
		width: 100%;

		li{
			display: inline-block;
			text-align: center;
			-webkit-box-flex: 1;
			-webkit-flex: 1 0 0%;
			    -ms-flex: 1 0 0%;
			        flex: 1 0 0%;
			min-width: 125px;

			.image-container{
				height: 100px;
				display: -webkit-box;
				display: flex;
				display: -webkit-flex;
				display: -moz-flex;
				display: -ms-flexbox;

				a{
		    		-webkit-align-self: center;
		    		    -ms-flex-item-align: center;
		    		        align-self: center;
		    	}
			}

		    a{
		    	text-align: center;
			    display: block;
			    font-size: 12px;
			    color: #ffffff;
			    text-transform: Capitalize;
			    font-weight: 300;
			    letter-spacing: 1px;
			    padding: 0;
				@media screen and (max-width: 1200px) {
			    	font-size: 10px;
			    }
			    @media screen and (min-width: 1440px) {
			    	font-size: 14px;
			    }
		    }


		}
	}
    ul{
    	margin: 0;
    	display: -webkit-box;
    	display: flex;
    	display: -webkit-flex;
    	display: -moz-flex;
    	display: -ms-flexbox;
    	-webkit-flex-wrap: wrap;
    	    -ms-flex-wrap: wrap;
    	        flex-wrap: wrap;
    	-webkit-box-orient: horizontal;
    	-webkit-box-direction: normal;
    	-webkit-flex-direction: row;
    	    -ms-flex-direction: row;
    	        flex-direction: row;
    }
}

.main-nav-item{
	.image-container{
		height: auto;
		display: -webkit-box;
    	display: flex;
    	display: -webkit-flex;
    	display: -moz-flex;
    	display: -ms-flexbox;
	}
	img{
		display: block;
	}
	a{
		text-align: center;
	    display: block;
	    font-size: 12px;
	    color: #434241;
	    text-transform: Capitalize;
	    font-weight: 300;
	    letter-spacing: 1px;
	    padding: 0 10px;
	    -webkit-align-self: center;
	        -ms-flex-item-align: center;
	            align-self: center;
	    @media only screen and (min-width: 1440px) {
	    	font-size: 14px;
	    }
	}

    border-right: 1px solid rgba(255, 255, 255, 0.51);
}




.site-nav--has-dropdown{

	> a{
		position: relative;
	}

	> a:after{
		content: "";
	    position: absolute;
	    left: -20px;
	    right: 0;
	    margin-left: auto;
	    margin-right: auto;
	    bottom: -20px;
	    height: 0;
	    width: 0;
	    border-left: 10px solid transparent;
	    border-right: 10px solid transparent;
	    border-bottom: 10px solid transparent;
	    -webkit-transition: border-bottom-color 0.15s;
	    transition: border-bottom-color 0.15s;
	}

	&:hover{
		> a::after{
		    border-bottom-color: black;
		}
	}

}

.all-types {
	padding-left: 15px;
	padding-right: 15px;
}

#allTypesLink {
    text-align: center;
    text-transform: Capitalize !important;
    font-weight: 300;
    color: #d2b158;
}

.image-background{
    display: block;
    position: relative;
    height: 100%;
    overflow: hidden;
}

.image-background img{
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: auto;
    border: none;
    -webkit-transform: translate(-50%,-50%);
    -ms-transform: translate(-50%,-50%);
    transform: translate(-50%,-50%);
}

