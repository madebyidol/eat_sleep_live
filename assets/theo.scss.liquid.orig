/* Parallax slides homepage */
.parallax-positioner {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	.parallax-container {
		position: relative;
		overflow: hidden;
		height: 100%;
		.parallax-slide-image {
			position: absolute;

		}
	}
}

@media screen and (max-width: 1400px) {
	.home-article-post {
		.caption {
			padding: 0% 0% !important;
		}
		.caption-inner {
			h3 {
				font-size: 14px !important;
				line-height: 21px !important;
			}
			p {
				font-size: 13px !important;
			}
		}
	}
}

