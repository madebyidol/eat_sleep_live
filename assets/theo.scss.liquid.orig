#fullpage{
	.caption{
	    width: 100%;
	    padding: 0 8%;
		margin: auto;
		z-index: 99 !important;
		-webkit-align-self: center;
		    -ms-flex-item-align: center;
		        align-self: center;

	    &.smaller{
	    	.caption-inner{
	    		width: 50%;

	    		h2{
	    			font-size: 183px;
    				line-height: 160px;
    				text-transform: capitalize;

    				@media screen and (max-width: 1400px) {
    					font-size: 145px;
    					line-height: 120px;
    				}

    				@media screen and (max-width: $medium){
				    	font-size: 100px;
				    	line-height: 100px;
			    	}
	    		}
                .lower{
                    text-transform:lowercase !important;
                }
	    		h3{
	    			margin: 0 0 10px 0;
				    padding: 0 21%;
				    font-size: 30px;

				    @media screen and (max-width: $medium){
				    	padding: 0;
    					font-size: 26px;
				    }
	    		}
	    	}
	    }

	    .caption-inner{
	    	margin: 0 auto;
	    	width: auto;
	    	display: inline-block;
	    	text-align: center;

	    	*{
	    		color: #fff;
	    	}

	    	h2, .caption-header {
	    		font-family: "Jenna Sue";
	    		margin: 0;
	    		text-shadow: 11px 2px 15px rgba(0, 0, 0, 0.6);
			    font-size: 279px;
			    font-weight: 400;
			    line-height: 270px;
			    text-transform: capitalize;

			    @media screen and (max-width: $medium){
			    	font-size: 125px;
			    	line-height: 175px;
			    }

			    @media screen and (min-width: $medium) and (max-width: 1400px){
			    	font-size: 170px;
    				line-height: 250px;
			    }
	    	}

	    	.caption-header {
	    		font-size: 100px;
	    		line-height: 130px;
	    		margin-bottom: 30px;
	    		@media screen and (max-width: 768px) {
					font-size: 80px;
					line-height: 110px;
		    	}
		    	@media screen and (max-width: 480px) {
					font-size: 65px;
					line-height: 80px;
		    	}
	    	}

	    	.caption-sub-heading {
	    		font-size: 30px;
	    		margin-top: 0px;
	    		font-weight: 400;
	    		letter-spacing: 4px;
				text-transform: uppercase;
	    		@media screen and (max-width: 768px) {
	    			display: none;
	    		}
	    	}

	    	h3{
				dispaly: block;
	    		font-family: 'Lato';
	    		font-weight: 300;
			    text-transform: uppercase;
			    font-size: 45px;
			    letter-spacing: 5px;
			    margin-top: -35px;
			    margin-bottom: 50px;
			    text-shadow: 8px 2px 15px rgba(0,0,0,0.9);

			    @media screen and (max-width: $medium){
			    	font-size: 35px;
			    	margin-bottom: 30px;
                  	margin-top:20px;
			    }
	    	}

	    	p{
	    		font-weight: 300;
			    font-size: 18px;
			    letter-spacing: 1px;
			    margin-bottom: 30px;
			    padding: 0% 18%;
			    text-shadow: 0px 1px 3px rgba(0,0,0,0.9);
	    	}

	    	.blog-title {
	    	background: transparent;
	    	color:#fff;
	    	border: 0px solid transparent;
	    	display:block;
	    	&:hover {
	    	background-color: transparent;
	    	}
	    	}

	    	a {
	    		background: #fff;
    		    color: #7a7a7a;
    		    font-weight: 500;
    		    padding: 7px 17px;
    		    text-transform: uppercase;
    		    border-radius: 20px;
    		    -webkit-transition: 0.15s;
    		    transition: 0.15s;
    		    &:hover {
    		    	background-color: #759193;
    		    	color: #fff;
    		    }
	    	}
	    }
	}
	.smaller-title-items{
		@media screen and (max-width: 768px) {
			.full-height {
				width: 100%;
				height: 100vh !important; //backhere
			}
		}
		.caption-inner{
			width: 70%;

			@media screen and (max-width: $medium){
		    	width: 80%;
			}

			h3{
				font-size: 17px;
			    font-weight: 400;
			    line-height: 26px;
			    margin: 0 0 30px 0;
			    letter-spacing: 2px;
			    font-family: 'Montserrat';
				display: block;
				a{
					padding: 0 40px;
				}
			}

			p{
				font-weight: 300;
				margin-bottom: 40px;
			}
		}
	}
}

