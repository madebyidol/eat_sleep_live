footer{
	//position: absolute;
    //width: 100%;
    background: #fff;
    //bottom: 0;

    .footer-inner{
		padding: 40px 35px;
    }

    ul{
    	list-style-type: none;
    	margin: 0;
    }

    img{
    	display: inline-block;
    	margin: 0 50px;
		
		//@media only screen and (max-width:1777px){
		//	margin: 0 10px;
		//}

    	@media screen and (max-width: 1024px) {
 			display: block;
 			float: right;
 			margin-left: 100%;
 			margin-bottom: 20px;
 			margin-right: 0;
 		}

    	@media screen and (max-width: 768px) {
    		margin-bottom: 20px;
    		margin: 0px auto 20px;
    		float: none;
		    display: block;
    	}

    }

    .footer-newsletter{
    	h4{
    		color:  #7a7a7a;
    		font-size: 14px;
		    letter-spacing: 1px;
		    font-weight: 600;
    	}
    }
    @media screen and (max-width: 1024px) {
    	.footer-newsletter {
	    	width: 70%;
	    	margin: 0px;
	    	display: block;
	    	clear: both;
	    	float: right;
	    	padding-top: 40px;
	    	padding-bottom: 10px;
			h4 {
				text-align: right;
			}
    	}
    }

    @media screen and (max-width: 768px) {
    	.footer-newsletter {
    		float: none;
    		margin: 0px auto;
    		h4 {
				text-align: center;
    		}
    	}
    }

    @media screen and (max-width: 480px) {
    	.footer-newsletter {
    		width: 100%;
    	}
    }

    .footer-images{
    	padding-top: 20px;
    	@media screen and (max-width: 1024px) {
			padding-top: 0px;
    	}
    }

    .sub-bar{
    	background-color: #292929;

    	p{
    		padding: 5px 35px;
    		color:  #8d8d8d !important;
    		font-size: 14px;
    		margin: 0;
    	}
    	@media screen and (max-width: 768px) {
    		padding: 15px 0px;
    		text-align: center;
    		p {
    			color: #fff !important;
    		}
    	}
    }

    .input-group{
    	width: 100%;
    	input{
    		outline: none;
    	}
    	input[type="text"]{
			background-color: #f6f6f6;
		    border-radius: 20px;
		    left: 0;
		    position: absolute;
		    width: 100%;
		    padding: 10px 118px 10px 20px;
    		height: 41px;
    	}
    	input[type="submit"]{
    		position: Absolute;
		    color: #fff;
		    padding: 10px 20px;
		    background-color: #759193;
		    text-transform: uppercase;
		    font-weight: 600;
		    font-size: 12px;
		    letter-spacing: 1px;
		    right: 0;
		    border-top-right-radius: 20px;
		    border-bottom-right-radius: 20px;
		    transition: 0.15s;
		    -webkit-transition: 0.15s;
		    -moz-transition: 0.15s;
		    -ms-transition: 0.15s;
		    &:hover {
		    	background-color: #537071;
		    }
    	}
    }
}

