#offer-banner-mobile{
  display:none;
  position:relative;
  z-index:9999;
  width:100%;
  @media screen and (max-width:1024px){
    display:block;
  }
}

.home-offer-section-mobile{
  display: block;
  background: {{ settings.offer_banner_bg_color }};
  padding: 0;
  width: 100%;
  position:fixed;
  .container{
    padding:5px 40px;
    z-index:0;
    text-align:center;
    a{
      color:#fff;
      @media screen and (max-width:480px){
        font-size: 12px;
      }
    }
  }
  .mobile-close-banner{
    position: absolute;
    right: 10px;
    top: 50%;
    color: #fff;
    z-index: 100;
    transform: translateY(-50%);
  }
}

.template-index{
	.home-offer-section-mobile{
		position: relative;
		.container{
			margin-bottom:15px;
		}
	}
}


@media screen and (max-width: 1024px) {
	.home-offer-section {
		/* display:none !important; */
	    /* background: #d2b057; 
	    background: {{ settings.offer_banner_bg_color }};
	    padding: 10px 0;
	    position: relative;
	    bottom: 0;
	    width: 100%;
	    text-align: center;*/
	}
	.home-offer-section ul li:first-of-type {
		width: 100%;
		text-align: left;
		padding-left: 15px;
	}
}

.mobile-nav{
	@media screen and (max-width: 1024px) {
		.home-offer-section {
			display:block;
			position: relative;
			.ob-text{
				padding:15px;
			}
		}
	}
}


