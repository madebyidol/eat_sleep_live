.fp-controlArrow.fp-prev{
	border: none !important;
	left: 7%;
	&:before{
		content: "\f104";
		-webkit-transition: all 0.5s ease;
		transition: all 0.5s ease;
		font-family: "FontAwesome";
		color: #fff;
		font-size: 45px;
	}
	&:hover:before{
		color: #fff;
	}
}

.fp-controlArrow.fp-next{
	border: none !important;
	right: 7%;
	&:before{
		content: "\f105";
		-webkit-transition: all 0.5s ease;
		transition: all 0.5s ease;
		font-family: "FontAwesome";
		color: #fff;
		font-size: 45px;
	}
	&:hover:before{
		color: #fff;
	}
}

@media screen and (max-width: 768px) {
	.fp-controlArrow.fp-prev,
	.fp-controlArrow.fp-next {
		display: none !important;
	}
}

.cover-height{
	img{
		height: 100%;
		width: auto;
		max-width: none;
	}
}

@media screen and (max-width: 768px) {
