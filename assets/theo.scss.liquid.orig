.home-offer-section{
	display: none;
	background: {{ settings.offer_banner_bg_color }};
	padding: 0;
	position: fixed;
	top: 0;
	width: 100%;
}

.mobile-banner-open{
	.mobile-nav{
		.home-offer-section{
			display:none !important;
		}
	}
}

.ob-text{
	text-align: center;
	color: {{ settings.offer_banner_txt_color }};
	padding: 5px 0;
	letter-spacing: 1px;
	margin: 0;
	text-transform: uppercase;
	display: inline-block;
	width: 100%;

	@media screen and (max-width: 1024px) {
		text-align: left;
		padding-left: 20px;
	}
	
	@media screen and (max-width: 768px){
		font-size: 10px !important;
	}
}

.home-offer-section .remove-section a {
	text-transform: uppercase;
	color: {{ settings.offer_banner_txt_color }};
}


