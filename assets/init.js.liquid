       on: 'click',
       url: zoomImg,
       onZoomIn: function(){
         $('#ImageLarge img.unzoomed').addClass('zoomedIn');
         $('.hideme, #Footer,#MainNav').hide();
         $('.previewImage').css('visibility','hidden');
       },
       onZoomOut: function(){
         $('#ImageLarge img.unzoomed').removeClass('zoomedIn');
         $('.hideme, #Footer,#MainNav').show();
         $('.previewImage').css('visibility','visible');
       }
     });


   },

   before: function(){
     $('#slider li img').trigger('zoom.destroy');
   },

   after: function(){

     var curSlide = $('#slider').data('flexslider').currentSlide
     var zoomImg = $("#slider img:eq("+curSlide+")").data('zoomed');
     $("#slider li:eq("+curSlide+")").zoom({
       on: 'click',
       url: zoomImg,
       onZoomIn: function(){
         $('#ImageLarge img.unzoomed').addClass('zoomedIn');
         $('.hideme, #Footer,#MainNav').hide();
         $('.previewImage').css('visibility','hidden');
       },
       onZoomOut: function(){
         $('#ImageLarge img.unzoomed').removeClass('zoomedIn');
         $('.hideme, #Footer,#MainNav').show();
         $('.previewImage').css('visibility','visible');
       }
     });

   }

 });










