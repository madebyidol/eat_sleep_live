    }

    .fallback-text {
        text-transform: capitalize;
    }
}

.social-icons li {
    margin: 0 ($gutter / 2) ($gutter / 2);
    vertical-align: middle;

    @include at-query ($min, $postSmall) {
        margin-left: 0;
    }

    .icon {
        font-size: 30px;
        line-height: 26px;
