      }
      @media screen and (max-width: 480px) {

      }
      .thumb {
        height: 100%;
        background-size: cover;
        a {
          display: flex;
          display: -webkit-flex;
          display: -moz-flex;
          display: -ms-flexbox;
          align-self: center;
          width: 100%;
          height: 100%;
          transition: 0.15s;
          -webkit-transition: 0.15s;
          -moz-transition: 0.15s;
          -ms-transition: 0.15s;
          position: relative;
          &.darken {
            background-color: rgba(0, 0, 0, 0.5);
          }
          span {
            position: absolute;
            top: 50%;
            left: 50%;
            -webkit-transform: translate(-50%, -50%);
            -ms-transform: translate(-50%, -50%);
            transform: translate(-50%, -50%);
            margin: 0px auto;
            color: #fff;
            font-weight: 700;
            text-transform: uppercase;
          }
        }
      }
    }
  }
  .slick-arrow {
    display: none !important;
   
  }
}

