    &.notes-wrapper {
        display: flex;
        flex-direction: row;
        padding-top: 2em;
        padding-bottom: 2em;

        @media screen and (max-width: $large) {
            flex-direction: column;
        }

        .notes__title {
            width: 15%;
        }

        .notes__text {
            width: 42.5%;
            padding-left: 1em;
            padding-right: 1em;

            @media screen and (max-width: $large) {
                padding-left: 0;
                padding-right: 0;
            }
        }

        @media screen and (max-width: $large) {
            .notes__title,
            .notes__text {
                width: 100%;
                margin-bottom: 1em;
            }

            .notes__text {
                &.notes__text-md.notes__text-larger * {
                    font-size: 18px;
                }
            }
        }

        p {
            margin-bottom: 0 !important;
        }
    }
  
