                padding-left: 0;
            }

            &:last-of-type {
                padding-right: 0;
            }

            &.js-hover-show {
                .site-header__desktop-link {
                    color: $colorBtnPrimary;

                    &:after {
                        width: calc(100% + 20px);
                    }
                }
            }

            &.js-hover-show .site-header__dropdown {
                padding: 35px 65px;
                opacity: 1;
                height: auto;
            }

            .site-header__desktop-link {
                text-align: center;
                cursor: pointer;
                margin: 0;
                color: #434241;
                font-weight: 400;
                font-size: 18px;
                line-height: 24px;
                @extend .spacing-text;
                text-transform: lowercase;
                position: relative;
                transition: color 0.4s ease-out;
                -webkit-transition: color 0.4s ease-out;
                -moz-transition: color 0.4s ease-out;
                -ms-transition: color 0.4s ease-out;

                &:after {
                    content: "";
                    transition: width 0.4s ease-out;
                    -webkit-transition: width 0.4s ease-out;
                    -moz-transition: width 0.4s ease-out;
                    -ms-transition: width 0.4s ease-out;
                    background-color: $colorBtnPrimary;
                    height: 4px;
                    left: -10px;
                    position: absolute;
                    bottom: -13px;
                    width: 0%;
                    z-index: 99;
                }
            }
        }

        .site-header__dropdown {
            overflow: hidden;
            max-height: 80vh;
            margin-top: 0;
            transition: opacity 0.4s ease-out;
            -webkit-transition: opacity 0.4s ease-out;
            -moz-transition: opacity 0.4s ease-out;
            -ms-transition: opacity 0.4s ease-out;
            opacity: 0;
            height: 0;
            @include flexbox;
            width: 100vw;
            position: absolute;
            left: 0;
            top: 100%;
            background-color: white;
        }

        .site-header__products-dropdown {
            .site-header__dropdown-links-title {
                @extend .spacing-text;
                color: $colorBodyTitles;
                
                line-height: 14px;
                text-transform: uppercase;
                min-height: 14px;
            }

            .site-header__dropdown-links {
                margin: 0;

                li {
                    padding: 0;
                    list-style: none;
                    font-size: 12px;
                    font-weight: 400;
                    line-height: 27px;

                    a {
                        color: $colorSecondaryTextBody;
                        transition: color 0.4s ease-out;
                        -webkit-transition: color 0.4s ease-out;
                        -moz-transition: color 0.4s ease-out;
                        -ms-transition: color 0.4s ease-out;
                        position: relative;

                        &:after {
                            content: "";
                            transition: width 0.4s ease-out;
                            -webkit-transition: width 0.4s ease-out;
                            -moz-transition: width 0.4s ease-out;
                            -ms-transition: width 0.4s ease-out;
                            background-color: $colorBtnPrimary;
                            height: 1px;
                            left: 0;
                            position: absolute;
                            bottom: -3px;
                            width: 0%;
                        }

                        &:hover {
                            color: $colorBtnPrimary;

                            &:after {
                                width: 100%;
                            }
                        }
                    }
                }
            }

            .site-header__product-container {
                padding: 0 10px;

                .product-block__title {
                    font-size: 16px;
                }

                img {
                    width: 100%;
                }
            }
        }

        .site-header__image-dropdown {
            .site-header__image-container {
                height: 100%;
                margin: 0 10px;

                .site-header__image {
                    width: 100%;
                    padding-bottom: 66%;
                    background-position: center;
                    background-size: cover;
                    position: relative;

                    .site-header__image-text-container {
                        width: 100%;
                        height: 100%;
                        position: absolute;
                        background-color: rgba(0, 0, 0, 0.5);
                        display: flex;
                        justify-content: center;
                        align-items: center;

                        p {
                            color: #ffffff;
                            font-size: 30px;
                            line-height: 30px;
                            text-align: center;
                            margin: 0;
                        }
                    }
                }
            }
        }

        .site-header__page-container a {
            position: relative;
            width: 100%;
            margin: 0;
            display: inline-block;
            position: relative;

            img {
                display: block;
                width: 100%;
            }

            .site-header__page-info {
                position: absolute;
                height: 100%;
                width: 100%;
                top: 0;
                @include flexbox;
                background-color: rgba(0, 0, 0, 0.5);

                p {
                    color: #ffffff;
                    margin: auto;
                    text-align: center;
                    width: 100%;
                    padding: 0 10px;
                    font-size: 25px;
                    font-weight: 700;
                }

                span {
                    padding-bottom: 25px;
                    position: absolute;
                    bottom: 0;
                    width: 100%;
                    text-align: center;
                    color: #ffffff;
                    @extend .spacing-text;
                    font-size: 16px;
                    text-transform: uppercase;
                }
            }
        }
    }
}

.site-header__search {
