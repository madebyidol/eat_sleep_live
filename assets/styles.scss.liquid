    margin-bottom: 35px;
    position: relative;

    &:before {
        content: "";
        width: 100%;
        height: 100%;
        z-index: 1;
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        background-color: rgba(0,0,0,0.2);

        @media screen and (max-width: $large) {
            background-color: rgba(0,0,0,0);
        }
    }

    @media screen and (max-width: $large) {
        background-color: transparent;
    }

    .collection-header__text-container {
        padding: 88px 13%;
        z-index: 1;
        position: relative;

        @media screen and (max-width: $large) {
            padding: 22px 30px 0 30px;
        }

        .collection-header__sub-title {
            font-size: 22px;
            margin-bottom: 8px;
            letter-spacing: 1px;
            margin-left: 3px;

            @media screen and (max-width: 1200px) {
                margin-bottom: 4px;
                font-size: 17px;
                line-height: 21px;
                margin-left: 2px;
            }
        }

        h1 {
            font-size: 75px;
            line-height: 72px;
            margin-bottom: 0;

            @media screen and (max-width: 1200px) {
                font-size: 32px;
                line-height: 38px;
            }
        }

        .collection-header__sub-title, h1 {
            color: #fff;
            width: 50%;

            @media screen and (max-width: $large) {
                width: 100%;
                color: {{ settings.color_product_title }}
            }
        }
    }

    .collection-header__background-image {
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center center;
        height: 100%;
        width: 100%;
        left: 0;
        top: 0;
        right: 0;
        position: absolute;
        z-index: 0;

        @media screen and (max-width: $large) {
            position: relative;
            padding-bottom: 33%;
        }

        @media screen and (max-width: $medium) {
            padding-bottom: 50%;
        }
    }

    .collection-header__video-container {
        height: 100%;
        width: 100%;
        left: 0;
        top: 0;
        right: 0;
        position: absolute;
        z-index: 0;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;

        & > iframe {
            width: 100%;
        }

        @media screen and (max-width: $large) {
            position: relative;
            height: 0;
            padding-bottom: 33%;

            .background-video .background-video__container .homepage-hero, .background-video .background-video__container video {
                bottom: -25%;
            }
        }

        @media screen and (max-width: $medium) {
            padding-bottom: 50%;
        }
    }
}

.collection-header-2 {
    position: relative;
    padding: 88px 0;

    @media screen and (max-width: 768px) {
        padding-top: 0;
        padding-bottom: 0;
        margin-bottom: 60px;       
    }

    #breadcrumbs {
        max-width: 1264px;

        @media screen and (min-width: 769px) {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            width: 100%;
            z-index: 2;
        }
    }

    .collection-header__text-container.wrapper {
        max-width: calc(1440px - (88px * 2));
    }

    .collection-header__video-container {
        height: 100%;
        width: 50%;
        left: 50%;
        top: 0;
        right: 0;
        position: absolute;
        z-index: 0;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;

        & > iframe {
            width: 100%;
        }

        .background-image__video.background-video {
            width: 100%;
            height: 100%;
            padding: 0;

            .background-video__container {
                position: absolute;
                top: 0%;
                left: 0%;
                width: 100%;
                height: 100%;
            }
        }

        @media screen and (max-width: 768px) {
            display: none;
        }

        @media screen and (min-width: 769px) {
            & + .collection-header__background-image {
                display: none !important;
            }
        }
    }

    .collection-header__background-image {
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center center;
        height: 100%;
        width: 50%;
        left: 50%;
        top: 0;
        right: 0;
        position: absolute;
        z-index: 0;

        @media screen and (max-width: 768px) {
            position: relative;
            display: block;
            padding-bottom: 50%;
            left: initial;
            width: 100%;
            margin-bottom: 16px;
        }
    }

    .collection-header__text-container {
        position: relative;
        z-index: 2;
        font-style: normal;
        color: #808171;

        .collection-header__sub-title {
            width: 45%;
            display: block;
            font-weight: 400;
            font-size: 22px;
            line-height: 29px;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
            margin-left: 3px;

            @media screen and (max-width: $navBreakpoint) {
                font-size: 20px;
                line-height: 25px;
            }

            @media screen and (max-width: 768px) {
                width: initial;
                
                font-weight: 500;
                font-size: 17px;
                line-height: 21px;
                margin-bottom: 4px;
            }
        }

        h1 {
            width: 45%;
            display: block;
            margin: 0;
            font-weight: 500;
            font-size: 56px;
            line-height: 67px;
            letter-spacing: 0.5px;
            font-family: $averia;

            @media screen and (max-width: $navBreakpoint) {
                font-size: 50px;
                line-height: 48px;
            }

            @media screen and (max-width: 768px) {
                width: initial;
                font-weight: 400;
                font-size: 32px;
                line-height: 38px;
            }

            span {
                color: #808171;
            }
        }
    }

    &:after {
        content: "";
        position: absolute;
        left: 0;
        right: 37%;
        top: 0;
        bottom: 0;
        height: 100%;
        width: 63%;
        background: linear-gradient(90.92deg, #F1EEEA 82.47%, rgba(242, 242, 242, 0.92) 84.1%, rgba(242, 242, 242, 0.53125) 90.79%, rgba(242, 242, 242, 0) 99.83%);
        z-index: 1;

        @media screen and (max-width: 768px) {
            display: none;
        }
    }
}

.filter-type {
    .slick-track {
        @include flexbox;
    }

    .slick-list {
        padding-left: 40px;
    }

    &.slick-list--paddingless {
        .slick-list {
            padding-left: 0;
        }
    }

    .filter-type__option {
        width: fit-content;
        width: -moz-fit-content;
        opacity: 0.7;
        position: relative;
        margin: auto auto 0 auto;

        &.filter-type__option--active {
            opacity: 1;

            &:after {
                position: absolute;
                content: "";
                width: 120%;
                height: 2px;
                background-color: $colorBtnPrimary;
                bottom: 10px;
                left: -10%;
            }
        }
    }

    .slick-slide {
        margin: 0 20px;
        height: auto;

        >div {
            height: 100%;

            >a {
                height: 100%;
                display: -webkit-box !important;
                display: -webkit-flex !important;
                display: -moz-flex !important;
                display: -ms-flexbox !important;
                display: flex !important;
                @include align-items(flex-end);
                @include flex-direction(column);
            }
        }

        p {
            font-weight: 700;
            letter-spacing: 0.47px;
            line-height: normal;
            text-transform: uppercase;
            text-align: center;
        }

        img,
        svg {
            margin: 0 auto 15px auto;
            display: block;
            max-width: 32px;
            position: relative;
            width: fit-content;
            width: -moz-fit-content;
        }
    }
}

.m-filter-type {
    background-color: #434241c9;
    top: 0;
    bottom: 0;
    position: fixed;
    overflow-y: scroll;
    overflow-x: hidden;
    z-index: 100000;
    padding: 20px;
    width: 100vw;

    p {
        color: white;
    }

    svg path {
        fill: white;
    }

    .m-filter-type__option-container {
        height: 34vw;
        padding: 4px 2px;

        a {
            width: 100%;
            height: 100%;
            border-radius: 3px;
            border: 1px solid #ffffff;
            @include flexbox;
            @include justify-content(center);
            @include align-items(center);
        }

        svg,
        img {
            margin: 0 auto 13px auto;
            display: block;
            max-width: 50px;
        }

        p {
            margin: 0;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.4px;
            line-height: normal;
            text-align: center;
            text-transform: uppercase;
        }

        &.m-filter-type__option-container--active {
            a {
                background-color: white;
            }

            svg path {
                fill: #434241;
            }

            p {
                color: $colorTextBody;
            }
        }
    }

    .m-filter-type-overlay__header {
        @include flexbox;
        @include justify-content(space-between);
        @include align-items(center);
        margin-bottom: 17px;

        .content-heading {
            line-height: normal;
            margin: 0;
        }

        .m-filter-type-overlay__close {
            @include align-items(center);

            img {
                height: 20px;
            }

            p {
                font-size: 14px;
                font-weight: 400;
                letter-spacing: normal;
                text-transform: none;
                margin: 0 10px 0 0;
                line-height: normal;
                text-align: center;
            }
        }
    }
}

.m-filter-type__toggle {
    margin: 20px 15px;

    .main-button {
        @include justify-content(center);
        width: 100%;
        margin: 0 auto;
        max-width: 600px;

        svg {
            margin-right: 11px;
        }
    }
}

.m-filter {
    @extend .m-filter-type;
    background-color: white;

    .filter-standard__filter-text {
        margin-bottom: 0;
        font-size: 16px;
        font-weight: 700;
        line-height: normal;
    }

    .filter-standard__selected {
        line-height: 1;
        margin-bottom: 0;
        margin-left: auto;
        margin-right: 30px;
    }

    .filter-standard__selector {
        border-bottom: 1px solid #979797;
        position: relative;

        &:after {
            content: url("{{ "chevron-down.svg" | asset_url }}");
            height: 20px;
            width: 20px;
            right: 0;
            position: absolute;
            transform: scale(0.8);
        }

        &.active {
            &:after {
                content: url("{{ "chevron-up.svg" | asset_url }}");
            }
        }
    }

    p {
        color: $colorTextBody;
    }

    a {
        display: block;
        color: $colorTextBody;
        font-size: 14px;
        line-height: normal;
    }

    .filter-standard__option-selected {
        color: $colorBtnPrimary;
    }

    .filter-standard__clear-all {
        margin: auto;
        margin-top: 15px;
        color: $colorBtnSecondary;
        text-align: center;
    }

    .filter-standard__options {
        transition: max-height .4s ease-out, margin .6s ease-out;
        -webkit-transition: max-height .4s ease-out, margin .6s ease-out;
        -moz-transition: max-height .4s ease-out, margin .6s ease-out;
        -ms-transition: max-height .4s ease-out, margin .6s ease-out;
    }

    .filter-standard__selector.active+.filter-standard__options {
        margin-top: 25px;
    }

    svg {
        float: right;
        margin-top: 5px;

        path {
            fill: $colorSecondaryTextBody;
        }
    }
}

.m-filter__toggle {
    @extend .m-filter-type__toggle;
}

.rv_collection-container {
    .block-featured {
        margin-bottom: 40px;
    }
}

.rv_collection {
    .product-block {
        display: none;
    }

    .slick-list .product-block {
        display: inherit;
    }

    .slick-list {
        padding-left: 30px;
        padding-right: 30px;
        margin: 0 -10px;

        @media screen and (max-width: $medium) {
            padding: 0;
            margin: 0;
        }

        .slick-slide {

            .product-block__title {
                font-size: 20px;
                line-height: normal;
                margin-top: 10px;
                margin: 7px 0 5px;

                @media screen and (max-width: $medium) {
                    font-size: 18px;
                }
            }
        }
    }
}

.filter-standard {
    .filter-standard__container {
        position: relative;

        .filter-standard__selector {
            position: relative;
            height: 59px;
            background-color: #ffffff;
            @include align-items(center);
            @include justify-content(space-between);
            padding: 0 40px 0 20px;

            &:after {
                content: url("{{ "chevron-down.svg" | asset_url }}");
                position: absolute;
                font-weight: 300;
                right: 15px;
                font-size: 20px;
                transition: all .2s ease-in-out;
                opacity: 0.6;
            }

            &.active {
                &:after {
                    transform: rotate(180deg);
                }
            }

            .filter-standard__filter-text {
                color: #43424199;
                margin: 0;
                font-size: 15px;
                font-weight: 500;
                line-height: 20px;
                letter-spacing: 0.5px;
            }

            .filter-standard__selected {
                color: #43424199;
                font-size: 16px;
                margin: 0 0 0 7px;
            }
        }

        .filter-standard__options {
            position: absolute;
            background-color: white;
            width: 190px;
            right: 0;
            z-index: 1;
            box-shadow: 0px 0px 4px rgba(0, 0, 0, 0.08);
            border-radius: 4px;

            a {
                display: flex;
                align-items: center;
                color: #43424199;
                font-weight: 500;
                letter-spacing: 0.5px;
                font-size: 15px;
                line-height: normal;
                margin-bottom: 12px;
                transition: color .3s ease-out;
                -webkit-transition: color .3s ease-out;
                -moz-transition: color .3s ease-out;
                -ms-transition: color .3s ease-out;
                position: relative;

                &:before {
                    content: '';
                    width: 14px;
                    height: 14px;
                    border: 1.5px solid #43424199;
                    border-radius: 50%;
                    display: block;
                    margin-right: 5px;
                    background: white;
                    flex: 0 0 auto;
                }

                &:after {
                    content: '';
                    background: url("{{ " check.svg" | asset_url }}");
                    background-repeat: no-repeat;
                    background-size: contain;
                    position: absolute;
                    top: 5px;
                    left: 2px;
                    opacity: 0;
                    width: 10px;
                    height: 10px;
                    flex: 0 0 auto;
                }

                &.selected {
                    &:after {
                        opacity: 1;
                    }

                    &:before {
                        background: #D2B057;
                        border-color: #D2B057;
                    }
                }

                &:hover {
                    color: $colorBtnPrimary;
                }

                &:last-of-type {
                    margin-bottom: 0;
                }
            }

            .filter-standard__clear {
                margin-top: 20px;
                color: $colorTextBody;
                font-size: 16px;
                font-weight: 700;
                letter-spacing: 2.29px;
                text-transform: uppercase;

                &:hover {
                    color: $colorTextBody;
                }
            }
        }

        @media only screen and (max-width: 768px) {
            width: 100%;
            margin-right: 0 !important;

            .filter-standard__selector {
                width: 100%;
            }

            .filter-standard__options {
                position: static;
                padding: 0 15px;
            }
        }
    }

    .filter-standard__container:last-of-type {
        margin-left: auto;
    }
}

.filter-standard__clear-all {
    margin-left: 20px;
    min-width: fit-content;
    min-width: -moz-fit-content;
    color: #D2B057;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-decoration: underline;
    text-decoration-color: #D2B057;
}

.rv_collection-container {
    .block-featured {
        h4 {
            text-align: center;
            margin-top: 90px;
            margin-bottom: 40px;

            @media screen and (max-width: $medium) {
                margin-top: 50px;
            }
        }
    }
}

.product-image__model-container {
    padding: 0 15px 0 40px;

    @media screen and (max-width: $large) {
        padding: 0;

        img {
            width: 100%;
        }
    }

    .product-image__model {
        width: 100%;
        height: calc(50vw - 55px);
        background-color: #f4f5f6;

        @media screen and (max-width: $large) {
            height: calc(100vw - 9px);
            max-height: 100vh;
        }
    }
}

.product-form {
    padding: 20px 80px 20px 0px;
    padding-right: 0;

    @media screen and (max-width: $navBreakpoint) {
        padding: 0px 0 20px 0px;
    }

    @media screen and (max-width: $large) {
        padding: 0px;

        form {
            padding-left: 0px;
        }
    }

    .product-form__legend {
        font-size: 16px;
        font-weight: 700;
        letter-spacing: 2px;
        line-height: normal;
        text-transform: uppercase;

        @media screen and (max-width: $large) {
            font-size: 14px;
            letter-spacing: 1.75px;
        }
    }

    .product-form__legend-inner {
        display: flex;
        flex-flow: row nowrap;
    }

    .product-form__option:not(.product-form__option-colour) {
        border-radius: 4px;
        border: 1px solid rgba(67, 66, 65, 0.5);

        .product-form__unselected-icon,
        .product-form__selected-icon {
            margin-right: 8px;

            svg {
                display: block;
                width: 20px;
                height: auto;
            }
        }

        .product-form__unselected-icon {
            display: inline-block;
        }

        .product-form__selected-icon {
            display: none;
        }

        &.product-form__option--selected {
            border-color: #808171;

            .product-form__unselected-icon {
                display: none;
            }

            .product-form__selected-icon {
                display: inline-block;
            }
        }
    }

    .product-form__quantity {
        width: 33%;
        height: 60px;
        background-color: #f2f2f2;

        .number-input-plus,
        .number-input-minus {
            width: 38%;
            padding: 0 15px;
            text-align: right;
            font-size: 16px;
        }

        .number-input-plus {
            text-align: left;
        }

        .number-input-target {
            width: 24%;
            border: 0;
            background-color: transparent;
            padding: 0;
            text-align: center;
            font-size: 20px;

            @media screen and (max-width: $large) {
                font-size: 16px;
            }
        }
    }

    .product-form__controls-group {
        @media screen and (max-width: $navBreakpoint) {
            margin-top: 20px;
        }

        .product-form__submit {
            flex-grow: 1;
            margin-left: 5px;
            height: inherit;

            @media screen and (max-width: $navBreakpoint) {
                padding: 0 10px;
            }
        }
    }

    .product-form__sticky {
        @media screen and (min-width: $medium) {
            display: none!important;
        }
        position: fixed;
        bottom: 0;
        z-index: 99999;
        left: 0;
        place-content: center;
        width: 100%;
        background-color: #F1EEEA;
    }

    .product-form__sticky-items {
        display: flex;
        align-items: center;
        width: 100%;
        padding: 15px;
        max-height: 75px;
        column-gap: 16px;
    }

    .product-form__sticky-image-container {
        min-width: 80px;
        width: 110px;
        height: 80px;
        flex-shrink: 0;
        background-size: cover;
        background-position: center center;
        margin-top: -20px;
        border-radius: 6px;
    }

    .product-form__sticky-button-container {
        flex-grow: 1;
    }

    @media screen and (max-width: $large) {
        .product-form__button-padding {
            margin-right: 0px;
        }
    }

    .product-form__samples {
        width: 100%;
        height: 60px;

        svg {
            margin-left: 10px;
            width: 12px;
            height: auto;
        }
    }

    .product-form__property {

        label {
            position: relative;
        }

        .product-form__property-input+label {
            height: 75px;

            @media screen and (max-width: $navBreakpoint) {
                height: 55px;
            }
        }

        .product-form__property-input:checked+label {
            .product-form__property-image {
                border: 2px solid #808171;
            }

            .product-form__property-icon {
                display: block;
            }
        }

        .product-form__property-name {
            display: none;
        }

        .product-form__property-icon {
            display: none;
            position: absolute;
            right: 0;
            top: -5px;
        }

        .product-form__property-image {
            width: 48px;
            min-height: 48px;
            border-radius: 100%;
            border: 2px solid #d2b05700;
            padding: 2px;
            transition: border 0.15s ease-out;
            -webkit-transition: border 0.15s ease-out;
            -moz-transition: border 0.15s ease-out;
            -ms-transition: border 0.15s ease-out;

            @media screen and (max-width: $navBreakpoint) {
                min-height: 55px;
                width: 55px;
            }
        }
    }
}

.product-form__quantity {
    width: 33%;
    height: 60px;
    background-color: #f2f2f2;

    .number-input-plus,
    .number-input-minus {
        width: 38%;
        padding: 0 15px;
        text-align: right;
        font-size: 16px;
    }

    .number-input-plus {
        text-align: left;
    }

    .number-input-target {
        width: 24%;
        border: 0;
        background-color: transparent;
        padding: 0;
        text-align: center;
        font-size: 20px;

        @media screen and (max-width: $large) {
            font-size: 16px;
        }
    }
}

.product {
    .product__wrapper {
        max-width: 2000px;
        margin: auto;
        transition: padding-top 0.15s ease-out;
        -webkit-transition: padding-top 0.15s ease-out;
        -moz-transition: padding-top 0.15s ease-out;
        -ms-transition: padding-top 0.15s ease-out;

        @media screen and (max-width: $large) {
            padding-top: 0px;
        }
    }

    .product__half {
        width: 50%;

        @media screen and (max-width: $large) {
            width: 100%;
        }
    }

    .product__title-price {
        @include justify-content(space-between);
        border-bottom: 1px solid $colorBorder;
        padding-bottom: 10px;

        @media screen and (max-width: $large) {
            padding: 20px 20px 0 20px;
        }

        .product-block__wishlist {
            position: relative;
            opacity: 1;

            @media screen and (max-width: $navBreakpoint) {
                width: 32px;
                height: 32px;
                left: 0px;
            }

            .wishl-icon:before {
                height: 60%;
                max-height: 30px;
                margin-top: 0;
                content: "" !important;

                @media screen and (max-width: $navBreakpoint) {
                    height: 100%;
                    width: auto;
                }
            }
        }

        .product__title {
            letter-spacing: -0.13px;
            line-height: normal;
            margin-bottom: 10px;
            padding-right: 10px;
        }

        .product__price {
            font-size: 20px;
            line-height: normal;

            @media screen and (max-width: $large) {
                font-size: 18px;
            }
        }
    }

    .product__single-cta.single-cta {
        height: fit-content;
        height: -moz-fit-content;
        margin: 80px 40px;
        width: unset;
        min-height: unset;

        @media screen and (max-width: $large) {
            margin: 40px 20px;
        }

        p {
            margin-bottom: 0;
        }

        .single-cta__text-container {
            color: $colorSecondaryTextBody;
            max-width: 650px;
            position: relative;
            max-width: 650px;

            @media screen and (max-width: $large) {
                padding: 0;
            }

            .h5 {
                color: $colorBodyTitles;
                margin-bottom: 10px;
                letter-spacing: -0.13px;
                line-height: normal;
            }

            .single-cta__text {
                color: $colorSecondaryTextBody;
            }
        }
    }

    .slick-arrows .slick-arrow.slick-next.product-gallery__arrow {
        right: 40px;
    }

    .slick-arrows .slick-arrow.slick-prev.product-gallery__arrow {
        left: 40px;
    }

    .product__gallery {

        .slick-slide img,
        .block-video video {
            height: 100%;
        }

        .slick-list {
            padding-left: 40px;

            @media screen and (max-width: $medium) {
                padding-left: 20px;
            }
        }

        .slick-slide {
            padding-right: 20px;

            @media screen and (max-width: $medium) {
                padding-right: 10px;
            }
        }

        .product-gallery__slide {
            padding-bottom: 20px;
            height: 48vw;
            margin: 0;

            svg {
                @media screen and (max-width: $medium) {
                    width: 40px;
                }
            }

            &.product-gallery__slide--half {
                height: 24vw;
            }
        }
    }

    .trustpoints {
        padding: 0 70px;
        margin: 90px 0 130px 0;

        @media screen and (max-width: 1200px) {
            padding: 0 10px;
        }

        @media screen and (max-width: $medium) {
            padding: 0;
            margin: 30px 0 30px 0;
        }

        .trustpoints__point {
            margin-top: 40px;
            max-width: 70%;
            transition: 0.15s;
            -webkit-transition: 0.15s;
            -moz-transition: 0.15s;
            -ms-transition: 0.15s;

            &.trustpoints__point-hover:hover {
                margin-top: 0;

                .trustpoints__link {
                    opacity: 1;
                    max-height: 90px;
                }
            }

            .trustpoints__link {
                transition: 0.15s;
                -webkit-transition: 0.15s;
                -moz-transition: 0.15s;
                -ms-transition: 0.15s;
                width: 100%;
                opacity: 0;
                max-height: 0;
            }

            &.trustpoints__point--mobile {
                margin: 0;
                border-top: 1px solid #979797;
                max-width: 100%;
                padding: 20px 40px 20px 15px;

                @media screen and (max-width: $medium) {
                    &:after {
                        content: url("{{ "chevron-down.svg" | asset_url }}");
                        height: 20px;
                        width: 20px;
                        position: absolute;
                        right: 20px;
                        position: absolute;
                        transform: rotate(-90deg);
                    }

                    h6 {
                        margin: 10px 0;
                        color: $colorBodyTitles;
                        font-size: 14px;
                        letter-spacing: normal;
                        line-height: normal;
                    }

                    .trustpoints__image {
                        width: 30px;
                        height: auto;
                        margin: 0 30px 0 0;
                    }
                }
            }
        }
    }

    .faqs {
        background-color: #f2f2f2;
        width: 100%;

        .faqs__container {
            max-width: 1056px;
            margin: auto;
            padding: 130px 40px;

            @media screen and (max-width: $medium) {
                padding: 40px 20px;
            }

            .faqs__title {
                line-height: normal;
                margin-bottom: 50px;

                @media screen and (max-width: $medium) {
                    margin-bottom: 30px;
                }
            }

            .faqs_question-answer {
                padding-bottom: 0;

                .accordion:before {
                    content: url("{{ "chevron-down.svg" | asset_url }}");
                    transform: rotate(0deg);
                    border-right: none;
                }

                .accordion:after {
                    display: none;
                }

                .accordion.active {
                    p {
                        color: $colorBodyTitles;
                    }

                    &:before {
                        border-right: none;
                    }
                }
            }

            .faqs_question {
                font-size: 14px;
                letter-spacing: 2px;
                line-height: normal;
                text-transform: uppercase;
                margin-bottom: 15px;

                @media screen and (max-width: $medium) {
                    font-size: 12px;
                }
            }
        }
    }

    .product__slider {
        .slick-slide {
            margin: 10px;
            width: 60vw;

            @media screen and (max-width: $medium) {
                width: 88vw;
                margin: 5px;
            }
        }

        .single-cta {
            margin: 0px;
            width: 60vw;

            @media screen and (max-width: $medium) {
                width: 88vw;
                height: 137vw;
            }
        }

        .single-cta .single-cta__text-container {
            @media screen and (min-width: $large) {
                bottom: 15%;
                text-align: left;
                left: 10%;
                top: unset;
                right: unset;
                max-width: 90%;

                .h5 {
                    margin-left: 0;
                }

                .main-button {
                    margin: 0;
                }
            }
        }
    }

    .product__yaml {
        margin: 90px 0 80px 0;

        @media screen and (max-width: $medium) {
            margin: 80px 0 40px 0;
        }

        .slick-list {
            margin: 20px 0px;

            h5 {
                font-size: 20px;
                letter-spacing: -0.11px;
                line-height: normal;

                @media screen and (max-width: $medium) {
                    font-size: 18px;
                }
            }

            @media screen and (max-width: $medium) {
                margin: 0px;
            }
        }
    }

    .single-cta.single-cta--full-width {
        min-height: 550px;

        .h1 {
            @media screen and (max-width: $medium) {
                margin-bottom: 24px;
                font-size: 75px;
                letter-spacing: normal;
                line-height: 32px;
            }
        }

        .main-button {
            padding: 0 15px;
        }
    }

    .rv_collection-container .block-featured .h4 {
        margin: 0;
    }
}

.product__price-prefix {
    color: $colorSecondaryTextBody;
    font-size: 14px;

    @media screen and (max-width: $large) {
        font-size: 14px;
    }
}

.sticky-product-hide {
    .product-sticky {
        visibility: hidden;
    }

    .product__wrapper {
        padding-top: 0;
    }
}

.product-sticky {
    position: fixed;
    background-color: #434241;
    color: white;
    width: 100%;
    z-index: 1010;
    overflow: hidden;
    letter-spacing: 1px;
    margin-top: -5px;
    transition: opacity 0.15s ease-out;
    -webkit-transition: opacity 0.15s ease-out;
    -moz-transition: opacity 0.15s ease-out;
    -ms-transition: opacity 0.15s ease-out;
    transform: translateY(-53px);

    @media screen and (max-width: $large) {
        visibility: visible;
    }

    .product-sticky__container {
        @include align-items(center);
        padding: 15px 45px;
        min-height: 74px;

        .product-sticky__title {
            font-size: 20px;
            letter-spacing: -0.11px;
            height: fit-content;
            height: -moz-fit-content;
            margin: 0;
        }

        h6 {
            font-size: 20px;
            letter-spacing: -0.11px;
            margin: 0;
        }

        .product-form__variants-container {
            position: relative;

            &:after {
                content: "";
                height: 26px;
                width: 1px;
                background-color: #ffffff80;
                position: absolute;
                left: 0;
                top: 0;
                bottom: 0;
                margin: auto;
            }
        }

        select {
            text-overflow: ellipsis;
        }

        .product-sticky__select-container,
        form {
            @include align-items(center);
        }

        .product-sticky__legend {
            max-width: 200px;
            opacity: 0.75;
            font-size: 12px;
            font-style: normal;
            letter-spacing: 0.4px;
            line-height: normal;
        }

        .product-form__select {
            max-width: 200px;
            color: white;
            padding: 0;
            border: none;
            font-weight: 700;
            letter-spacing: 0.47px;
            position: relative;
            padding-right: 5px;
            background-image: none;
            font-size: 13px;
            white-space: pre-wrap;
        }

        .product-sticky__property-image {
            width: 41px;
            margin-right: 10px;
            background-color: #434241;
            border-radius: 100%;
        }

        .product-sticky__submit-container {
            margin-left: auto;
            @include align-items(center);

            .product-form__quantity {
                height: unset;
                width: 113px;
                background-color: transparent;
                border: 1px solid #ffffff;

                .number-input-minus,
                .number-input-plus,
                input {
                    color: white;
                }
            }
        }

        .product__price {
            font-size: 18px;
            margin: 0;
        }
    }
}

.product-overlay {
    position: fixed;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 10000000000 !important;
    cursor: pointer;
    overflow-y: scroll;
    overflow-x: hidden;

    &.product-overlay--hide {
        top: 200vh;
    }

    .product-overlay__container {
        width: 78%;
        max-height: 85vh;
        background-color: white;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        -ms-transform: translate(-50%, -50%);
        overflow-y: scroll;
        overflow-x: hidden;

        @media screen and (max-width: 1250px) {
            width: 90%;
        }

        @media screen and (max-width: $large) {
            padding: 20px;
        }

        @media screen and (max-width: $medium) {
            transform: none;
            top: 0;
            left: 0;
            width: 100%;
            max-height: unset;
            min-height: 100vh;
        }

        .product-overlay__close {
            margin-left: auto;
            height: 29px;
        }

        .product-overlay__title {
            font-size: 25px;
            letter-spacing: -0.13px;
            line-height: normal;

            @media screen and (max-width: $large) {
                font-size: 20px;
            }
        }

        .product-overlay__bold-title {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: -0.11px;
            line-height: normal;

            @media screen and (max-width: $large) {
                font-size: 18px;
            }
        }

        .product-overlay__product-details {
            border-right: 1px solid $colorBorderLight;

            @media screen and (max-width: $navBreakpoint) {
                padding: 0;
                border: none;

                .product-overlay__bold-title {
                    max-width: 50%;
                }

                .product-overlay__options-container {
                    margin-top: 15px;
                    border-bottom: 1px solid #9797977a;
                    padding-bottom: 30px;
                }
            }

            .product-upsell__option-name {
                color: $colorSecondaryTextBody;

                @media screen and (max-width: $large) {
                    font-size: 14px;
                }
            }

            .product-upsell__option-value {
                font-weight: 700;
                margin-right: 15px;

                @media screen and (max-width: $large) {
                    font-size: 14px;
                    font-weight: 400;
                }
            }

            .product-upsell__option-block {
                @media screen and (max-width: $large) {
                    display: block;
                }
            }

            .product-overlay__mobile-image-container {
                @include justify-content(center);
                @include flex-direction(column);
                @include flexbox;

                .small--flex {
                    @include flex-direction(row);

                    .product-overlay__mobile-image {
                        flex: 1;
                        max-width: 50%;

                        img {
                            width: 90%;
                        }
                    }

                    .product-overlay__image {
                        @include flexbox;
                        @include align-items(flex-start);
                    }
                }

                @media screen and (max-width: $large) {
                    width: 100%;
                }
            }

            .product-overlay__image {
                width: 35%;
                margin-right: 30px;
                @include align-self(center);

                @media screen and (max-width: $large) {
                    margin-right: 20px;
                    width: 50%;
                }
            }
        }

        .product-overlay__buttons {
            margin-left: 40px;
            margin-top: 20px;

            @media screen and (max-width: $large) {
                margin-left: 0;
            }

            .main-button {
                width: 200px;

                @media screen and (max-width: $navBreakpoint) {
                    width: 100%;
                }
            }
        }

        .product-overlay__price-container {
            padding-left: 10px;
            height: fit-content;
            height: -moz-fit-content;

            @media screen and (max-width: $navBreakpoint) {
                padding-left: 0;
            }
        }

        .product-overlay__price-and-buttons {
            padding-left: 30px;
            margin-top: auto;
            margin-bottom: auto;
        }

        @media screen and (max-width: $navBreakpoint) {
            .product-overlay__price-and-buttons {
                padding: 0;
            }

            .large--flex {
                @include justify-content(flex-end);
            }

            .product-overlay__price-container {
                margin-top: 20px;
            }

            .product__price-prefix {
                font-size: 12px;
            }
        }

        .product-overlay__upsell {
            margin-top: 44px;
            margin-left: -40px;
            margin-right: -40px;
            border-top: 1px solid $colorBorder;

            @media screen and (max-width: $navBreakpoint) {
                border-top: none;

                .product__price {
                    margin-bottom: 20px;
                }
            }

            .product-block__title {
                margin-top: 10px;
                font-size: 16px;
                line-height: normal;
            }
        }

        .slick-list {
            margin-left: 40px;
            margin-right: 20px;

            .slick-slide {
                margin: 0;
                padding-right: 20px;
            }

            @media screen and (max-width: $large) {
                margin: 0;
                padding-left: 20px;

                .slick-slide {
                    padding-right: 0;
                    margin-left: 20px;
                }

                img {
                    padding-bottom: 11px;
                }

                .product-block__title {
                    padding-bottom: 8px;
                }
            }
        }
    }
}

@media only screen and (max-width: 768px) {
    .product-overlay__options-container {
        margin: 0;
        padding: 0;
        border: 0;

        br {
            display: none;
        }
    }
}

@media only screen and (max-width: 650px) {
    .product-overlay__product-details {
        flex-flow: column nowrap;
        justify-content: center;
        align-items: center;
    }
}

.additional-checkout-buttons {
    border-top: 1px solid #434241;
    border-bottom: 1px solid #434241;
    padding: 20px 0;
    margin: 20px 0;

    p {
        font-size: 12px;
        font-weight: 700;
        font-style: normal;
        line-height: normal;
        letter-spacing: 1.5px;
        
        color: #434241;
        text-transform: uppercase;
        text-align: center;
        margin-bottom: 0;
        padding: 5px 15px 15px;
    }
}

.cart {
    position: relative;

    .cart__title {
        font-size: 50px;
        letter-spacing: -0.27px;
        line-height: normal;
        margin-bottom: 75px;

        @media screen and (max-width: $medium) {
            font-size: 30px;
            letter-spacing: -0.16px;
        }
    }

    .cart__line-item {
        margin-bottom: 45px;
        padding-bottom: 45px;
        border-bottom: 1px solid $colorBorderLight;

        &:last-of-type {
            border-bottom: none;
        }

        .cart__form {
            max-width: 100%
        }
    }

    .cart__item-image {
        width: 178px;

        @media screen and (max-width: $medium) {
            width: 111px;
            margin-right: 20px;
        }

        img {
            width: 100%;
        }
    }

    .product-block__title {
        font-size: 20px;
        line-height: normal;
    }

    .product-block__price {
        font-size: 16px;

        @media screen and (max-width: $medium) {
            font-size: 14px;
        }
    }

    .cart__item-content {
        flex: 1;
        overflow: auto;

        .cart__item-variants {
            @extend .product-sticky;
            position: relative;
            background-color: unset;
            color: unset;
            margin-left: -20px;
            margin-top: 0;

            .product-sticky__container {
                padding-left: 20px;
                padding-right: 0;

                .product-form__select {
                    color: $colorTextBody;
                }
            }
        }

        .cart__item-variants--mobile {
            span {
                font-size: 12px;
                letter-spacing: -0.06px;
                padding-left: 3px;
                padding-right: 3px;
                border-left: 1px solid $colorBorderLight;

                &.cart__item-variants--mobile--no-border {
                    border-left: none;
                }

                &.cart__mobile-property {
                    white-space: nowrap;
                }

                .product-sticky__property-image {
                    width: 17px;
                    margin-bottom: -3px;
                }
            }
        }
    }

    .product-form__controls-group {
        width: 100%;
        margin-left: 218px;

        .small-link {
            cursor: pointer;
        }

        @media screen and (max-width: $medium) {
            margin-left: 0;
        }

        .product-form__quantity {
            width: 12%;
            min-width: 90px;
            height: 37px;

            @media screen and (max-width: $medium) {
                width: 111px;
            }
        }

        .cart__edit-button {
            flex: 1;

            p {
                text-align: right;
                width: 100%;
            }
        }
    }

    .product-form__variants-container {
        border-left: 1px solid $colorBorderLight;
        position: relative;

        &:after {
            content: "";
            height: 26px;
            width: 1px;
            background-color: #ffffff80;
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            margin: auto;
        }

        @media screen and (max-width: 920px) {
            border-left: none;
            padding-left: 0;
        }

        &.product-form__variants-container--no-border {
            border-left: 0;
            padding-left: 0;
        }

        svg path {
            stroke: #434241;
        }

        select {
            background-image: none;
        }
    }

    .cart__update-cart {
        margin-left: 218px;
        margin-top: 10px;

        @media screen and (max-width: $medium) {
            margin-left: 0;
        }
    }

    .image-overlay {
        width: 120%;
        z-index: 1000;
        background-color: #ffffffbf;
    }

    .cart__summary-container {
        padding-left: 20px;

        @media screen and (max-width: $medium) {
            width: calc(100% + 20px);
        }

        .cart__summary {
            background-color: #f2f2f2;
            padding: 30px 40px;

            @media screen and (max-width: $navBreakpoint) {
                padding: 20px 15px 20px 15px;
            }

            @media screen and (max-width: $medium) {
                padding: 20px 20px 30px 20px;
            }

            h6 {
                letter-spacing: -0.13px;
                line-height: normal;
                margin-bottom: 30px;
                font-size: 25px;

                @media screen and (max-width: $medium) {
                    font-size: 20px;
                }
            }

            td {
                padding-left: 0;
                padding-right: 0;
                border: none;

                &.cart__summary-value {
                    line-height: normal;
                    text-align: right;
                }

                &.cart__summary-key {
                    @extend .spacing-text;
                    text-align: left;
                    text-transform: uppercase;
                }

                .cart__summary-total {
                    font-size: 14px;
                    font-weight: 700;
                    font-style: normal;
                    letter-spacing: 1.75px;
                    text-transform: uppercase;

                    @media screen and (max-width: $medium) {
                        line-height: normal;
                    }
                }

                &.cart__summary-border {
                    border-bottom: 1px solid $colorBorderLight;
                }

                .product__price-prefix {
                    font-size: 12px;
                    line-height: 14px;
                }

                .product__price .product-price {
                    font-size: 18px;
                    font-weight: 700;
                    letter-spacing: -0.1px;

                    @media screen and (max-width: $medium) {
                        font-size: 16px;
                    }
                }
            }

            .main-button {
                width: 100%;
            }

            .cart__trustmark {
                width: 50%;
                margin-top: 20px;

                @media screen and (max-width: 1300px) {
                    width: 100%;
                }

                @media screen and (max-width: $medium) {
                    width: 50%;
                }

                .cart__trustmark-text {
                    flex: 1;
                    color: $colorSecondaryTextBody;
                    font-size: 10px;
                    font-weight: 700;
                    letter-spacing: 1.25px;
                    line-height: normal;
                    text-transform: uppercase;
                }
            }
        }
    }

    .cart__empty {
        @include justify-content(center);
        @include align-items(center);
        @include flex-direction(column);
        @include flexbox;
        height: 300px;

        @media screen and (max-width: $medium) {
            height: 250px;
        }
    }

    .cart__note {
        @media screen and (max-width: $medium) {
            margin: 0 20px;
        }

        textarea {
            border: 1px solid $colorBorderLight;
            width: 100%;
            height: 113px;
        }
    }

    .cart__payment-icons {
        @include justify-content(space-around);
        padding: 0 20px;
        margin-top: 35px;
        margin-bottom: 45px;

        @media screen and (max-width: $medium) {
            margin-bottom: 35px;
        }

        svg {
            margin: 10px 3px;
        }
    }

    .product .faqs__container {
        padding: 0;
        background-color: white;
        width: 100%;
        max-width: unset;

        @media screen and (max-width: $medium) {
            margin-top: 40px;
        }

        .faqs_question-answer {
            margin-bottom: 40px;
            border-bottom: none;
        }

        .accordion-panel {
            border-bottom: 1px solid #9797977a;
        }
    }

    .cart__contact {
        padding: 25px;
        background-color: #f2f2f2;

        p {
            margin-bottom: 0;

            @media screen and (max-width: $large) {
                text-align: center;
            }
        }

        svg {
            margin-right: 10px;

            @media screen and (max-width: $large) {
                margin: 0 auto 10px auto;
                display: block;
            }
        }
    }
}

.cart__sticky {
    position: fixed;
    width: 100%;
    height: 60px;
    background-color: #434241;
    bottom: 0;
    left: 0;
    z-index: 10000000000;

    .product-price {
        font-size: 16px;
        letter-spacing: -0.09px;
        line-height: normal;
    }

    .cart__sticky__total {
        padding: 13px 0 0 21px;
    }

    .main-button {
        height: 50px;
        width: 100%;
        margin-right: 5px;
    }

    p {
        color: white;
    }
}

.cart-overlay {

    .product-sticky__property-image img,
    img.product-sticky__property-image {
        width: 20px;
    }

    .main-button {
        width: 100%;
    }

    .filter-standard__cart-trigger {
        transition: color 0.15s ease-out;
        -webkit-transition: color 0.15s ease-out;
        -moz-transition: color 0.15s ease-out;
        -ms-transition: color 0.15s ease-out;
    }

    .filter-standard__selected {
        text-align: right;
    }
}

.cart__products {
    .product-block h5 {
        font-size: 20px;
        line-height: normal;
        margin-top: 10px;
        margin-bottom: 4px;

        @media screen and (max-width: $medium) {
            font-size: 18px;
        }
    }
}

.contact-us {
    .contact-us__contact {
        padding-top: 80px;
        padding-bottom: 80px;

        @media screen and (max-width: $medium) {
            padding-top: 30px;
            padding-bottom: 40px;
        }
    }

    .wrapper {
        max-width: 1096px;
    }

    .contact-us__form-container {
