.process-content {
    max-width: calc(100% - ((100% - 1440px) / 2));
    margin: 100px 0 100px auto;
    padding-right: 0;
    padding-left: 40px;
    display: grid;
    grid-template-columns: repeat(16, minmax(0, 1fr));
    column-gap: 1rem;

    @media screen and (max-width: $navBreakpoint) {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        grid-template-rows: repeat(2, 1fr);
        padding-left: 32px;
        padding-right: 32px;
        margin: 60px 0;
    }

    .process__text-content {
        border-radius: 4px;
        margin: 52px 0;
        padding: 102px 32px;
        background-color: white;
        grid-row: 1; 
        z-index: 1;
        grid-column: 1 / 6; 

        h4 {
            font-size: 32px;
            line-height: 42px;
            color: #808171;
        }

        a.main-button {
            text-transform: lowercase;
            font-size: 17px;
            letter-spacing: 0.5px;
            font-weight: normal;

            img {
                width: 18px;
                margin-left: 8px;
                position: relative;
                top: 1px;
            }
        }

        @media screen and (max-width: $navBreakpoint) {
            grid-column: span 3 / span 3;
            margin: 0;
            padding: 32px 0px;
        }

        .subtitle {
            margin: 0;
            text-transform: uppercase;
        }

        p {
            a {
                color: #9F5130;
                text-decoration: underline;
            }
        }
    }

    .process__image-content {
        border-radius: 4px;
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
        grid-column: span 4 / span 4;
        grid-row: 1;
        max-height: 620px;

        @media screen and (max-width: $navBreakpoint) {
            grid-column: span 1 / span 1;
            grid-row: 2;
            max-height: 360px;
            min-height: 360px;
        }

        @media screen and (min-width: $navBreakpointDown) {
            min-height: 620px;
        }
    }


    & > div:nth-child(2) { 
        grid-column: 5 / 9;

        @media screen and (max-width: $navBreakpoint) {
            grid-column: span 1 / span 1;
        }
    }
}

