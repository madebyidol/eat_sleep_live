    width: 0;
    margin-bottom: 0;
    overflow: hidden;
    clip: rect(1px, 1px, 1px, 1px);

    .ie9 &,
    .lt-ie9 & {
        position: static;
        height: auto;
        width: auto;
        margin-bottom: 2px;
        overflow: visible;
