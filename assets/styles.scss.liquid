.icon {
    svg {
        fill: #434241;
    }
}

.icon--gold {
    svg {
        fill: #D2B057;
    }
}

.icon--white {
    svg {
        fill: #ffffff;
    }
}

.icon--grey {
    svg {
        fill: #434241;
    }
}

.icon--light-grey {
    svg {
        fill: #A0A0A0;
    }
}

#shopify-section-footer-blog {
    background-color: {{ settings.color_footer_bg }};
}

.footer-blog {
    background: none;
    padding: 50px 20px;
    color: #fff;

    .footer-blog__inner {
        width: 100%;
        max-width: 1292px;
        margin: 0 auto;
    }

    .footer-blog__title {
        width: 100%;
        display: flex;
        flex-flow: row nowrap;
        align-items: center;
        padding-bottom: 50px;

        @media screen and (max-width: $small) {
            justify-content: center;
            text-align: center;

            &.medium--hide.large--hide {
                padding-top: 15px;
                padding-bottom: 0;
                a {
                    margin-right: auto;
                }
            }
        }

        h3 {
            margin: 0;
            font-size: 32px;
            line-height: 42px;
            font-weight: 400;

        }

        a {
            margin-left: auto;
            color: #fff;
            font-size: 18px;
            font-weight: 500;
            display: flex;
            align-items: center;
            text-transform: lowercase;

            .icon {
                display: flex;
                align-items: center;

                svg {
                    width: 6px;
                    height: auto;
                    margin-left: 5px;
                }
            }
        }
    }

    .footer-blog__articles {
        width: 100%;
        display: flex;
        flex-flow: row nowrap;

        .footer-blog__article-stack {
            display: flex;
            flex-flow: column nowrap;

            .footer-blog__article {
                margin-bottom: 24px;
                margin-left: 0;
            }

            .footer-blog__article:last-of-type {
                margin-bottom: 0;
            }
        }
    }

    .footer-blog__article {
        width: 310px;
        position: relative;
        margin-left: 20px;

        .footer-blog__article-image {
            width: 100%;
            height: 135px;
            border-radius: 4px;
            overflow: hidden;
            position: relative;

            img {
                object-fit: cover;
                width: 100%;
                height: 100%;
                transform: scale(1);
                transition: all .3s ease-in-out;
            }
        }

        .footer-blog__article-image--tag {
            position: absolute;
            bottom: 0;
            right: 0;
            background: #808171;
            border-radius: 4px 0 4px 0;
            color: white;
            display: flex;
            flex-flow: row nowrap;
            align-items: center;
            justify-content: center;
            padding: 0 8px;
            height: 26px;
            z-index: 1;
            font-size: 12px;
            line-height: 14px;
            letter-spacing: 0.2px;

            .icon {
                align-self: center;

                svg {
                    width: 12px;
                    height: 12px;
                    position: relative;
                    top: 2px;
                    margin-right: 3px;
                }
            }
        }

        .footer-blog__article-image:after {
            content: '';
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.3);
            position: absolute;
            top: 0;
            left: 0;
        }

        .footer-blog__article-title {
            position: absolute;
            top: 16px;
            left: 16px;
            font-weight: 400;
            font-size: 22px;
            line-height: 29px;
            letter-spacing: 0.5px;
            color: white;
            max-width: calc(100% - 32px);
        }

        .footer-blog__article-title--full {
            position: static;
            background: white;
        }
    }
    
    .footer-blog__article:hover {
        .footer-blog__article-image {
            img {
                transform: scale(1.1);
            }
        }
    }

    .footer-blog__article--full {
        .footer-blog__article-image {
            height: 294px;
        }
    }

    .footer-blog__article--guide {
        display: flex;
        flex-flow: column nowrap;
        background-color: white;
        border-radius: 4px;
        overflow: hidden;
        
        a {
            width: 100%;
            height: 100%;
            display: flex;
            flex-flow: column nowrap;
        }

        .footer-blog__article-image {
            flex: 0 0 auto;
        }
        
        .footer-blog__article-title {
            color: #434241;
            height: 100%;
            font-size: 18px;
            line-height: 24px;
            padding: 16px;
            display: flex;
            flex-flow: column nowrap;
        }

        .footer-blog__article-title--link {
            margin-top: auto;
            display: flex;
            flex-flow: row nowrap;
            align-items: center;
            color: #A0A0A0;
            font-size: 13px;
            line-height: 18px;
            letter-spacing: 0.5px;

            .icon {
                width: 19px;
                height: 19px;
            }

            svg {
                margin-left: 5px;
                display: block;
                width: 100%;
                height: 100%;
            }
        }
    }

    @media only screen and (max-width: 980px) {
        .footer-blog__articles {
            flex-flow: row wrap;
        }

        .footer-blog__article-stack {
            width: 100%;
            margin-bottom: 20px;

            .footer-blog__article {
                width: 100%;
                border: 0;
            }
        }

        .footer-blog__article.footer-blog__article--full,
        .footer-blog__article.footer-blog__article--guide {
            width: calc(100% / 3 - 14px);
        }

        .footer-blog__article:nth-child(2) {
            margin-left: 0;
        }
    }

    @media only screen and (max-width: 768px) {
        .footer-blog__article.footer-blog__article--full,
        .footer-blog__article.footer-blog__article--guide {
            width: 100%;
            margin: 10px 0;
        }

        .footer-blog__article--full .footer-blog__article-image {
            height: 135px;
        }
    }
}

#shopify-section-footer-blog + #shopify-section-footer .footer {
    padding-top: 20px;
}

#shopify-section-footer .footer {
    padding-top: 50px;
    font-family: $bodyFontStack;
}

.footer {
    padding: 20px;
}

.footer__inner {
    width: 100%;
    max-width: 1292px;
    margin: 0 auto;
    display: flex;
    flex-flow: row nowrap;

    @media only screen and (max-width: 980px) {
        flex-flow: row wrap;
    }
}

.footer h4 {
    font-size: 22px;
    line-height: 29px;
    letter-spacing: 0.5px;
    font-weight: 400;
    margin-bottom: 24px;

    @media only screen and (max-width: 768px) {
        margin-bottom: 27px;
    }
}

.footer__menus {
    display: flex;
    flex-flow: row nowrap;

    @media only screen and (max-width: 980px) {
        width: 60%;
    }

    @media only screen and (max-width: 768px) {
        width: 100%;
        justify-content: center;
    }

    @media only screen and (max-width: 500px) {
        flex-flow: column nowrap;
    }
}

.footer__menu {
    display: flex;
    flex-flow: column nowrap;
    padding-right: 45px;

    @media only screen and (max-width: 500px) {
        padding-bottom: 35px;
    }
}

.footer__menu ul {
    display: flex;
    flex-flow: column nowrap;
    margin: 0;
    padding: 0;
    list-style-type: none;
}

.footer__menu ul li a {
    color: #fff;
    font-size: 15px;
    line-height: 18px;
    letter-spacing: 0.8px;
    font-weight: 400;
    text-transform: capitalize;
}

.footer__address {
    @media only screen and (max-width: 980px) {
        width: 40%;
    }

    @media only screen and (max-width: 768px) {
        width: 100%;
        display: flex;
        flex-flow: column nowrap;
        text-align: center;
    }

    @media only screen and (max-width: 500px) {
        text-align: left;
    }
}

.footer__address-address {
    p {
        margin: 0;
        font-size: 15px;
        letter-spacing: 0.5px;
        line-height: 20px;
    }
    a {
        font-size: 15px;
        letter-spacing: 0.5px;
        line-height: 20px;
    }
    a[href^="tel"]{
        font-size: 15px;
        color:inherit;
        text-decoration:none;
    }
}

.footer__form {
    margin-left: auto;

    @media only screen and (max-width: 980px) {
        width: 100%;
        padding-top: 35px;
        display: flex;
        flex-flow: column nowrap;
        align-items: center;
    }

    @media only screen and (max-width: 500px) {
        align-items: flex-start;
        row-gap: 8px;
    }
}

.footer__form .klaviyo-form {
    position: static;
    width: 420px;
    max-width: 100%;
}

.footer__form form {
    position: relative;
    display: flex;
    flex-flow: row nowrap;
    
    @media only screen and (max-width: 500px) {
        // flex-flow: column nowrap;
        column-gap: 8px;
    }
}

.footer__logos {
    margin-top: 50px;
    display: flex;
    align-items: center;
    gap: 30px;

    @media only screen and (max-width: 768px) {
        margin-top: 27px;
    }

    img {
        height: 30px;
        width: auto;
        display: block;
    }
}

.footer__social-links {
    @include justify-content(flex-start);
    margin-top: 20px;

    @media only screen and (max-width: 980px) {
        @include justify-content(center);
        margin-top: 40px;
    }

    @media only screen and (max-width: 500px) {
        @include justify-content(flex-start);
    }

    ul {
        margin: 0;
        list-style: none;
        gap: 15px;

        li {
            margin: 0;

            .social-icons__link svg {
                display: block;
                height: 20px;
                width: auto;
                fill: #fff;
            }
        }
    }

    .icon__fallback-text {
        display: block;
        visibility: hidden;
        width: 0;
        height: 0;
        overflow: hidden;
    }
}

.footer__lower {
    width: 100%;
}

.footer__lower .footer__inner {
    padding: 30px 0;
    margin-top: 30px;
    border-top: 1px solid white;
}

.footer__lower-menu {
    @media only screen and (max-width: 980px) {
        width: 100%;
    }
}

.footer__lower-menu ul {
    margin: 0;
    padding: 0;
    list-style-type: none;
    display: flex;
    flex-flow: row wrap;
}

.footer__lower-menu ul li {
    padding-right: 70px;

    &.wiro-link > a {
        font-size: 10px;
        text-transform: none;
    }

    @media only screen and (max-width: 980px) {
        width: 50%;
        padding-right: 30px;
    }

    @media only screen and (max-width: 500px) {
        width: 100%;
        padding-right: 0;
    }
}

.footer__lower-menu ul li a {
    color: #fff;
    text-transform: capitalize;
}

.footer__lower-logo {
    margin-left: auto;

    @media only screen and (max-width: 980px) {
        width: 100%;
        margin: 30px 0 0 0;
        display: flex;
        justify-content: center;
    }

    @media only screen and (max-width: 500px) {
        justify-content: flex-start;
    }
}

.product__tab-header {
    width: 100%;
    max-width: 1256px;
    margin: 0 auto;
    display: flex;
    flex-flow: row nowrap;
    padding: 50px 20px 0 20px;
    overflow-y: hidden;
    overflow-x: scroll;

    -ms-overflow-style: none; /* Edge, Internet Explorer */
    scrollbar-width: none; /* Firefox */

    &::-webkit-scrollbar {
        display: none; /* Chrome, Safari, Opera */
    }

    @media screen and (max-width: $medium) {
        padding: 0px 20px;
    }
}

.product__tab-header-item {
    text-transform: lowercase;
    padding: 16px 16px;
    margin: 0 15px;
    font-weight: 400;
    color: #A0A0A0;
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 1.6px;
    position: relative;
    cursor: pointer;
    transition: all .2s ease-in-out;
    flex: 0 0 auto;
}

.product__tab-header-item:after {
    content: '';
    width: 100%;
    height: 0;
    display: block;
    position: absolute;
    bottom: 0;
    left: 0;
    background: #808171;
    border-radius: 3px 3px 0 0;
    transition: all .2s ease-in-out;
}

.product__tab-header-item:hover,
.product__tab-header-item.active {
    font-weight: 700;
    color: #808171;
}

.product__tab-header-item.active:after,
.product__tab-header-item:hover:after {
    height: 3px;
}

.product__tab {
    display: none;

    & > div:last-child {
        padding-bottom: 100px;
    }

    @media screen and (max-width: $medium) {
        & > div:last-child {
            padding-bottom: 50px;
        }
    }
}

.product__tab.active {
    display: block;
}

.product__image-text,
.product__description {
    width: 100%;
    padding: 60px 20px;
    position: relative;
}

.product__description::before,
.product__image-text::before {
    content: '';
    width: 70%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    background-color: #F1EEEA;
    pointer-events: none;
    box-shadow: 0px 8px 15px rgba(96, 97, 112, 0.1);
}

.product__description-inner,
.product__image-text-inner {
    display: flex;
    flex-flow: row nowrap;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
}

.product__description-content,
.product__image-text-content {
    width: 40%;
    display: flex;
    flex-flow: column nowrap;
    //align-items: center;
    justify-content: center;
    padding-right: 90px;
    position: relative;

    .review-heading {
        font-weight: 600;
    }

    @media screen and (max-width: $medium) {
        width: 100%;
        padding: 0;
    }
}

.product__image-text-subtitle {
    width: 100%;
    font-size: 14px;
    line-height: 20px;
    text-transform: uppercase;
    letter-spacing: 1.6px;
}

.product__image-text-title {
    font-size: 32px;
    line-height: 42px;
    color: #434241;
    font-weight: 600;
    
    margin-bottom: 15px;
    width: 100%;
}

.product__image-text-description {
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 0.25px;
    color: #434241;
}

.product__description-image,
.product__image-text-image {
    width: 60%;
    overflow: hidden;

    @media screen and (max-width: $medium) {
      width: 100%;
      margin-top: 16px;
    }
}

.product__description-image img,
.product__image-text-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    position: relative;
    border-radius: 8px;
}

@media only screen and (max-width: 768px) {
    .product__description::before,
    .product__image-text::before {
        content: none;
        display: none;
    }
    
    .product__description-inner,
    .product__image-text-inner {
        flex-flow: column nowrap;
    }

    .product__description-content
    .product__image-text-content {
        width: 100%;
        padding: 0;
    }

    .product__description-image
    .product__image-text-image {
        width: 100%;
    }
}

.product__usps {
    width: 100%;
    padding: 50px 20px;

    .product__usps-inner {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-flow: row nowrap;
    }

    .product__usp {
        padding: 15px;
        width: calc(100% / 3);
        display: flex;
        flex-flow: column nowrap;

        .product__usp-image {
            width: 100%;
            height: 225px;
            border-radius: 8px;
            overflow: hidden;

            img {
                width: 100%;
                height: 100%;
