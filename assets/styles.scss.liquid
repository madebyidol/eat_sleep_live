}

.js-component__slick {
    transition: opacity .5s ease-out;
    -webkit-transition: opacity .5s ease-out;
    -moz-transition: opacity .5s ease-out;
    -ms-transition: opacity .5s ease-out;
}

.slick-hide {
    transition: opacity .5s ease-out;
    -webkit-transition: opacity .5s ease-out;
    -moz-transition: opacity .5s ease-out;
    -ms-transition: opacity .5s ease-out;
    opacity: 0;
    height: 0;

    &.slick-hide-mobile {
        opacity: 1;
        height: auto;

        @media screen and (max-width: $large) {
            opacity: 0;
        }
    }

    &.slick-initialized {
        opacity: 1;
        height: auto;
    }
}

