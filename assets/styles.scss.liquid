.grey-section-bg {
    padding: 80px;
    background-color: {{ settings.color_section_bg }};
    border-radius: 4px;
    box-shadow: 0px 8px 15px rgba(96, 97, 112, 0.1);

    @media screen and (max-width: $medium) {
        padding: 60px 40px;
    }

    @media screen and (max-width: $small) {
        padding: 40px 20px;
    }
}

.text-and-usps {
    margin-bottom: 90px;

    & > div:not(.grey-section-bg) {
        margin-top: 90px;
    }

    h4 {
        color: #808171;
    }

    /* .text-and-usps_text {
        opacity: 0.5;
    } */

    @media screen and (max-width: $small) {
        .grey-section-bg {
            padding-left: 15px;
            padding-right: 15px;
        }
    }

    .flex-stretch {
        -ms-flex-align: stretch;
        -webkit-align-items: stretch;
        -moz-align-items: stretch;
        align-items: stretch;

        @media screen and (max-width: $medium) {
            -webkit-justify-content: center;
            -moz-justify-content: center;
            justify-content: center;
        }

        & > .usp__point .usp__link {
            display: flex;
            justify-content: space-between;
            flex-direction: column;
            height: 100%;
           
            @media screen and (max-width: $small) {
                flex-direction: column;
            }
       }
    }

    @media screen and (max-width: $medium) {
        margin-top: 60px;
        margin-bottom: 60px;

        & > div:not(.grey-section-bg) {
            margin-top: 60px;
        }
    }

    .usp__point {
        margin-top: 70px;
        padding: 0 10px;

        @media screen and (max-width: $small) {
            display: flex;

            & > a {
                display: inherit;
            }
        }

        @media screen and (max-width: $medium) {
            margin-top: 30px;
        }

        .usp__text-content {
            width: 90%;

            @media screen and (max-width: $medium) {
                width: 100%;
            }

            @media screen and (max-width: $small) {
                order: 2;
                align-self: center;

                p:last-child {
                    margin-bottom: 0;
                }
            }

            h6 {
                position: relative;
                font-size: 18px;
                line-height: 24px;
                font-weight: 400;
                color: #434241;

                @media screen and (max-width: $small) {
                    font-size: 17px;
                }

                .usp__icon {
                    display: block;
                    width: 24px;
                    height: auto;
                    position: absolute;
                    left: 0;
                    top: 50%;
                    transform: translateY(-50%);
        
                    & + span {
                        vertical-align: middle;
                        padding-left: 40px;
                        display: block;
                    }
                }
            }

            .usp__text-content_description {
                /* opacity: 0.5; */
                color: #434241;
            }
        }

        .usp__image-container {
            width: 100%;
            height: 0;
            padding: 30% 0;
            overflow: hidden;
            position: relative;

            @media screen and (max-width: $small) {
                width: 100%;
                height: 100px;
                padding: 0;
                order: 1;
                align-self: center;
                flex-shrink: 0;
                margin-bottom: 16px;
                border-radius: 4px;
            }

            &:after {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 120%;
                height: 100%;
                background: linear-gradient(0deg, rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2));
                z-index: 1;
                 /*@media screen and (max-width: $small) {
                   top: 3px;
                    height: 91%;
                }*/
            }

            .usp__image {
                position: absolute;
                display: block;
                width: 120%;
                height: auto;
                max-width: initial;
                top: 50%;
                transform: translateY(-50%) scale(1);
                transition: transform 0.8s ease;
            }
        }

        a {
            &:hover, &:active, &:focus {
                .usp__image {
                    transform: translateY(-50%) scale(1.1);
                }
            }
        }
    }
}

.product__form-usps {
