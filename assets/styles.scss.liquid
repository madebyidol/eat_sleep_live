.samples-header__form-autocomplete {
    margin-top: 12px;
    position: relative;
}

.samples-header__form-autocomplete input{
    margin-top: 12px;
    position: relative;
}

.samples-header__form-autocomplete-results {
    position: absolute;
    top: 44px;
    left: 0;
    width: 100%;
    height: 450px;
    overflow-x: hidden;
    overflow-y: scroll;
    padding: 15px;
    background: white;
    opacity: 0;
    visibility: hidden;
    transition: all .25s ease-in-out;
    z-index: 4;
    border: 1px solid #A0A0A0;
    border-radius: 8px;

    &.active {
        opacity: 1;
        visibility: visible;
    }

    .autocomplete-item {
        padding: 5px 0;
        border-bottom: 1px solid #A0A0A0;
        cursor: pointer;
    }

    .autocomplete-item::last-child {
        border-bottom: 0;
    }
}

.samples-header__form-radio-button {
    position: relative;

    label {
        font-size: 15px;
        line-height: 20px;
        letter-spacing: 0.5px;
        text-transform: lowercase;
        display: flex;
        gap: 0.5em;
        align-items: center;
        color: $colorPrimary;
    }

    label:before {
        content: '';
        width: 15px;
        height: 15px;
        border-radius: 50%;
        border: 0.075em solid currentColor;
    }

    input[type="radio"] {
        position: absolute;
        left: -99999px;
    }

    input[type=radio]:checked + label:after {
        content: '';
        position: absolute;
        top: 50%;
        left: 3px;
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background-color: currentColor;
        transform: translateY(-50%);
    }
}

