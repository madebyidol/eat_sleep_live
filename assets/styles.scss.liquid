    .contact-us__location {
        margin-top: 100px;

        @media screen and (max-width: $medium) {
            margin-top: 40px;
        }

        h4 {
            letter-spacing: -0.17px;
            line-height: normal;
            margin-top: 35px;
            margin-bottom: 10px;

            @media screen and (max-width: $medium) {
                margin-top: 0;
            }
        }

        p {
            @extend .secondary-color;
            margin-bottom: 0;
        }

        .main-button {
            color: white;

            @media screen and (max-width: $medium) {
                width: 100%;
            }
        }

        .contact-us__location-content {
            margin-bottom: 33px;

            @media screen and (max-width: $medium) {
                margin-bottom: 23px;
            }
        }

        .contact-us__location-title {
            color: $colorBodyTitles;
            font-size: 18px;
            font-weight: 700;
            letter-spacing: -0.1px;
            line-height: normal;
            margin-bottom: 10px;
        }

        .contact-us__map-container {
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
            margin-right: -20px;

            @media screen and (max-width: 1200px) {
                margin-right: 0;
            }

            @media screen and (max-width: $medium) {
                margin-top: 40px;
                margin-bottom: 65px;
            }

            .contact-us__location-content {
                padding: 40px 40px 45px 40px;

                @media screen and (max-width: $medium) {
