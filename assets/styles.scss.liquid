/* Hotspot section start */

.hotspot-section {
    padding-top: 20px;
    padding-bottom: 140px;
    background: radial-gradient(36% 52% at 48% 56%, #B8B9A9 0%, #808171 100%);

    @media screen and (max-width: $navBreakpoint) {
        padding-top: 10px;
        padding-bottom: 90px;
    }

    @media screen and (max-width: $medium) {
        padding-top: 0;
        padding-bottom: 50px;
    }

    .main_menu_heading.menu-banner-heading {
        h2 {
            color: #fff;
            font-family: $bodyFontStack;
            font-weight: 400;
        }

        a {
            color: #fff;
            text-align: left;
            display: flex;
            align-items: center;
            gap: 4px;

            svg {
                width: 7px;
                height: auto;
                display: block;
                margin-left: 19px;
            }
        }
    }
}

.hotspot {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    grid-template-rows: minmax(0, 1fr);

    @media screen and (max-width: $navBreakpoint) {
        grid-template-columns: repeat(16, minmax(0, 1fr));
    }

    @media screen and (max-width: $medium) {
        display: block;
    }

    .hotspot__image-container {
        grid-row-start: 1;
        grid-column-start: 1;
        grid-column-end: 7;
        position: relative;

        @media screen and (max-width: $navBreakpoint) {
            grid-column-end: 14;
        }

        .hotspot__image {
            display: block;
            max-width: 100%;
            min-width: 100%;
        }

        .hotspot__image-mobile {
            display: none;
        }

        @media screen and (max-width: $medium) {
            margin-bottom: -30px;

            .hotspot__image {
                display: none;
            }

            .hotspot__image-mobile {
                display: block;
            }
        }
    }

    .slick-dots {
        position: absolute;
        width: 100%;
        height: 100%;
        left: 0;
        right: 0;
        top: 0;
        bottom: 0;
        list-style: none;
        margin: 0;

        li {
            margin: 0;
            
            button {
                position: absolute;
                width: 32px;
                height: 32px;
                opacity: 0.8;
                border: solid 1px #fff;
                border-radius: 50%;
                transform: translateX(-50%) translateY(-50%) scale(1);
                transition: transform 0.3s ease-in-out;
                display: block;

                .hotspot__hotspot-label {
                    visibility: hidden;
                    width: 0;
                    height: 0;
                    overflow: hidden;
                    display: block;
                }

                &:after {
                    content: "";
                    position: absolute;
                    width: 16px;
                    height: 16px;
                    background-color: #fff;
                    border-radius: 50%;
                    top: 50%;
                    left: 50%;
                    transform: translateX(-50%) translateY(-50%) scale(1);
                    transition: transform 0.3s ease-in-out;
                }

            }

            &:hover,
            &.slick-active{
                button {
                    transform: translateX(-50%) translateY(-50%) scale(1.3);

                    &:after {
                        transform: translateX(-50%) translateY(-50%) scale(1.5);
                    }
                }
            }
        }
    }

    .hotspot__slider-container {
        grid-row-start: 1;
        grid-column-start: 6;
        grid-column-end: 8;
        overflow: hidden;
        display: inherit;
        align-items: center;
        justify-content: end;

        @media screen and (max-width: $navBreakpoint) {
            grid-column-start: 11;
            grid-column-end: 16;
        }

        @media screen and (max-width: $medium) {
            padding: 0 20px;
        }
        
        .hotspot__slider {
            max-width: 417px;
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            flex-grow: 0;
            flex-shrink: 0;

            @media screen and (max-width: $medium) {
                margin: auto;
            }
        }
    }

    .hotspot__slick-buttons {
        grid-row-start: 1;
        grid-column-start: 7;
        grid-column-end: 7;
        align-self: end;
        justify-self: end;
        display: flex;
        gap: 17px;

        @media screen and (max-width: $navBreakpoint) {
            grid-column-start: 15;
            grid-column-end: 15;
        }

        @media screen and (max-width: $medium) {
            display: none;
        }

        button {
            color: #fff;
            display: block;
            padding: 5px;
            
            svg {
                display: block;
            }
        }

        button + button svg {
            transform: rotate(180deg);
        }

        .slick-disabled {
            opacity: 0.5;
        }
    }

    & + .wrapper .main_menu_heading.menu-banner-heading {
        padding-bottom: 0;
    }
}

/* Hotspot section end  */




