.site-header__navigation,
.site-header__navigation-inner {
    grid-area: nav;
    width: 100%;
    margin: auto;
}

.site-header__navigation {
    @media only screen and (max-width: $navBreakpoint) {
        position: fixed;
        width: 100vw;
        height: 100vh;
        z-index: 999;
        top: 100%;
        background: white;
        left: -100%;
        transition: all .35s ease-in-out;
        overflow: hidden;
        border-top: 0;
    }
}

.site-header__navigation.active {
    @media only screen and (max-width: $navBreakpoint) {
        left: 0;
        overflow-y: scroll;
    }
}

.site-header__navigation-inner {
    border: 0;
    display: flex;
    flex-flow: row-reverse nowrap;

    @media only screen and (max-width: $navBreakpoint) {
        width: 100%;
        height: 100%;
        border-top: 0;
        flex-flow: column nowrap;
    }
}

.site-header__navigation-mobile-search {
    display: none;

    @media only screen and (max-width: $navBreakpoint) {
        display: flex;
        justify-content: center;

        .site-header__search {
            display: block;
            max-width: 400px;
            padding: 5px 10px;
            position: relative;
            
            button {
                height: 100%;
                right: 10px;
            }
        }
    }
}

.site-header__navigation-list {
    margin: 0;
    display: flex;
    gap: 32px;
    flex-flow: row nowrap;
    list-style-type: none;
    width: 100%;
    justify-content: center;

    @media only screen and (max-width: $navBreakpoint) {
        flex-flow: column nowrap;
    }
}

.site-header__navigation-item {
    margin-bottom: 0;

    > a {
        display: block;
        color: var(--esl-olive);
        line-height: 24px;
        position: relative;
        
        img,
        button {
            display: none;
        }
    }

    > a:after {
        content: "";
        width: 0;
        height: 1px;
        background: #808171;
        position: absolute;
        bottom: 0;
        left: 0;
        margin: 0 auto;
        transition: all .25s ease-in-out;
    }

    button {
        display: none;
    }

    @media only screen and (max-width: $navBreakpoint) {
        width: 100%;
        display: flex;
        flex-flow: row nowrap;
        align-items: center;
        
        > a {
            width: 100%;
            display: flex;
            flex-flow: row nowrap;
            align-items: center;
            
            img,
            button {
                display: block;
            }
        }

        .site-header__navigation-link--no-image {
            padding: 0 10px 0 10px;

            span {
                padding: 0;
            }
        }

        > a:after {
            content: none;
            display: none;
        }

        span {
            padding: 0 30px;
            display: block;
        }

        button {
            display: block;
            margin-left: auto;
            position: relative;
            z-index: 999;
            padding: 20px 30px 20px 20px;
        }

        .mobile-next {
            svg {
                transform: rotate(-90deg);
            }
        }
    }
}

.site-header__navigation-item:hover {

    > a:after {
        width: 100%;
    }

    .site-header__navigation-item-dropdown {
        opacity: 1;
        visibility: visible;
        top: 100%;

        @media only screen and (max-width: $navBreakpoint) {
            top: 0;
            opacity: 1;
            visibility: visible;
        }
    }
}

.site-header__navigation-item--active {
    > a:after {
        content: "";
        width: 100%;
        height: 1px;
        background: #808171;
        position: absolute;
        bottom: 0px;
        left: 0;
        right: 0;
        margin: 0 auto;
        transition: all .25s ease-in-out;
    }

    @media only screen and (max-width: $navBreakpoint) {
        > a:after {
            content: none;
            display: none;
        }
    }
}

.site-header__navigation-item-header {
    display: none;

    @media only screen and (max-width: $navBreakpoint) {
        display: flex;
        width: 100%;
        position: relative;
        z-index: 9;
        justify-content: center;
        background: #f2f2f2;
        padding: 14px 30px;
        align-items: center;
        margin-bottom: 15px;

        .mobile-back {
            margin-left: 0;
            margin-right: auto;

            img {
                transform: rotate(-180deg);
            }
        }

        span {
            text-transform: lowercase;
            color: #434241;
            font-size: 15px;
            line-height: 20px;
            letter-spacing: 0.5px;
            font-family: $bodyFontStack;
            margin-right: auto;
        }
    }
}

.site-header__navigation-item-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: white;
    display: flex;
    flex-flow: row nowrap;
    padding: 50px 0 40px;
    z-index: 2;
    transition: all .25s ease-in-out;
    opacity: 0;
    visibility: hidden;

    @media only screen and (max-width: $navBreakpoint) {
        top: 0;
        left: 150vw;
        width: 100vw;
        flex-flow: column nowrap;
        opacity: 1;
        visibility: visible;
        z-index: 9999;
        padding-top: 0;
        height: 100vh;
        overflow-y: scroll;
    }
}

.site-header__navigation-item-dropdown.active {
    @media only screen and (max-width: $navBreakpoint) {
        left: 0;
    }
}

.site-header__navigation-item-dropdown:before {
    content: '';
    width: 125vw;
    height: 100%;
    position: absolute;
    top: 0;
    left: -25vw;
    background: white;
    z-index: 1;
}

.site-header__navigation-item-dropdown-inner {
    width: 100%;
    display: flex;
    flex-flow: column nowrap;
    position: relative;
    z-index: 2;
    
    @media only screen and (max-width: $navBreakpoint) {
        overflow-y: scroll;
    }
}

.site-header__navigation-child-list {
    position: relative;
    z-index: 2;
    display: flex;
    flex-flow: row nowrap;
    width: 100%;
    padding-right: 100px;

    @media only screen and (max-width: $navBreakpoint) {
        flex-flow: column nowrap;
        padding-right: 0;
    }
}

.site-header__navigation-child-item {
    display: flex;
    flex-flow: column nowrap;
    width: calc(100% / 3);

    & > span {
        color: #a0a0a0;
        font-family: $bodyFontStack;
        font-size: 15px;
        line-height: 20px;
        letter-spacing: 0.5px;
        font-weight: normal;
        text-transform: lowercase;
        margin-bottom: 24px;
    }

    @media only screen and (max-width: $navBreakpoint) {
        width: 100%;

        & > span {
            margin-bottom: 10px;
        }
    }
}

.site-header__navigation-grandchild-list {
    display: flex;
    flex-flow: column nowrap;

    @media only screen and (max-width: $navBreakpoint) {
        padding: 0 30px;
        margin-bottom: 35px;
    }
}

.site-header__navigation-grandchild-item {
    
    a {
        padding: 4px 0;
        font-family: $bodyFontStack;
        font-size: 16px;
        line-height: 24px;
        color: #434241;
        font-weight: 600;
        position: relative;
        width: 100%;
        display: block;

        span {
            display: inline-block;
            width: auto;
            position: relative;
            padding: 0;
        }
    }

    span {
        position: relative;
        font-family: $bodyFontStack;
        font-size: 16px;
        line-height: 24px;
        color: #434241;
        font-weight: 600;
    }
}

@media only screen and (max-width: 1080px) {
    .site-header__navigation-grandchild-item {
    
        a {
            width: 100%;
            display: block;
        }
    }
}

.site-header__navigation-grandchild-item a span:after {
    content: '';
    width: 0%;
    height: 1px;
    background-color: #434241;
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    margin: 0 auto;
    transition: all .25s ease-in-out;
}

.site-header__navigation-grandchild-item a:hover span:after {
    width: 100%;
}

.site-header__navigation-grandchild-item::first-of-type {
    padding-top: 0;
}

.site-header__navigation-image {
    position: relative;
    z-index: 2;
    width: 527px;
    height: 330px;
    overflow: hidden;
    border-radius: 8px;
    margin-left: auto;
    flex: 0 0 auto;

    img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
    }

    a {
        position: absolute;
        bottom: 20px;
        right: 20px;
        background: #808171;
        color: white;
        font-size: 17px;
        line-height: 24px;
        font-weight: normal;
        font-family: $bodyFontStack;
        text-transform: lowercase;
        padding: 12px 25px;
        display: flex;
        align-items: center;

        svg {
            margin-left: 10px;
            transition: all .25s ease-in-out;
            transform: rotate(-90deg);
            width: 13px;
            height: 12px;
            position: relative;
            right: 0;
        }
    }

    @media only screen and (max-width: $navBreakpoint) {
        display: none;
    }
}

.site-header__navigation-image a:hover {
    svg {
        right: -10px;
    }
}

.site-header__navigation-button, .site-header__navigation-image a {
    background: #808171;
    color: #fff;
    font-size: 17px;
    line-height: 24px;
    font-weight: 400;
    text-transform: uppercase;
    padding: 12px 25px;
    display: flex;
    align-items: center;
    margin-top: auto;
    align-self: flex-start;
    margin-top: 16px;
    border-radius: 12px;
    font-family: Lexend Exa, sans-serif;
    font-size: 14px;
    letter-spacing: 1px;

    svg {
        margin-left: 10px;
        transition: all .25s ease-in-out;
        transform: rotate(-90deg);
        width: 13px;
        height: 12px;
        position: relative;
        right: 0;
    }

    @media only screen and (max-width: $navBreakpoint) {
        width: calc(100% - 60px);
        margin: 0 30px;
        justify-content: center;

        span {
            padding: 0;
        }
    }
}

.site-header__navigation-button:hover {
    color: #fff;
  
    svg {
        right: -10px;
    }
}

.site-header__navigation-collection-list {
    width: 100%;
    display: flex;
    flex-flow: row nowrap;
    gap: 20px;
    justify-content: center;

    @media only screen and (max-width: $navBreakpoint) {
        flex-flow: column nowrap;
    }
}

.site-header__navigation-collection-list--small {
    flex-flow: row wrap;
    justify-content: center;

    @media only screen and (max-width: $navBreakpoint) {
        flex-flow: column nowrap;
        align-items: center;
    }
}

.site-header__navigation-collection-item {
    width: calc(100% / 7 - 17px);

    span {
        color: #434241;
        font-family: $bodyFontStack;
        text-transform: capitalize;
        width: 100%;
        display: block;
        text-align: center;
        padding: 0 10px;
        font-size: 16px;
        line-height: 24px;
    }

    @media only screen and (max-width: $navBreakpoint) {
        width: 50%;

        span {
            padding: 0;
            text-align: left;
        }
    }

    @media only screen and (max-width: 568px) {
        max-width: 100%;
        width: 100%;
        padding: 0 30px;
    }
}

.site-header__navigation-collection-item:hover {
    img {
        transform: scale(1.15);
    }
}

.site-header__navigation-collection-item--small {
    width: calc(100% / 8);
    max-width: 152px;

    @media only screen and (max-width: $navBreakpoint) {
        width: 100%;
        max-width: 50%;
    }

    @media only screen and (max-width: 568px) {
        max-width: 100%;
        padding: 0 30px;
    }
}

.site-header__navigation-collection-item-image {
    width: 100%;
    height: 142px;
    overflow: hidden;
    margin-bottom: 8px;

    img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        transition: all .35s ease-in-out;
        border-radius: 8px;
    }
}

.site-header__mobile-list {
    display: none;
    
    @media only screen and (max-width: $navBreakpoint) {
        display: flex;
        flex-flow: column nowrap;
        margin-top: 30px;
        margin-left: 0;

        li {
            padding: 10px 10px 20px;

            a {
                padding: 0;
            }
        }

        span {
            padding: 0 0 0 10px;
        }
    }
}

.shopify-section.klarna + .shopify-section.hotspot-section {
    margin-top: 80px;

    @media screen and (max-width: $medium) {
        margin-top: 60px;
    }

    @media screen and (max-width: $small) {
        margin-top: 30px;
    }
}

// samples page
.shopify-challenge__container {
    padding-top: 100px;
    padding-bottom: 100px;
}

.shopify-challenge__container .shopify-challenge__button {
