.breadcrumbs {
    padding: 16px 0;
    margin: 0;

    .breadcrumbs__list {
        list-style-type: none;
        margin: 0;
        padding: 0;

        .breadcrumbs__item {
            display: inline-block;
            
            &:not(:last-child):after {
                border-style: solid;
                border-color: #434241;
                opacity: 0.5;
                border-width: 1px 1px 0 0;
                content: '';
                display: inline-block;
                height: 5px;
                margin: 0 .8em 0 0.50em;
                position: relative;
                transform: rotate(45deg);
                vertical-align: middle;
