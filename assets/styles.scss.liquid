.product-overview {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 60px;
    padding-top: 28px;

    @media screen and (max-width: 1200px) {
      gap: 30px;
    }

    @media screen and (max-width: $medium) {
        gap: 30px;
        grid-template-columns: repeat(1, minmax(0, 1fr));
        padding-top: 20px;
    }

    @media screen and (max-width: $medium) {
        padding-left: 30px;
        padding-right: 30px;

        .prev-container{
            .slick-arrow {
                position: absolute;
                background: white;
                padding: 5px;
                width: 30px;
                height: 30px;
                left: 16rem;
                bottom: -150px;
                z-index: 9;
                border-radius: 50%;
                display: flex!important;
                align-items: center;
                justify-content: center;
            }
        }
    }

    .product-overview__images {
        padding-top: 30px;

        @media screen and (max-width: $navBreakpointDown) {
            padding-top: 0px;
        }

        .product-image__container {
            position: relative;

            @media screen and (max-width: $medium) {
                &:before {
                    content: "";
                    position: absolute;
                    background: rgba(117, 144, 146, 0.05);
                    height: 233px;
                    bottom: 15px;
                    width: 100%;
                    right: 0;
                    left: 0;
                }
            }

            img {
                border-radius: 4px;
                height: auto;
                aspect-ratio: 148 / 99;
            }

            .product-image__image-container {

                @media screen and (max-width: $medium) {
                    padding-left: 0px;
                    padding-right: 0px;
                }

                img {
                    object-fit: cover;
                    width: 100%;
                    height: 100%;
                    aspect-ratio: 148 / 99;
                }

                .slick-arrow {
                    position: absolute;
                    top: 50%;
                    transform: translateY(-50%);
                    width: 35px;
                    height: 35px;
                    border-radius: 50%;
                    background: white;
                    z-index: 1;
                    display: flex;
                    align-items: center;
                    justify-content: center;

                    svg {
                        fill: black;
                    }
                }

                .slick-next {
                    right: 15px;

                    svg {
                        transform: rotate(180deg);
                        height: 10px;
                    }

                    @media only screen and (max-width: 768px) {
                        right: 30px;
                    }
                }

                .slick-prev {
                    left: 15px;

                    svg {
                        transform: rotate(0deg);
                        height: 10px;
                    }

                    @media only screen and (max-width: 768px) {
                        left: 30px;
                    }
                }
            }

            .img-slide__info {
                background-color: #f1eeea;
                border-radius: 4px;
                padding: 4px;
                display: flex;
                width: 100%;
                justify-content: center;
                white-space: normal;
                height: fit-content;
                margin: 8px 0 0 0;
                text-align: center;

                @media only screen and (max-width: 768px) {
                    max-height: fit-content;
                    height: 36px;
                    align-items: center;
                    white-space: unset;
                    width: max-content;
                    max-width: 90%;
                    width: 90%;
                    margin: 8px auto;
                }

                span {
                    font-size: 10px;
                    line-height: 14px;
                    letter-spacing: 0.2px;
                    text-transform: lowercase;
                    color: #808171;
                }

                .info__title {
                    font-weight: 600;
                }
            }

            .product-image__render-message-container {
                line-height: 1;
                position: absolute;
                bottom: 16px;
                left: 16px;
            }

            .product-image__render-container {
                position: absolute;
                top: 0;
                left: 0;
                z-index: 1;
                display: none; 

                .img-slide {
                    margin: -5px;
                    display: none;
                }
            }

            .product-image__render-message {
                font-size: 10px;
                line-height: 14px;
                letter-spacing: 0.2px;
                color: #434241;
            }

            .img-slide__full-view {
                position: absolute;
                background: white;
                top: 10px;
                right: 10px;
                z-index: 2;
                width: 30px;
                height: 30px;
                padding: 7px;
                border-radius: 5px;
            }

            .product-image__thumbnail-container {
                overflow: hidden;
                z-index: 2;
                padding-top: 8px;

                @media screen and (max-width: $medium) {
                    padding-left: 20px;
                    padding-right: 20px;
                }
                
                .slick-list {
                    margin: 0 0 0 -36px;

                    @media screen and (max-width: $navBreakpointDown) {
                        margin: 0 0 0 -68px;
                    }

                    @media screen and (max-width: $small) {
                        overflow: visible;
                        margin: 0 0 0 -54px;
                    }
                
                    .slick-slide {
                        margin: 0 4px;
                        filter: brightness(50%);
                        transition: filter 0.5s ease;

                        &.slick-current {
                            filter: brightness(100%);
                        }
                    }        
                }
            }
        }
    }

    .product-overview__summary {
        display: flex;
        flex-flow: column nowrap;

        @media screen and (max-width: $medium) {
            padding-left: 0;
            padding-right: 0;
        }
    }

    .product-overview__title {
        font-size: 40px;
        line-height: 55px;
        color: #808171;
        font-weight: normal;
        
        @media screen and (max-width: $navBreakpointDown) {
            font-size: 32px;
            line-height: 42px;
        }

        @media screen and (max-width: $medium) {
            font-size: 20px;
            line-height: 27px;
        }
    }

    .product-overview__price {
        font-size: 30px;
        line-height: 50px;
        color: #434241;
        font-weight: normal;
        margin-bottom: 20px;

		/* for sale price */
		display: flex;
		gap: 25px;
		flex-direction: row;
		align-items: start;

		@media screen and (max-width: $medium) {
            flex-direction: column;
			gap: 0px;

			.strike {
				line-height: 1;
				margin-bottom: 15px;
			}
        }

    }

    .product-overview__tagline {
        color: #808171;
        font-size: 18px;
        line-height: 22px;
        letter-spacing: 1px;
        margin-bottom: 40px;
        text-transform: uppercase;
        font-weight: 600;

        @media screen and (max-width: $medium) {
            text-align: center;
            font-size: 14px;
            line-height: 17px;
        }
    }

    form {       
        .product-form__options {
            display: flex;
            flex-flow: column nowrap;
        }

        .product-upsell-option {
            margin-bottom: 36px;
        }
        
        .product-form__option {
            display: flex;
            flex-flow: column nowrap;

            &.product-form__option-colour,
            &.product-form__option-handle {
                .product-form__option-name .product-form__selected-option img {
                    margin-left: 26px;
                    margin-right: 7px;
                    width: 19px;
                    height: auto;
                    border-radius: 50%;
                    display: block;

                    @media screen and (max-width: $medium) {
                        margin-left: 0px;
                    }
                }

                .product-form__option-wrapper {
                    display: flex;
                    gap: 10px;
                }
            }

            &.product-form__option-colour {
                .product-form__option-wrapper {
                    @media screen and (max-width: $medium) {
                        display:grid;
                        justify-items: center;
                        grid-template-columns: repeat(3, minmax(0, 1fr))
                    }

                    .product-form__option-input {
                        
                        label {
                            padding: 0;
                        }
                    }
                }
                
                
            }
        }

        .product-form__option-name {
            width: 100%;
            color: #434241;
            margin-bottom: 10px;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            cursor: pointer;

            .product-form__property-image {
              margin-left: 0 !important;
            }

            @media screen and (max-width: $medium) {
                margin-bottom: 20px;
                row-gap: 12px;
                grid-template-areas: 
                    "p p p"
                    ". selected svg";
                grid-template-columns: 28px auto 28px;
            }
            
            p {
                font-size: 18px;
                line-height: 24px;
                letter-spacing: 1px;
                font-weight: 500;
                text-transform: uppercase;
                margin: 0;
                
                span {
                    font-weight: 600;
                }

                @media screen and (max-width: $medium) {
                    grid-area: p;
                    font-size: 14px;
                    line-height: 17px;
                    letter-spacing: 2.25px;
                    text-align: center;
                }
            }

            svg {
                display: inline;
                vertical-align: bottom;
                margin-left: 10px;
                margin-right: 10px;
                height: 24px;
                width: auto;
                visibility: hidden;

                @media screen and (max-width: $medium) {
                    grid-area: svg;
                    justify-self: end;
                    height: 18px;
                }
            }

            &.closed svg {
                visibility: visible;
            }

            .product-form__selected-option {
                justify-self: end;
                display: flex;
                align-items: center;

                @media screen and (max-width: $medium) {
                    grid-area: selected;
                    justify-self: center;
                }

                span {
                    font-weight: 400;
                    font-size: 13px;
                    line-height: 19px;
                    text-align: right;
                    letter-spacing: 0.5px;
                    color: rgba(67, 66, 65, 0.7);
                    text-transform: capitalize;
                    display: block;
                    pointer-events: none;
                }
            }
        }

        .product-form__option-wrapper {
            display: grid;
            width: 100%;
            column-gap: 16px;
            row-gap: 25px;
            padding: 10px 0;
            grid-template-columns: repeat(3, minmax(0, 1fr));

            @media screen and (max-width: $navBreakpointDown) {               
                row-gap: 16px;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                justify-content: center;
            }
        }

        // .product-form__option-input {
        //     height: 100%;
        // }

        .product-form__option-price {
            margin-top: 3px;
            padding-left: 12px;

            @media screen and (max-width: $medium) {
                font-size: 13px;
                line-height: 18px;
            }
        }

        .product-form__option-input {
            input[type=radio] {
                position: absolute;
                left: -9999px;
            }

            label { 
                font-size: 13px;
                line-height: 18px;
                letter-spacing: 0.5px;
                position: relative;
                padding: 12px;
                height: 100%;
            }

        }

        [data-upsell-option="Wood Colour"] {
            .product-form__option {
               .product-form__option-wrapper {
                    .product-form__option-inner:nth-of-type(2) .product-form__option-input label img {
                        object-fit: none;
                    }
               } 
            }
        } 
    }
    
    #splitit-container {
        width: 100%;
        padding: 8px 20px;
        background-color: #F2F2F2;
        display: flex;
        align-items: center;
        justify-content: center;
