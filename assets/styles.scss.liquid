    }

    &.general-page__banner--no-image {
        .general-page--heading {
            color: #808171;
        }
    }

    .general-page--heading {
        color: white;
        font-size: 57px;
        font-family: "Averia Serif Libre", 'Times New Roman', Times, serif;
