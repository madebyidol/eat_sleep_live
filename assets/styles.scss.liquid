            @media screen and (max-width: $medium) {
                margin-right: 20px;
            }
        }

        .contact-us__details {
            border-bottom: 1px solid #9797977a;
            margin-top: 30px;

            @media screen and (max-width: $medium) {
                margin-top: 20px;
            }
        }

        h6 {
            letter-spacing: -0.1px;
        }

        .footer__social-links {
            @include justify-content(flex-start);

            .footer__social-link {
