                @media only screen and (max-width: 1050px) {
                    &.cst_hotspot_btn {
                        display: none;
                    }
                }
            }
        }

        h4.menu_price {
            color: #555453;
            padding-left: 0;
            padding-bottom: 0;
            font-size: 16px;
            font-weight: 400;
        }

        @media screen and (max-width: $medium) {
            flex-flow: row wrap;

            .cst_hotspot_btn {
                margin-left: 0;
                display: none;

                & > span {
                    visibility: hidden;
                    width: 0;
                    overflow: hidden;
                }
            }
        }

        .custom-colors {
            display: grid;
            grid-template-columns: repeat(5, 16px);

            @media screen and (max-width: $medium) {
                grid-template-columns: repeat(5, 8px);
            }
        }

        .custom-colors + .custom-colors {
            transform: translateX(-16px);

            @media screen and (max-width: $medium) {
                transform: translateX(-8px);
            }
        }

        .custom-colors__item {
            width: 32px;
            height: 32px;
            position: relative;
            border-radius: 50%;
            overflow: hidden;
            align-self: center;
            grid-column: span 2 / span 2;
            grid-row: 1;

            @media screen and (max-width: $medium) {
                width: 22px;
                height: 22px;
            }

            img {
                width: 100%;
                height: auto;
                display: block;
            }
        }
        
        @for $i from 1 through 8 {
            .custom-colors__item:nth-child(#{$i}) {
                grid-column-start: #{$i};
                grid-column-end: #{$i + 1};
            }
        }

        .custom-colours__count {
            margin-right: 12px;
        }

        .custom-colours__count,
        p {
            font-weight: 400;
            font-size: 13px;
            line-height: 18px;
            letter-spacing: 0.5px;
            color: #759092;
            display: flex;
            align-items: center;
            margin-bottom: 0;

            @media screen and (max-width: $medium) {
                font-size: 16px;
                margin-bottom: 0;
            }
        }

        svg {
            margin-right: 5px;
        }

        .product-block__icon {
            border-left: 1px solid #979797;
            padding-left: 5px;

            &.product-block__icon--borderless {
                border-left: none;
                padding-left: 0;
            }
        }

        .cst_hotspot_btn {
            transition: opacity .3s ease-out;
            -webkit-transition: opacity .3s ease-out;
            -moz-transition: opacity .3s ease-out;
            -ms-transition: opacity .3s ease-out;
            visibility: visible;
            opacity: 0;
            font-size: 15px;
            line-height: 20px;
            padding: 8px 16px 8px 16px;
            width: auto;
        }
    }
}

