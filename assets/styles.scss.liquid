}
// General Page Banner section : END

// Image content column section : BEGIN
.image-content-column--warranty-text-mobile {
    display: none;
    font-size: 13px;
    margin-top: 1rem
}

.image-content-column--warranty-text-desktop {
    font-size: 13px;
    margin-top: 2rem
}

.image-content-column--content svg {
    margin-bottom: 15px;
}

.image-content-column--cta {
    margin-top: 1rem;
}

.image-content-column--heading {
    font-size: 32px;
    line-height: 42px;
    color: #808171;
}

.image-content-column--content {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.image-content-column__container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
    padding: 3rem 6rem;
    background-color: #F1EEEA;
    border-radius: 15px;
    box-shadow: 0 0 0 #fff;
}

.image-content-column--image {
    width: 100%;
}

.image-content-column-content__container .image-content-column--content a {
	font-weight: 400;
	font-size: 16px;
	line-height: 24px;
	color: #434241;
}

.image-content-column-content__container .image-content-column--content a:hover,
.image-content-column-content__container .image-content-column--content a:focus,
.image-content-column-content__container .image-content-column--content a:active {
	color: #ca7551;
}

@media screen and (max-width: 1080px) {
    .image-content-column__container {
        grid-template-columns: repeat(1, 1fr);
        padding: 2rem;
    }

    .image-content-column-content__container {
        grid-row: 1;
    }

    .image-content-column--warranty-text-desktop {
        display: none;
    }

    .image-content-column--warranty-text-mobile {
        display: block;
    }
}
// Image content column section : END

// FAQs section : BEGIN
.faq-wrapper {
    max-width: 1080px;
    padding: 30px;
    margin: auto;

    .frequently-asked-question--heading {
        font-size: 32px;
        line-height: 42px;
        color: #808171;
        text-align: center;

        @media screen and (max-width: $small) {
            font-size: 20px;
        }
    }

    .frequently-asked-question {
        margin-top: 5rem;
        margin-bottom: 5rem;

        .frequenlty-asked-question__container {
            margin-top: 1rem;

            .faq-accordion--card.active {
                box-shadow: 0px 4px 8px 0px #60617029;
                border-radius: 4px;
                overflow: hidden;
            }

            .faq-accordion--card {
                .faq-panel {
                    padding: 0 18px;
                    background-color: white;
                    max-height: 0;
                    overflow: hidden;
                    transition: max-height 0.2s ease-out;
                    color: #434241;

                    p {
                        padding-left: 1rem;
                        font-size: 14px;
                    }
                }

                .faq-accordion.active { 
                    .faq-accordion-icon {
                        transition: 0.5s;
                        transform: rotate(45deg);
                    }
                }

                .faq-accordion {
                    cursor: pointer;
                    padding: 18px;
                    width: 100%;
                    border: none;
                    text-align: left;
                    outline: none;
                    font-size: 15px;
                    transition: 0.4s;
                    transition: 0.5s;

                    .faq-accordion-icon {
                        transition: 0.5s;
                    }
                }

                .accordion-heading {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    color: #808171;
                }
            }
        }
    }
}
// FAQs section : END

// Custom Image Text section : BEGIN
.custom-image-text {
    margin-top: 3rem; 

	.product__description-image {
		img {
			display: block;
		}
	}

    @media screen and (max-width: $medium) {
        margin-top: 0rem; 

		.product__description {
			padding: 40px 30px 0 30px;
			margin: 0 auto 40px auto;
		}

		.product__description::before {
			display: block;
			content: '' !important;
			width: 100%;
			height: 80%;
		}

		.product__description-image {
			width: 100%;
			margin-top: 2rem;
		}
	}
}
// Custom Image Text section : END

// Card Column section : BEGIN
.card-column {
    margin-top: 5rem;

    @media screen and (max-width: $medium) {
        margin-top: 40px;
    }

    .card-column__heading {
        font-size: 32px;
        line-height: 42px;
        color: #808171;
        text-align: center;
        margin-bottom: 1rem;

		@media screen and (max-width: $medium) {
			font-size: 20px;
			line-height: 27px;
			margin-bottom: 2rem;
		}
    }

    .card-column__content-container.quad-block {
      
      .card-column__card {
          width: calc(100% / 2);
      
          @media screen and (max-width: $medium) {
            width: calc(100% / 1);
            flex-flow: row nowrap;
        }

        .card-column__thumbnail {
          height: 350px;

          @media screen and (max-width: $medium) {
            height: 75px;
          }
        }
      }
    }

    .card-column__content-container {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 3rem;

		@media screen and (max-width: $medium) {
			margin-top: 2rem;
		}

        .card-column__card {
            padding: 15px;
            width: calc(100% / 3);
            display: flex;
            flex-flow: column nowrap;
			column-gap: 1rem;

            
            @media screen and (max-width: $medium) {
                width: calc(100% / 1);
                flex-flow: row nowrap;
            }

            .card-column__thumbnail {
                width: 100%;
                height: 225px;
                border-radius: 8px;
                overflow: hidden;

                @media screen and (max-width: $medium) {
                    width: 95px;
                    height: 75px;
                    flex: 0 0 auto;
                }

                .card-column__img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }
            }

            .card-column__card__heading {
                font-weight: 600;
                color: #808170;

                @media screen and (max-width: $medium) {
                    margin-bottom: 0;
                }

            }

            .card-column__card__description {
                font-size: 16px;
                line-height: 24px;
                font-weight: 400;
                letter-spacing: .25px;
                opacity: .5;

                @media screen and (max-width: $medium) {
                    font-size: 14px;
					margin-bottom: 0;
                }
            }

            .card-column__card__content {
                width: 90%;
				padding: 24px;
                display: flex;
                flex-flow: column nowrap;
                position: relative;
                transform: translateY(-30px);
                background-color: #fff;
                border-radius: 8px 0 8px 8px;
                align-self: flex-end;

                @media screen and (max-width: $medium) {
                    width: 100%;
					transform: translateY(-5px);
					padding: 0;
                }
            }
        }
    }

}
// Card Column section : END

// Section CTA section : BEGIN
.section-cta {
    background-color: #F1EEEA;

    .section-cta__content {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: center;
        padding: 5rem 1rem;

        .section-cta__heading {
            font-size: 32px;
            line-height: 42px;
            color: #808171;
            text-align: center;
        }

        .section-cta__description {
            max-width: 520px;
            text-align: center;
            margin-bottom: 1rem;
        }
    }
}
// Section CTA section : END

// Content tabs section : BEGIN
.section-heading {
    max-width: 1200px;
    margin: auto;
    margin-top: 2.5rem;

    @media screen and (max-width: $medium) {
        padding: 0rem 1rem;
        text-align: center;
    }

	.section-heading__content {
		max-width: 750px;
	}

	.section-heading__content--left {
		margin-right: auto;
		text-align: left;
	}

	.section-heading__content--right {
		margin-left: auto;
		text-align: right;
	}

	.section-heading__content--center {
		margin: auto;
		text-align: center;
	}

    .section-heading__text {
        color: #808171;

		@media screen and (max-width: $medium) {
			font-size: 20px;
			line-height: 27px;
		}
    }
}

.title-with-icon {
    font-weight: 400;
    font-size: 22px;
    line-height: 29px;
    display: flex;
    align-items: center;
    gap: 8px;

    img {
        width: 24px;
        height: auto;
        display: block;
    }
}
// Content tabs section : END

// Text section : BEGIN
.text-section {
    .text-section__content {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: center;
        padding: 0rem 1rem;


        .text-section__heading {
            font-size: 32px;
            line-height: 42px;
            color: #808171;
            text-align: center;
        }

        .text-section__description {
            max-width: 520px;
            text-align: center;
            margin-bottom: 1rem;
        }

        .text-section__description a{
            text-decoration: underline;
            color: #9f5130;
        }
    }
}
// Text section : END

// Text imgage column section : BEGIN
.text-image-section {
    .text-image-section__content {
        display: grid;
        gap: 4rem;
        padding-top: 3rem;
        padding-bottom: 3rem;
        align-items: center;
        grid-template-columns: (repeat(2, 1fr));

        @media screen and (max-width: $medium) {
           flex-direction: column-reverse!important;
           grid-template-columns: 1fr;
           grid-template-areas: 
            "text"
            "image" !important;
           gap: 1rem;
        }

        .text-image-section__image {
            grid-area: image;
            width: 100%;

            img {
                width: 100%;
              border-radius: .4rem;
            }
        }

        .text-image-section__text {
            width: 100%;
            grid-area: text;
        }

        .text-image-section__heading {
            color: #808170;
            font-size: 22px;
            line-height: 29px;
            font-weight: 600;
        }

        .text-image-section__description {
            color: #434241;
            /* opacity: 0.5; */
        }

    }
}
// Text imgage column section : END

// Please note section : BEGIN
