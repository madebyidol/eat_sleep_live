.product-block__wishlist {
    transition: background-color .3s ease-out;
    -webkit-transition: background-color .3s ease-out;
    -moz-transition: background-color .3s ease-out;
    -ms-transition: background-color .3s ease-out;
    position: absolute;
    background-color: rgba(242, 242, 242, 0);
    right: 8px;
    width: 4vw;
    height: 4vw;
    max-width: 40px;
    max-height: 40px;
    border-radius: 100%;
    top: 8px;
    display: flex;
    justify-content: center;
    align-items: center;

    .wishl-add-wrapper {
        width: 100%;
        height: 100%;
        margin: 0;

        a {
            display: inline-block;
            width: 100%;
            height: 100%;

            i {
                height: 100%;
                width: 100%;
                display: inline-block;
                position: relative;
                animation: none !important;
                opacity: 1;
            }
        }
    }

    .wishl-icon.icon-adding,
    .wishl-icon.icon-heart {
        opacity: 1;

        &:before {
            background-image: url({{ 'wish-icon.svg' | asset_url }});
            width: 40%;
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            content: "";
            height: 40%;
            margin: auto;
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            right: 0;
        }

        &.isin {
            &:before {
                content: "";
                background-image: url({{ 'wish-icon-filled.svg' | asset_url }});
            }
        }
    }
}

