.samples-header {
    background: linear-gradient(0deg, {{ settings.color_section_bg }}, {{ settings.color_section_bg }}), linear-gradient(90deg, {{ settings.color_section_bg }} 43.03%, {{ settings.color_section_bg }} 53.51%, rgba(241, 238, 234, 0) 72.97%);
    position: relative;
    padding: 100px 0;
    margin-bottom: 185px;

    @media screen and (max-width: 768px) {
        padding: 64px 0 56px 0;
        margin-bottom: 80px;
    }

    .samples-header__content {
        padding-left: 109px;
        position: relative;
        display: flex;
        flex-direction: column;
        align-self: stretch;
        justify-content: center;

        @media screen and (max-width: $navBreakpoint) {
            padding-left: 0px;
        }
    }
    
    .samples-header__content-title {
        color: $colorPrimary;
        display: block;
        margin: 0;
        font-weight: 500;
        font-size: 56px;
        line-height: 67px;
        letter-spacing: 0.5px;
        font-family: $averia;
        text-transform: lowercase;

        & + .samples-header__content-text {
            margin-bottom: 16px;
        }
        
        @media screen and (max-width: $navBreakpoint) {
            font-size: 50px;
            line-height: 48px;
        }

        @media screen and (max-width: 768px) {
            font-size: 32px;
            line-height: 38px;
        }
    }

    .samples-header__content-text {
        font-weight: 400;
        font-size: 16px;
        line-height: 24px;

        p {
            margin-bottom: 0;
        }

        @media screen and (max-width: 768px) {
            font-size: 14px;
            line-height: 19px;
        }
    }

    .samples-header__content-wood-types {
        gap: 12px;
        margin-top: 24px;

        @media screen and (max-width: $navBreakpoint) {
            left: 0px;
        }

        @media screen and (max-width: 768px) {
            gap: 8px;
            position: relative;
            bottom: initial;
            left: initial;
            margin-top: 24px;
        }

        .samples-header__content-wood-type {
            position: relative;
            width: 72px;

            @media screen and (max-width: $navBreakpoint) {
                width: 50px;
            }

            .samples-header__content-wood-type-image {
                display: block;
                width: 100%;
                height: auto;
            }

            .samples-header__content-wood-type-text {
                padding: 5px;
                position: absolute;
                top: 50%;
                left: 0;
                right: 0;
                text-align: center;
                width: 100%;
                transform: translateY(-50%);
                color: #fff;
                margin: 0;
                font-size: 16px;

                @media screen and (max-width: $navBreakpoint) {
                    font-size: 12px;
                }
            }
        }

        .samples-header__content-wood-type:nth-of-type(5) {

            .samples-header__content-wood-type-text {
                @media screen and (max-width: $navBreakpoint) {
                    padding-left: 1px;
                }
            }
        }
    }

    .samples-header__form-container {
        margin-bottom: -180px;

        .posted_successfully {
            /* background: {{ settings.color_section_bg }}; */
            padding: 0;
            font-size: 14px;
            text-align: center;
            margin: 0;
            color: black;
        }

        .posted_error {
            background: #ffa883a3;
            padding: 10px;
            font-size: 14px;
            text-align: center;
            margin-bottom: 20px;
        }

        @media screen and (max-width: 768px) {
            margin-bottom: 0px;
            margin-top: 16px;
        }

        .samples-header__form {
            margin-left: 120px;
            padding: 24px 32px;
            background-color: #fff;
            box-shadow: 0px 8px 15px rgba(96, 97, 112, 0.1);

            @media screen and (max-width: $navBreakpoint) {
                margin-left: 30px;
            }

            @media screen and (max-width: 768px) {
                margin-left: 0px;
                padding: 24px 16px;
            }

            .samples-header__form-content {
                .samples-header__form-title {
                    font-size: 22px;
                    line-height: 29px;
                    margin-bottom: 0;

                    & + .samples-header__form-paragraph {
                        margin-top: 8px;
                    }

                    @media screen and (max-width: 768px) {
                        font-size: 17px;
                        line-height: 21px;
                    }
                }

                .samples-header__form-paragraph {
                    font-size: 14px;
                    line-height: 21px;
                    color: #A0A0A0;
                    letter-spacing: 0.5px;

                    p {
                        margin-bottom: 0;
                    }

                    @media screen and (max-width: 768px) {
                        font-size: 13px;
                        line-height: 18px;
                    }
                }
            }

            .samples-header__form-fields {
                margin-top: 16px;
                margin-bottom: 24px;

                input {
                    color: $colorPrimary;
                    border-color: #A0A0A0;
                    border-radius: 8px;
                }

                label {
                    display: block;
                    margin-top: 12px;
                }

                select {
                    margin-top: 12px;
                    background-color: #fff;
                    color: #808171;
                    border-color: #a0a0a0;
                    border-radius: 8px;
                }

                input.has-error,
                select.has-error {
                    border-color: #9F5130;
                }

                .error {
                    color: #9F5130;
                    font-size: 10px;
                    margin-top: 4px;
                }
                
                input + .error + input,
                input + .error + select,
                select + .error + input {
                    margin-top: 12px;
                }

                .samples-header__form-radio-buttons {
                    margin-top: 16px;

                    p {
                        margin-bottom: 8px;
                    }

                    label {
                        font-size: 15px;
                        line-height: 20px;
                        letter-spacing: 0.5px;
                        text-transform: lowercase;
                        display: grid;
                        grid-template-columns: 1em auto;
                        gap: 0.5em;
                        align-items: center;
                        color: $colorPrimary;

                        input[type="radio"] {
                            -webkit-appearance: none;
                            appearance: none;
                            background-color: #fff;
                            margin: 0;
                            font: inherit;
                            color: currentColor;
                            width: 1em;
                            height: 1em;
                            border: 0.075em solid currentColor;
                            border-radius: 50%;
                            display: grid;
                            place-content: center;
                            transform: translateY(0.15em);
                        }

                        input[type="radio"]::before {
                            content: "";
                            width: 0.65em;
                            height: 0.65em;
                            border-radius: 50%;
                            transform: scale(0);
                            transition: 120ms transform ease-in-out;
                            box-shadow: inset 1em 1em $colorPrimary;
                        }

                        input[type="radio"]:checked::before {
                            transform: scale(1);
                        }
                    }

                    label + label {
                        margin-top: 8px;
                    }
                }
            }

            .main-button {
                width: 100%;

                @media screen and (max-width: 768px) {
                    width: max-content;
                }
            }

            .samples-header__form-note {
                margin-top: 8px;
                margin-bottom: 0;
                font-weight: 400;
                font-size: 10px;
                line-height: 14px;
                letter-spacing: 0.2px;
                text-transform: lowercase;
            }
        }
    }
}

