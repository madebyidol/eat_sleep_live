.faqs {
    width: 76vw;
    margin: auto;

    @media screen and (max-width: $medium) {
        width: 88vw;
    }

    h4 {
        margin-bottom: 40px;

        @media screen and (max-width: $medium) {
            margin-bottom: 30px;
        }
    }

    .faqs_question-answer {
        border-bottom: 1px solid #9797977a;
        padding-bottom: 20px;
        margin-bottom: 30px;

        @media screen and (max-width: $medium) {
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        .faqs_question {
            color: $colorBodyTitles;
            font-size: 16px;
            font-weight: 700;
        }

        .accordion {
            position: relative;

            &:after,
            &:before {
                content: "";
                position: absolute;
                right: 8px;
                top: 5px;
                border-right: 1px solid #434241;
                height: 17px;
                opacity: 1;
                transition: .3s ease-out;
                -webkit-transition: .3s ease-out;
                -moz-transition: .3s ease-out;
                -ms-transition: .3s ease-out;
            }

            &:before {
                transform: rotate(90deg);
            }

            p {
                transition: 0.5s;
                -webkit-transition: 0.5s;
                -moz-transition: 0.5s;
                -ms-transition: 0.5s;

                span {
                    margin-right: 10px;
                }
            }
        }

        .accordion.active {
            &:after {
                opacity: 0;
            }

            &:before {
                border-right: 1px solid #d2b057;
            }

            p {
                @extend .active-color;
            }
        }
    }
}

