#mc_embed_signup {
	width: 25%;
	float: left;
	h2 {
	    color: #7a7a7a;
	    font-size: 14px;
	    letter-spacing: 1px;
	    font-weight: 600;
	    text-transform: uppercase;
	    text-align: right;
	}
	.indicates-required {
		display: none;
	}
	.mc-field-group {
		label {
			display: none;
		}
		input[type="email"] {
			width: 65%;
			float: left;
			border-top-left-radius: 30px;
    		border-bottom-left-radius: 30px;
    		height: 40px;
    		padding: 0;
    		padding-left: 20px;
    		color: #afaeae;
			font-family: Montserrat;
			font-size: 14px;
			font-weight: 300;
			border-top-right-radius: 0;
			border-bottom-right-radius: 0;
			border-right: 0;
		}
		input[type="submit"] {
			width: 35%;
			height: 40px;
			float: left;
			padding: 0;
			color: #ffffff;
			font-family: Montserrat;
			font-size: 15px;
			font-weight: 700;
			text-transform: uppercase;
			border: 0;
			border-top-left-radius: 0;
			border-bottom-left-radius: 0;
		}
	}
	div.mce_inline_error {
	    color: #f55 !important;
	    margin-top: 10px !important;
	    border: 1px solid #f55 !important;
	    text-align: center !important;
	    background-color: #fefafa !important;
	    font-weight: 300 !important;
	}
	input.mce_inline_error {
		border-color: #e5e5e5 !important;
	}
	#mce-responses {
		.response {
			font-size: 13px;
			margin-top: 10px;
		}
	}
}

@media screen and (max-width: 1200px) {
	#mc_embed_signup {
		.mc-field-group {
			input[type="email"] {
				width: 65%;
			}
			input[type="submit"] {
				width: 35%;
			}
		}
	}
}

@media screen and (max-width: 1024px) {
	#mc_embed_signup {
		width: 70%;
		clear: both;
		float: right;
		margin: 0px;
		text-align: center;
		padding-top: 40px;
		padding-bottom: 10px;
		.mc-field-group {
			input[type="email"] {
				width: 70%;
				font-size: 14px;
			}
			input[type="submit"] {
				width: 30%;
				font-size: 14px;
			}
		}
		#mce-responses {
			.response {
				font-size: 13px;
				margin-top: 10px;
				text-align: center; 
			}
		}
	}

}

@media screen and (max-width: 1024px) {
	#mc_embed_signup {
		float: none;
    	margin: 0 auto;
    	h2 {
    		text-align: center;
    	}
	}
}

@media screen and (max-width: 480px) {
	#mc_embed_signup {
	 	width: 100%;
	 	padding: 0;
	}
}