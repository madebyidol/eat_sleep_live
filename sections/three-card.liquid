{% comment %}
  Three Card Section
  Displays a heading with alternating image/text cards stacked vertically
{% endcomment %}

<div class="three-card-container wrapper">
  
  {% if section.settings.show_heading %}
  <div class="three-card-header">
    {% if section.settings.overline != blank %}
      <p class="three-card-overline sml-caps">{{ section.settings.overline }}</p>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="three-card-heading">{{ section.settings.heading }}</h2>
    {% endif %}
  </div>
  {% endif %}

  <div class="three-card-list">
    {% for block in section.blocks %}
      <div class="three-card-item" {{ block.shopify_attributes }}>

        {% if block.settings.image != blank %}
          <div class="three-card-image">
            <img 
              src="{{ block.settings.image | img_url: '800x' }}"
              alt="{{ block.settings.image.alt | default: block.settings.title }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          </div>
        {% endif %}

        <div class="three-card-content">
          {% if block.settings.category != blank and block.settings.show-category == true %}
            <p class="three-card-category sml-caps">{{ block.settings.category }}</p>
          {% endif %}
          {% if block.settings.title != blank %}
            <h4 class="three-card-title">{{ block.settings.title }}</h4>
          {% endif %}
          {% if block.settings.description != blank %}
            <p class="p-lrg three-card-description">{{ block.settings.description }}</p>
          {% endif %}
          {% if block.settings.button_text != blank %}
            <a href="{{ block.settings.button_link }}" class="main-button sml-button">
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        </div>

      </div>
    {% endfor %}
  </div>

</div>

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
  }

  .three-card-section {
    width: 100%;
    padding-top: var(--section-padding);
    padding-bottom: var(--section-padding);
  }

  .three-card-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .three-card-header {
    text-align: center;
    margin-bottom: {{ section.settings.header_spacing }}px;
  }

  .three-card-overline {
    margin-bottom: 16px;
  }

  .three-card-heading {
    max-width: 28ch;
    margin: 0 auto;
  }

  /* Desktop: 3 cards side by side */
  .three-card-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }

  /* Each card: image on top, text below */
  .three-card-item {
    display: grid;
    grid-template-rows: auto 1fr;
    overflow: hidden;
    border-radius: {{ section.settings.card_border_radius }}px;
    background: #fff;
    position: relative;
  }

  /* Image */
  .three-card-image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .three-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .three-card-item:hover .three-card-image img {
    transform: scale(1.04);
  }

  /* Content */
  .three-card-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 24px;
  }

  .three-card-content * {
    margin: 0;
  }

  .three-card-category {
    margin-bottom: 0;
  }

  .three-card-content .main-button {
    align-self: flex-start;
    margin-top: auto;
  }

  .three-card-content .main-button::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 32px;
  }

  @media (max-width: 1080px) {
    .three-card-list {
      gap: 16px;
    }
  }

  /* ~760px and below: cards stack vertically, image and text side by side */
  @media (max-width: 760px) {
    .three-card-list {
      grid-template-columns: 1fr;
    }

    .three-card-category {
      display: none;
    }

    .three-card-item {
      grid-template-rows: none;
      grid-template-columns: 1fr 1fr;
      min-height: 240px;
    }

    .three-card-image {
      aspect-ratio: unset;
    }

    .three-card-content {
      justify-content: center;
      gap: 16px;
    }
  }

  /* Small mobile: image on top, text below */
  @media (max-width: 479px) {
    .three-card-itemt {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .three-card-image {
      aspect-ratio: 3 / 2;
    }
  }
</style>

{% schema %}
{
  "name": "Three Card",
  "tag": "section",
  "class": "three-card-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background colour"
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline text",
      "default": "Thoughtfully made for your home"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Transform your home with our unique reclaimed wood furniture"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Maximum width",
      "default": 1380
    },
    {
      "type": "range",
      "id": "header_spacing",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Header spacing",
      "default": 64
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 10,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Card gap",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Card border radius",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Eat"
        },
        {
          "type": "checkbox",
          "id": "show-category",
          "label": "Display category",
          "default": true
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "DINING ROOM FURNITURE"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Timeless dining furniture, carefully made from reclaimed wood."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "SHOP DINING ROOM"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Three Card Section",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Eat",
            "category": "DINING ROOM FURNITURE",
            "description": "Timeless dining furniture, carefully made from reclaimed wood.",
            "button_text": "SHOP DINING ROOM"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Sleep",
            "category": "BEDROOM FURNITURE",
            "description": "Thoughtfully made bedroom furniture, crafted to last.",
            "button_text": "SHOP BEDROOM"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Live",
            "category": "LIVING ROOM FURNITURE",
            "description": "Beautiful, practical furniture designed for modern living.",
            "button_text": "SHOP LIVING ROOM"
          }
        }
      ]
    }
  ]
}
{% endschema %}
