<div>
  <div class="large--flex js-component__slick slick-hide slick-hide-mobile" data-slick='{"mobileOnly": true, "slidesToShow": 1.3, "infinite": false, "rows": 0}'>
  	{% for block in section.blocks %}
  		{% capture child %}
  		{% if block.settings.video-url != blank %}
	  		<div class="background-video__container">
				<video autoplay loop muted playsinline>
					<source src="{{ block.settings.video-url }}" type="video/mp4">
				</video>
			</div>
		{% endif %}
  		<div class="slim-carousel__text-container"  data-aos-delay="50">
  			<h3 class="main-title h1 slim-carousel__text-title">{{ block.settings.title }}</h3>
  			<p class='fade-in fade-in-desktop m-b-40'>{{ block.settings.subtitle }}</p>
  			<div class="fade-in fade-in-desktop">
  				<a class="main-button" href="{{ block.settings.button-url | downcase }}">{{ block.settings.button-text }}</a>
  			</div>
  		</div>
  		{% endcapture %}
  		{% include 'background-image-element' with image: block.settings.image, classes: 'slim-carousel large--one-third fade-in-container', child: child %}
  	{% endfor %}
  </div>
</div>


{% schema %}
  {
    "name": "Slim Carousel",
    "max_blocks": 3,
    "blocks": [
    	{
    		"type": "carousel",
			"name": "Carousel Item",
    		"settings": [
    			{
    				"type": "paragraph",
    				"content": "A video or image aspect ratio of 3:5 is recommended"
    			},
    			{
    			  "type": "text",
    			  "id": "title",
    			  "label": "Title"
    			},
    			{
    			  "type": "text",
    			  "id": "subtitle",
    			  "label": "Subtitle"
    			},
    			{
    			  "type": "image_picker",
    			  "id": "image",
    			  "label": "Image"
    			},
    			{
    			  "type": "text",
    			  "id": "button-text",
    			  "label": "Button Text"
    			},
    			{
    			  "type": "url",
    			  "id": "button-url",
    			  "label": "Button Link"
    			},
    			{
    			  "type": "text",
    			  "id": "video-url",
    			  "label": "Video URL",
    			  "info": "Upload your video into the files section of Shopify and paste the URL here. Selecting a video will override any hero images (MP4 only)."
    			}
    		]
    	}
    ],
    "presets": [
      {
        "name": "Slim Carousel",
        "category": "Blocks"
      }
    ]
  }
{% endschema %}