{% include 'standard-header' with image: section.settings.background-image, title: section.settings.title %}

{% assign sections = section.settings.groups | split: ',' %}


<div class="filter-text">
	<div class="filter-text__options flex large--flex-center">
		{% for section in sections %}
			<div class="filter-text__option">
				<a class="anchor-link" data-link="{{ section | handleize }}"><p>{{ section }}</p></a>
			</div>
		{% endfor %}
	</div>
</div>

<div class="faqs">
{% if shop.metafields.custom_fields["faq_question"] != blank %}
      {% assign separator = "|###|" %}
      {% assign question_category_array = shop.metafields.custom_fields["question_category"] | split: separator %}
      {% assign question_array = shop.metafields.custom_fields["question"] | split: separator %}
      {% assign answer_array = shop.metafields.custom_fields["answer"] | split: separator %}
      {% assign fc_keys = shop.metafields.custom_fields["faq_question"] | split: "," %}
      
      {% for section in sections %}
      <div id="{{ section | handleize }}" class="faqs__container">
      	<h4>{{section}}</h4>
	      {% for i in fc_keys %}
	        {% assign index = i | plus: 0 %}
	        	{% if section == question_category_array[index] %}
	        	<div class="faqs_question-answer">
		        	<div class="accordion">
		            	<p class="faqs_question"><span class="active-color">Q.</span>{{ question_array[index] }}</p>
		            </div>
		            <div class="accordion-panel">
		            	<p class="secondary-color">{{ answer_array[index] }}</p>
		        	</div>
		        </div>
	            {% endif %}
	       {% endfor %}
	    </div>
	  {% endfor %}
{% endif %}
</div>

<div class="faqs-end">
	{% assign title-class = 'h4' %}
	{% assign link-text = section.settings.link-text-end %}

	<div {% if section.settings.background-image-end-mobile != blank %}class="small--hide show"{% endif %}>
		{% include 'standard-header' with image: section.settings.background-image-end, title: section.settings.title-end, description: section.settings.description-end, link: section.settings.link-end, link-text: link-text, title-class: title-class %}
	</div>	
	{% if section.settings.background-image-end-mobile != blank %}
		<div class="small--show hide">
			{% include 'standard-header' with image: section.settings.background-image-end-mobile, title: section.settings.title-end, description: section.settings.description-end, link: section.settings.link-end, link-text: link-text, title-class: title-class %}
		</div>
	{% endif %}
</div>

{% schema %}
  {
    "name": "FAQs",
    "settings": [
    	{
    	  "type": "text",
    	  "id": "title",
    	  "label": "Page Title",
    	  "default": "FAQs"
    	},
    	{
    	  "type": "text",
    	  "id": "groups",
    	  "label": "FAQ Groups",
    	  "info": "List of the FAQ groups separated by a comma (e.g. delivery,ordering,assembly) (case sensitive, max 6)"
    	},
    	{
    	  "type": "image_picker",
    	  "id": "background-image",
    	  "label": "Background Image"
    	},
    	{
    	  "type": "paragraph",
    	  "content": "Add your questions in the FAQ Questions of the Global section of the Custom Fields app"
    	},
    	{
    		"type": "header",
    		"content": "Page Bottom CTA"
    	},
    	{
    		"type": "image_picker",
    		"id": "background-image-end",
    		"label": "Background Image"
    	},
    	{
    		"type": "image_picker",
    		"id": "background-image-end-mobile",
    		"label": "Background Image Mobile",
    		"info": "Leave blank to use the desktop background image for mobile too"
    	},
    	{
    	  "type": "text",
    	  "id": "title-end",
    	  "label": "Title"
    	},
    	{
    	  "type": "textarea",
    	  "id": "description-end",
    	  "label": "Description"
    	},
    	{
    	  "type": "url",
    	  "id": "link-end",
    	  "label": "Button Link"
    	},
    	{
    	  "type": "text",
    	  "id": "link-text-end",
    	  "label": "Button Text"
    	}
    ]
  }
{% endschema %}