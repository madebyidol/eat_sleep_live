<section id="heading-{{ section.id }}" class="section-heading">
    <div class="section-heading__content section-heading__content--{{ section.settings.alignment }}">
        <h4 class="section-heading__text"> {{ section.settings.heading }} </h4>
        <div class="section-heading__description"> {{ section.settings.content }} </div>
    </div>
</section>

<div class="product__tab-header">
    {% for block in section.blocks %}
        <div class="product__tab-header-item {% if forloop.first %}active{% endif %}">{{ block.settings.title }}</div>
    {% endfor %}
</div>

{% for block in section.blocks %}

    <div class="product__tab {% if forloop.first %}active{% endif %}">

        <div class="product__description">

            <div class="product__description-inner">

                <div class="product__description-content">

                    <h5 class="title-with-icon">
                        {% if block.settings.icon != blank %}
                            {{ block.settings.icon | image_url: width: 48 | image_tag: widths: '48', loading: 'lazy' }}
                        {% endif %}
                        <span>{{ block.settings.title }}</span>
                    </h5>

                    {% if block.settings.content != blank %}
                        {{ block.settings.content }}
                    {% endif %}

                </div>

                <div class="product__description-image">
                    {% if block.settings.image != blank %}
                        {{ block.settings.image | image_url: width: 635, height: 420, crop: 'center' | image_tag: widths: '635, 720, 950', loading: 'lazy' }}
                    {% endif %}
                </div>

            </div>
        </div>

    </div>

{% endfor %}

{% schema %}
{
  "name": "Content Tabs",
  "class": "content-tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "label": "Left",
          "value": "left"
        },
        {
          "label": "Center",
          "value": "center"
        },
        {
          "label": "Right",
          "value": "right"
        }
      ],
      "default": "left"
    }
  ],
  "max_blocks": 5,
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "Suggested min size: 48x48px"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Suggested min size: 635x420px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Content Tabs",
      "category": "ADVANCED LAYOUT"
    }
  ]
}
{% endschema %}