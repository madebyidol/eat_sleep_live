<div class="samples-header">

  <div class="wrapper">

    <div class="flex flex-wrap flex-start">

      <div class="samples-header__content one-half small--one-whole medium--one-whole">
        {% unless section.settings.title == blank %}
          <h1 class="samples-header__content-title">{{ section.settings.title }}</h1>
        {% endunless %}

        {% unless section.settings.paragraph == blank %}
          <div class="samples-header__content-text">{{ section.settings.paragraph }}</div>
        {% endunless %}

        <div class="samples-header__content-wood-types flex flex-wrap">
          {% for block in section.blocks %}

            {% if block.settings.wood_image != blank %}

              <div class="samples-header__content-wood-type">
                
                <svg class="samples-header__content-wood-type-image" width="96" height="96" viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
