{% schema %}
  {
    "name": "Collection Standard",
    "settings": [
        {
            "type": "header",
            "content": "Collection Header"
        },
        {
            "type": "checkbox",
            "id": "default-height",
            "label": "Default Image Height",
            "info": "Select whether the collection header image use its image's height or the collection design's default height.",
            "default": true
        },
        {
            "type": "header",
            "content": "Products"
        },
        {
            "type": "text",
            "id": "button-text",
            "label": "Button Text",
            "default": "SELECT YOURS"
        },
        {
            "type": "text",
            "id": "size-variant",
            "label": "Size Variant Name",
            "default": "Choose Your Size",
            "info": "In order to display the number of sizes available, enter the option name sizes are classed under for your products (e.g. Choose Your Size) (Note: Case sensitive)"
        },
        {
            "type": "header",
            "content": "Filter"
        },
        {
            "type": "paragraph",
            "content": "To add filter options, tags products accordingly: filter_<filter name>_<filter option> (e.g. filter_Size-of-Bed_Single) (Use - for spaces, option text is case sensitive)"
        },
        {
            "type": "paragraph",
            "content": "To add a new filter to a collection page (e.g. Size-of-Bed), add it to the [Standard Filter options](https://customfields.bonify.io/dashboard/eat-sleep-live-2.myshopify.com/globals) on Custom Fields global attribute"
        },
        {
            "type": "header",
            "content": "Products"
        },
        {
            "type": "text",
            "id": "rv-title",
            "label": "Recently Viewed Title",
            "default": "Recently Viewed Products"
        }
    ]
  }
{% endschema %}

{% if template contains 'collection' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "url": "{{ collection.url }}",
  "name": "{{ collection.title | escape }}",
  "description": "{{ collection.description | strip_html | escape }}",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      {% for product in collection.products %}
      {
        "@type": "Product",
        "name": "{{ product.title | escape }}",
        "image": "{% if product.featured_image %}{{ product.featured_image.src | img_url: 'master' | prepend: 'https:' }}{% endif %}",
        "description": "{{ product.description | strip_html | escape }}",
        "sku": "{% if product.sku != blank %}{{ product.sku | escape }}{% endif %}",
        "brand": {
          "@type": "Brand",
          "name": "Eat Sleep Live"
        },
        "offers": {
          "@type": "Offer",
          "url": "{{ product.url | escape }}",
          "priceCurrency": "{{ shop.currency }}",
          "price": "{{ product.price | divided_by: 100.0 }}",
          "itemCondition": "https://schema.org/NewCondition",
          "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
        }
      }{% if forloop.last == false %},{% endif %}
      {% endfor %}
    ]
  }
}
</script>
{% endif %}

