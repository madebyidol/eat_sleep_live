{% paginate collection.products by 25 %}
<div class="wrapper">
    <div class="grid flex flex-wrap">
        {% for product in collection.products %}
            <div class="grid__item small--one-half medium--one-half one-third">
                {% include 'product-block' with collection_block: true %}
            </div>
        {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      <div class="pagination">
        {{ paginate | default_pagination | replace: '&laquo; Previous', '<svg width="13" height="22" viewBox="0 0 13 22" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6.31046 13.3448C8.46219 15.5793 11.3794 19.7586 12.5174 21.6207C11.3794 20.8966 9.20701 19.6552 6.10357 16.6552C4.96056 15.5503 1.51736 12.4483 0.000118256 10.9655C1.41391 9.58621 4.62211 6.50572 6.10357 5.17241C9.20701 2.37931 11.5863 0.827586 12.9312 0C12.207 1.55172 9.51736 4.75862 8.58632 6C7.8415 6.9931 5.2415 9.7931 4.0346 11.069L6.31046 13.3448Z" fill="currentColor"/></svg>' | replace: 'Next &raquo;', '<svg width="5" height="8" viewBox="0 0 5 8" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.7069 4.4766C1.98966 5.22142 1.01724 6.61453 0.637931 7.23522C1.01724 6.99384 1.74138 6.58004 2.77586 5.58004C3.15686 5.21174 4.3046 4.17775 4.81034 3.68349C4.33908 3.22372 3.26968 2.19689 2.77586 1.75246C1.74138 0.821424 0.948276 0.304182 0.5 0.0283203C0.741379 0.545562 1.63793 1.61453 1.94828 2.02832C2.19655 2.35935 3.06322 3.29269 3.46552 3.71798L2.7069 4.4766Z" fill="currentColor"/></svg>' }}
