{%- endcomment -%}
{% capture child %}
	<div class="image-overlay"></div>
	<div class="single-cta__text-container" >
		{% if section.settings.preheader %}<p class="{% if section.settings.full == true %}h1{% else %}h3{% endif %} jenna-sue normal-spaced"  data-aos-delay="20">{{ section.settings.preheader }}</p>{% endif %}
		{% if section.settings.title %}<h3 class="h5 normal-spaced"  data-aos-delay="40">{{ section.settings.title }}</h3>{% endif %}
		{% if section.settings.content %}<p  data-aos-delay="60">{{ section.settings.content | newline_to_br }}</p>{% endif %}
		{% if section.settings.button-url %}
			<a class="main-button" href="{{ section.settings.button-url | downcase }}"  data-aos-delay="80">{{ section.settings.button-text }}</a>
		{% endif %}
	</div>
    {% if section.settings.video-url != blank %}
        <div class="background-video__container">
            <video autoplay loop muted playsinline>
                <source src="{{ section.settings.video-url }}" type="video/mp4">
            </video>
        </div>
    {% endif %}
{% endcapture %}

{% assign cta-classes = 'single-cta hover-video' %}
{% if section.settings.full == true %}
	{% assign cta-classes = 'single-cta--full-width single-cta hover-video' %}
{% endif %}

{% if section.settings.image != blank %}
    {% include 'background-image-element' with image: section.settings.image, classes: cta-classes, child: child %}
{% endif %}

{% schema %}
  {
    "name": "Single CTA",
    "settings": [
      {
      	"type": "checkbox",
      	"id": "full",
      	"label": "Large & Full Width"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      },
      {
        "type": "text",
        "id": "preheader",
        "label": "Preheader"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "textarea",
        "id": "content",
        "label": "Content"
      },
      {
        "type": "text",
        "id": "button-text",
        "label": "Button Text"
      },
      {
        "type": "url",
        "id": "button-url",
        "label": "Button Link"
      },
      {
        "type": "text",
        "id": "video-url",
        "label": "Video URL",
        "info": "Upload your video into the files section of Shopify and paste the URL here. If video and image are both uploaded, video will play on hover."
      }
    ],
    "presets": [
      {
        "name": "Single CTA",
        "category": "Blocks"
      }
    ]
  }
{% endschema %}