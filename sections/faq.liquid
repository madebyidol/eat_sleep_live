<section id="frequently-asked-question--{{ section.id }}" class="faq-wrapper">
    <div class="frequently-asked-question">
        
        <h4 class="frequently-asked-question--heading"> {{ section.settings.heading }} </h4>

        <div class="frequenlty-asked-question__container">
  
            {% for faq in section.blocks %}
                <div class="faq-accordion--card">
                    <button class="faq-accordion accordion-heading">
                        {{ faq.settings.question }}
                        <span class="faq-accordion-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                xmlns="http://www.w3.org/2000/svg">
                                <path fill-rule="evenodd" clip-rule="evenodd"
                                    d="M5 12C5 11.4477 5.44772 11 6 11H18C18.5523 11 19 11.4477 19 12C19 12.5523 18.5523 13 18 13H6C5.44772 13 5 12.5523 5 12Z"
                                    fill="#434241" />
                                <path fill-rule="evenodd" clip-rule="evenodd"
                                    d="M12 5C12.5523 5 13 5.44772 13 6L13 18C13 18.5523 12.5523 19 12 19C11.4477 19 11 18.5523 11 18L11 6C11 5.44772 11.4477 5 12 5Z"
                                    fill="#434241" />
                            </svg>
                        </span>
                    </button>

                    <div class="faq-panel">
                        <p>{{ faq.settings.answer }}</p>
                    </div>
                </div>
            {% endfor %}
         
        </div>
    </div>
</section>

<script>
    var acc = document.getElementsByClassName("faq-accordion");
    var i;

    for (i = 0; i < acc.length; i++) {
        acc[i].addEventListener("click", function () {
            this.classList.toggle("active");
            var panel = this.nextElementSibling;
            var faqContainer = this.parentElement;
            faqContainer.classList.toggle("active");

            if (panel.style.maxHeight) {
                panel.style.maxHeight = null;
            } else {
                panel.style.maxHeight = panel.scrollHeight + "px";
            }
        });
    }
</script>

{% schema %}
{
  "name": "FAQs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "text",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQs",
      "category": "ADVANCED LAYOUT"
    }
  ]
}
{% endschema %}