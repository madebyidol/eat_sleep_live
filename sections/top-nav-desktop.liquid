<nav class="site-header__desktop">

  <div class="mobile-button">
    <a aria-label="Click to open menu" style="cursor: pointer;" id="mobile-trigger">
      {% include 'menu-icon' %}
      {% include 'x-icon' %}
    </a>
  </div>

	<!-- Logo -->
	<div class="site-header__logo__grid {% unless settings.logo_use_image %}site-header__logo__grid-text{% endunless %}">

  {% if settings.logo_use_image %}
		{% comment %}
			Use the uploaded logo from theme settings if enabled.
			Site name gets precedence with H1 tag on homepage, div on other pages.
		{% endcomment %}
		{% include 'shop-logo' %}

  {% else %}

    <a href="/" itemprop="url" title="{{ shop.name }}" class="site-header__logo-link">

      <span>{{ shop.name }}</span>

    </a>
  
  {% endif %}

	</div>

	{% comment %} Menu {% endcomment %}
	{% include 'desktop-menu' blocks: section.blocks %}
	
	{% comment %} Icons {% endcomment %}
	<ul class="customer-links">
		<li class="contact_link"><a class="sml-caps" style="margin-right: 8px" href="/pages/get-in-touch">Get in touch</a></li>
    <li>
			<a aria-label="Click here to view your account" href="/search">{% include 'search-icon' %}</a>
		</li>
		{% if shop.customer_accounts_enabled %}
			<li class="account_link">
				{% if customer %}
					<a aria-label="Click here to view your account" href="https://account.eatsleeplive.co.uk">{% include 'account-icon' %}</a>
				{% else %}
					<a aria-label="Click here to view your account" href="https://account.eatsleeplive.co.uk">{% include 'account-icon' %}</a>
				{% endif %}
			</li>
		{% endif %}
		{% comment %}
			Keep this comment here as wishlist king requires it to work.
		{% endcomment %}
		<!-- include 'wishlist-link-li' -->
    {% comment %}
		<li class="wishlist_link">
			<a href="/a/wishl-wishlist">
				{% include 'wishlist-icon' %}
			</a>
		</li>
  {% endcomment %}
		<li>
			{% include 'cart-button' %}
		</li>
	</ul>
</nav>

<script>
  var mobileImgs = $('.swapimgMobile');
  var imgs = $('.swapimg');

$(document).on("click", ".mobile-button #mobile-trigger", function(){ 

  if (mobileImgs.attr("src") != mobileImgs.attr("data-swap")) {
    mobileImgs.each(function () {
      $(this).attr('src', $(this).attr("data-swap"));
    });
  }

});

$(".site-header__navigation-item").hover(function () {
  if (imgs.attr("src") != imgs.attr("data-swap")) {

      imgs.each(function () {
          $(this).attr('src', $(this).attr("data-swap"));
      });
  }
});
</script>

{% schema %}
{
  "name": "Desktop Nav",
  "settings": [
    {
      "type": "link_list",
      "id": "top_desktop_menu",
      "label": "Menu"
    }
  ],
  "blocks": [
    {
      "type": "dropdown_image",
      "name": "Dropdown Image",
      "settings": [
        {
          "type": "text",
          "id": "nav_link",
          "label": "Navigation Link",
          "info": "Enter the name of the top level link you want the image to appear on."
        },
        {
          "type": "image_picker",
          "id": "nav_image",
          "label": "Dropdown Image",
          "info": "Recommended minimum size: 527x330px"
        },
        {
          "type": "header",
          "content": "Button Under Links"
        },
        {
          "type": "url",
          "id": "lower_button_url",
          "label": "Lower Button URL"
        },
        {
          "type": "text",
          "id": "lower_button_label",
          "label": "Lower Button Label"
        },
        {
          "type": "header",
          "content": "Button Over Image"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Image Button URL"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Image Button Label"
        }
      ]
    },
    {
      "type": "collection_list",
      "name": "Collection List",
      "settings": [
        {
          "type": "text",
          "id": "nav_link",
          "label": "Navigation Link",
          "info": "Enter the name of the top level link you want the list to appear on."
        },
        {
          "type": "checkbox",
          "id": "enable_collection_list",
          "label": "Enable Collection List"
        }
      ]
    }
  ]
}
{% endschema %}
