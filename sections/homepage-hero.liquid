{% capture hero-text %}
<div class="image-overlay"></div>
  <div class="homepage-hero__container">
    <h1 class="homepage-hero__title main-title h1" >{{ section.settings.title }}</h1>
    <a class="main-button" href="{{ section.settings.button-url | downcase }}" >{{ section.settings.button-text }}</a>
  </div>
{% endcapture %}

{% if section.settings.video-url != blank %}
  <div class="background-video background-image__video">
    {{ hero-text }}
    <div class="background-video__container">
      <video autoplay loop muted playsinline>
        <source src="{{ section.settings.video-url }}" type="video/mp4">
          {% include 'background-image-element' with image: section.settings.image, classes: 'homepage-hero hide large--show' %}
          {% include 'background-image-element' with image: section.settings.image_mobile, classes: 'homepage-hero homepage-hero-mobile show large--hide' %}
      </video>
    </div>
  </div>
{% elsif section.settings.image != blank %}
  {% include 'background-image-element' with image: section.settings.image, child: hero-text, classes: 'homepage-hero hide large--show' %}

  {% include 'background-image-element' with image: section.settings.image_mobile, child: hero-text, classes: 'homepage-hero homepage-hero-mobile show large--hide' %}
{% endif %}


{% schema %}
  {
    "name": "Hero",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "text",
        "id": "button-text",
        "label": "Button Text"
      },
      {
        "type": "url",
        "id": "button-url",
        "label": "Button Link"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      },
      {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "Image Mobile"
      },
      {
        "type": "text",
        "id": "video-url",
        "label": "Video URL",
        "info": "Upload your video into the files section of Shopify and paste the URL here. Selecting a video will override any hero images (MP4 only)."
      }
    ],
    "presets": [
      {
        "name": "Hero",
        "category": "Blocks"
      }
    ]
  }
{% endschema %}