<div class="rv-container rv_collection-container product_main wrapper">
    <div class="row center recently-viewed js-component__recently-viewed slick-hide slick-arrows rv_collection"
      data-title="{{ section.settings.rv-title }}"
      {% comment %} data-slick='{"slidesToShow": 3, "slidesToScroll": 3, "infinite": true}' {% endcomment %}
    >
    </div>
</div>

{% schema %}
{
   "name": "RV",
   "class": "custom-carousel-section",
  "settings": [
    {
    "type": "text",
    "id": "rv-title",
    "label": "Recently Viewed Title",
    "default": "Recently viewed products"
    }
  ]
}
{% endschema %}