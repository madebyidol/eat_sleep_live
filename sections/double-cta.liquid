<div class="grid grid--gutterless double-cta">
	{% if section.settings.image-1 != blank %}
	{% capture child %}
	    <div class="image-overlay"></div>
		<div class="double-cta__title">
			<h5 class="normal-spaced"  data-aos-delay="50" data-aos-anchor-placement="top-center">{{section.settings.title-1}}</h5>
		</div>
		<div class="double-cta__description">
			<p  data-aos-delay="50">{{section.settings.content-1}}</p>
			{% if section.settings.button-url-1 != blank %}
			<a class="main-button" href="{{ section.settings.button-url-1 | downcase }}" data-aos-anchor-placement="top-center"  data-aos-delay="100">{{ section.settings.button-text-1 }}</a>
			{% endif %}
		</div>
        {% if section.settings.video-url-1 != blank %}
            <div class="background-video__container">
                <video autoplay loop muted playsinline>
                    <source src="{{ section.settings.video-url-1 }}" type="video/mp4">
                </video>
            </div>
        {% endif %}
	{% endcapture %}
	<div class="medium--one-whole small--one-whole one-half grid__item grid__item--gutterless double-cta__left"  data-aos-anchor-placement="top-center">
		{% include 'background-image-element' with image: section.settings.image-1, child: child, classes: 'double-cta__image hover-video' %}
	</div>
	{% endif %}

	{% if section.settings.image-2 != blank %}
	{% capture child %}
	    <div class="image-overlay"></div>
		<div class="double-cta__title">
			<h5 class="normal-spaced"  data-aos-delay="50" data-aos-anchor-placement="top-center">{{section.settings.title-2}}</h5>
		</div>
		<div class="double-cta__description">
			<p  data-aos-delay="50" data-aos-anchor-placement="top-center">{{section.settings.content-2}}</p>
			{% if section.settings.button-url-2 != blank %}
			<a class="main-button" href="{{ section.settings.button-url-2 | downcase }}"  data-aos-anchor-placement="top-center" data-aos-delay="100">{{ section.settings.button-text-2 }}</a>
			{% endif %}
		</div>
        {% if section.settings.video-url-2 != blank %}
            <div class="background-video__container">
                <video autoplay loop muted playsinline>
                    <source src="{{ section.settings.video-url-2 }}" type="video/mp4">
                </video>
            </div>
        {% endif %}
	{% endcapture %}
	<div class="medium--one-whole small--one-whole one-half grid__item grid__item--gutterless double-cta__right"  data-aos-anchor-placement="top-center">
		{% include 'background-image-element' with image: section.settings.image-2, child: child, classes: 'double-cta__image hover-video' %}
	</div>
	{% endif %}
</div>

