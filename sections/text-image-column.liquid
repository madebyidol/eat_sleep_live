<section id="text-image-section--{{ section.id }}" class="text-image-section wrapper">
    <div class="text-image-section__content">
        <div class="text-image-section__image">
            <img alt="{{ section.settings.image.alt }}" width="658" height="498" loading="lazy" src='{{ section.settings.image | image_url: width: 950, height: 720 }}' />
        </div>

        <div class="text-image-section__text">
            <h2 class="text-image-section__heading"> {{ section.settings.heading }} </h2>
            <div class="text-image-section__description">
                {{ section.settings.description }} 
            </div>
        </div>
    </div>
</section>

<style>
    #text-image-section--{{ section.id }} .text-image-section__content {
        grid-template-areas: "{{ section.settings.image_position }}";
    }
</style>

{% schema %}
{
  "name": "Text Image Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "image",
      "info": "Minimum size: 950x720px."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        {
          "value": "text image",
          "label": "Right"
        },
        {
          "value": "image text",
          "label": "Left"
        }
      ],
      "default": "text image"
    }
  ],
  "presets": [
    {
      "name": "Text Image Section"
    }
  ]
}
{% endschema %}