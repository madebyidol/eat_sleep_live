<div class="contact-us page-template">
  {% capture page_child %}
    <div class="image-overlay"></div>
    <div class="single-cta__text-container">
      {% if page.title %}<h1 class="h1">{{ page.title }}</h1>{% endif %}
      {% if section.settings.hero-text != blank %}<p>{{ section.settings.hero-text | newline_to_br }}</p>{% endif %}
    </div>
  {% endcapture %}

  {% if section.settings.hero-image %}
    {% assign banner_image = section.settings.hero-image | image_url: width: 1000 %}
  {% endif %}

  {% if section.settings.hero-image-mobile %}
    {% assign banner_image_mobile = section.settings.hero-image-mobile | image_url: width: 500 %}
    <div class="hide small--show medium--show">
      {% include 'page-banner' with child: page_child, banner_image: banner_image_mobile, page_title: page.title %}
    </div>
  {% endif %}

  <div class="{% if section.settings.hero-image-mobile != blank %}small--hide medium--hide{% endif %} show">
    {% include 'page-banner' with child: page_child, banner_image: banner_image, page_title: page.title %}
  </div>

  <div id="contact-form-anchor" class="contact-us__contact">
    <div class="wrapper">
      <div class="grid">
        <div class="grid__item two-thirds medium-down--one-whole contact-us__form-container">

          {% if section.settings.zapier_url != blank %}

            {% if section.settings.form-title != blank %}<h4>{{ section.settings.form-title }}</h4>{% endif %}
            <div class="contact-us__form">

              <form id="contactForm" class="contact__form" name="contactForm" method="post" data-webhook="{{ section.settings.zapier_url }}" novalidate>

                <p class="posted_successfully" style="display: none;">
                  {% if section.settings.posted_successfully != blank %}
                    {{ section.settings.posted_successfully }}
                  {% else %}
                    {{ 'contact.form.post_success' | t }}
                  {% endif %}
                </p>
    
                <p class="posted_error" style="display: none;">
                  There has been an error. Please try again later.
                </p>

      
                <div class="samples-header__form-content">

                    <h4 class="samples-header__form-title">We'd love to hear from you</h4>
  
                </div>
      
                <div class="samples-header__form-fields">
      
                  <input type="hidden" name="contact[form]" value="Contact us form">

                  <input id="first_name" name="contact[first_name]" class="full-width" type="text" placeholder="first name" required>
                  <span class="error" aria-live="polite"></span>
                  
                  <input id="last_name" name="contact[last_name]" class="full-width" type="text" placeholder="last name" required>
                  <span class="error" aria-live="polite"></span>

                  <input id="email" name="contact[email]" class="full-width" type="email" placeholder="email" required>
                  <span class="error" aria-live="polite"></span>

                  <input id="phone" name="contact[phone]" class="full-width" type="text" placeholder="phone number" required>
                  <span class="error" aria-live="polite"></span>

                  <textarea id="howcanwehelp" name="contact[body]" class="full-width" placeholder="how can we help?"></textarea>
                  <span class="error" aria-live="polite"></span>

                  <div class="samples-header__form-select">
                    <label for="hearaboutus">how did you hear about us?</label>
                    <select id="hearaboutus" name="contact[hearaboutus]" class="full-width" >
                      <option disabled="" value="">Please Select</option>
                      <option value="Facebook">Facebook</option>
                      <option value="Instagram">Instagram</option>
                      <option value="Google">Google</option>
                      <option value="Friends or family">Friends or family </option>
                      <option value="Events (i.e. Grand Designs)">Events (i.e. Grand Designs)</option>
                      <option value="Other">Other</option>
                    </select>
                  </div>
      
                  <div class="samples-header__form-radio-buttons">
                    <p>are you?</p>
                    
                    <div class="samples-header__form-radio-button">
                      <input type="radio" id="renovating" name="contact[are_you]" value="Renovating your home" checked>
                      <label for="renovating">
                        Renovating your home
                      </label>
                    </div>

                    <div class="samples-header__form-radio-button">
                      <input type="radio" id="moving" name="contact[are_you]" value="Moving house">
                      <label for="moving">
                        Moving house
                      </label>
                    </div>

                    <div class="samples-header__form-radio-button">
                      <input type="radio" id="browsing" name="contact[are_you]" value="Just browsing">
                      <label for="browsing">
                        Just browsing
                      </label>
                    </div>



                  </div>

                  <div class="samples-header__form-radio-buttons">
                    <p>are you interested in a bespoke creation?</p>
                    <div class="samples-header__form-radio-button">
                      <input type="radio" id="bespokecreation" name="contact[bespokecreation]" value="yes">
                      <label for="bespokecreation">
                        yes
                      </label>
                    </div>
                  </div>
                </div>
      
                <button class="main-button has-chevron" type="submit">
                  <span>Submit</span>
                  {% render 'chevron-right' %}
                </button>
      
                <p class="samples-header__form-note">
                  <small>
                    Eat Sleep Live needs the contact information you provide to us to contact you about our products and services. For information on how to unsubscribe, as well as our commitment to protecting your privacy & data, please review our <a href="/pages/privacy" title="Privacy Policy">Privacy Policy</a>.
                  </small>
                </p>
                
              </form>

            </div>

          {% endif %}

        </div>
        <div class="grid__item one-third medium-down--one-whole contact-us__details-container">
          {% if section.settings.details-title != blank %}<h4>{{ section.settings.details-title }}</h4>{% endif %}
          <div class="contact-us__details">
            {% if section.settings.phone-number != blank %}
              <div class="flex flex-align-center-wrapless m-b-30">
                <div class='contact-us__details-icon'>{% include 'icon-phone' %}</div>
                <div>
                  <a class="m-0 primary" href="tel:{{  section.settings.phone-number  }}">{{section.settings.phone-number}}</a>
                  {% if section.settings.phone-line != blank %}<div class="italic-text secondary-color m-0">{{ section.settings.phone-line | newline_to_br }}</div>{% endif %}
                </div>
              </div>
            {% endif %}
            {% if section.settings.email != blank %}
              <div class="flex flex-align-center-wrapless m-b-30">
                <div class='contact-us__details-icon'>{% include 'icon-mail' %}</div>
                <div>
                  <a class="m-0 primary" href="mailto: {{  section.settings.email  }}">{{section.settings.email}}</a>
                  {% if section.settings.email-subtext != blank %}<div class="italic-text secondary-color m-0">{{ section.settings.email-subtext | newline_to_br }}</div>{% endif %}
                </div>
              </div>
            {% endif %}
            {% if section.settings.live-chat != blank %}
              <div class="flex flex-align-center-wrapless m-b-30">
                <div class='contact-us__details-icon'>{% include 'icon-chat' %}</div>
                <div>
                  <p class="m-0"><span>{{ section.settings.live-chat }} - </span><a style="cursor: pointer;" onclick="const chatElement = document?.getElementById(`ShopifyChat`)?.shadowRoot?.querySelector(`.chat-app>button`)
    chatElement && chatElement.click()">Chat now</a></p>
                  {% if section.settings.live-chat-subtext != blank %}<div class="italic-text secondary-color m-0">{{ section.settings.live-chat-subtext | newline_to_br }}</div>{% endif %}
                </div>
              </div>
            {% endif %}
          </div>
          <div class="m-t-30">
            <h6>{{ section.settings.social-title }}</h6>
            <div class="flex footer__social-links">
              {% for block in section.blocks %}
                <div class="footer__social-link">
                  <a href="{{ block.settings.social-url }}">
                    {% include 'image-element' with image_object: block.settings.social-logo %}
                  </a>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="visit-our-workshop" class="wrapper contact-us__location">
    <div class="grid">
      <div class="grid__item medium-down--one-whole one-half">
        {% if section.settings.location-title != blank %}<h4>{{ section.settings.location-title }}</h4>{% endif %}
        {% if section.settings.location-intro != blank %}<div class="contact-us__location-content">{{ section.settings.location-intro | newline_to_br }}</div>{% endif %}
        {% if section.settings.opening-times != blank %}
        <p class="contact-us__location-title">Opening Times</p>
          <div class="contact-us__location-content">{{ section.settings.opening-times | newline_to_br }}</div>
        {% endif %}
        {% if section.settings.parking != blank %}
        <p class="contact-us__location-title">Parking</p>
          <div class="contact-us__location-content">{{ section.settings.parking | newline_to_br }}</div>
        {% endif %}
        {% if section.settings.booking != blank %}
        <a href="{{ section.settings.booking_link }}" class="main-button">{{ section.settings.booking }}</a>
        {% endif %}
      </div>
      <div class="grid__item medium-down--one-whole one-half">
        <div class="contact-us__map-container">
          <div class="contact-us__map">
            {{ section.settings.google-map }}
          </div>
          <div class="contact-us__address">
            {% if section.settings.address != blank %}
              <div class="contact-us__location-content">
                <p class="contact-us__location-title">{{ shop.name }}</p>
                {{ section.settings.address | newline_to_br }}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>

</div>



