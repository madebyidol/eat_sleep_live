{%- endcomment -%}
	{% if shop.metafields.custom_fields["explore_range"] != blank %}
		{% assign separator = "|###|" %}
      	{% assign product_tag_array = shop.metafields.custom_fields["product_tag"] | split: separator %}
      	{% assign collection_array = shop.metafields.custom_fields["collection"] | split: separator %}
      	{% assign collection_title_array = shop.metafields.custom_fields["collection_title"] | split: separator %}
      	{% assign collection_description_array = shop.metafields.custom_fields["collection_description"] | split: separator %}
      	{% assign fc_keys = shop.metafields.custom_fields["explore_range"] | split: "," %}
      	{% for i in fc_keys %}
      		{% assign index = i | plus: 0 %}
      		{% if product.tags contains product_tag_array[index] %}
      			{% assign collection_ref = collections[collection_array[index]] %}
      			{% if collection_ref != blank %}
	      			
	      			{% capture child %}
	      				<div class="image-overlay"></div>
	      				<div class="single-cta__text-container">
	      					<p class="h1 jenna-sue">{% if collection_title_array[index] != blank %}{{ collection_title_array[index] }}{% else %}{{ collection_ref.title }}{% endif %}</p>
	      				
	      					<h3 class="h5">Part of the {% if collection_title_array[index] != blank %}{{ collection_title_array[index] }}{% else %}{{ collection_ref.title }}{% endif %} Range</h3>

	      					{% if collection_description_array[index] != blank %}<p>{{  collection_description_array[index] }}</p>{% endif %}

	      					<a class="main-button" href="{{ collection_ref.url | downcase }}">VIEW {% if collection_title_array[index] != blank %}{{ collection_title_array[index] }}{% else %} {{ collection.title }}{% endif %} COLLECTION</a>
	      				</div>
	      			{% endcapture %}

	      			{% if collection_ref.image != blank %}
	      				{% include 'background-image-element' with image: collection_ref.image, classes: 'single-cta--full-width single-cta' %}
	      			{% endif %}
	      			{% break %}
      			{% endif %}
      		{% endif %}
      	{% endfor %}
	{% endif %}


{% schema %}
{
	"name": "Explore Range"
}
{% endschema %}	