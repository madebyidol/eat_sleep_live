{% if section.settings.blog != blank %}
<div class="featured-blogs section-padding">
	{% if section.settings.title != blank %}
		<div class="section-title"  data-aos-delay="50" data-aos-anchor-placement="top-center"><h4>{{ section.settings.title }}</h4></div>
	{% endif %} 
	<div class="js-component__slick slick-hide slick-arrows" data-slick='
  	{
  		"slidesToShow": 1,
  		"infinite": false,
  		"draggable": true,
  		"arrows": true,
  		"nextArrow": "<button type=\"button\" class=\"slick-next\"></button>",
  		"prevArrow": "<button type=\"button\" class=\"slick-prev\"></button>",
  		"responsive": [{
  			"breakpoint": 768,
  			"settings": {
  				"slidesToShow": 1.1,
  				"arrows": false
  			}
  		}]
  	}'>
	  	{% for article in blogs[section.settings.blog].articles limit: 3 %}
	  	<div class="{% if forloop.index == 1 %}featured-blogs__blog--first{% endif %} grid grid--gutterless featured-blogs__blog">
	  		<div class="grid__item grid__item--gutterless one-half small--one-whole medium--one-whole" >
	  			{% include 'background-image-element' with image: article.image, classes: 'featured-blogs__image' %}
	  		</div>
	  		<div class="grid__item grid__item--gutterless one-half small--one-whole medium--one-whole featured-blogs__text-half">
	  			<div class="featured-blogs__text-container"  data-aos-delay="150" data-aos-anchor-placement="top-center">
	  				<p class="date-preheader">{{ article.updated_at | date: format: 'abbreviated_date' }}</p>
	  				<h5>{{ article.title }}</h5>
		  			<p class="featured-blogs__description--small light-description">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
		  			<p class="featured-blogs__description--large light-description">{{ article.excerpt_or_content | strip_html | truncate: 266 }}</p>
		  			<a href="{{ article.url | downcase }}" class="main-button-text">READ MORE ></a>
	  			</div>
	  		</div>
	  	</div>
	  	{% endfor %}
	</div>
</div>
{% endif %}


{% schema %}
  {
    "name": "Featured Blogs",
    "settings": [
    	{
    		"type": "blog",
    		"id": "blog",
    		"label": "Blog Category"
    	},
    	{
    		"type": "text",
    		"id": "title",
    		"label": "Section Title"
    	}
    ],
    "presets": [
      {
        "name": "Featured Blogs",
        "category": "Blocks"
      }
    ]
  }
{% endschema %}
