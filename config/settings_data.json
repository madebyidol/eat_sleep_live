    "testimonial-slide-3-name": "Chrisitne Houseley, County Durham",
    "testimonial-slide-4-image": "shopify://shop_images/avatar-image_9b34407b-cccb-44fe-9d2a-3df8c63cfafe.png",
    "testimonial-slide-4-review": "From the first phone call through until delivery, Eat Sleep Live were a delight to deal with. First class service and the actual product, a beautiful bed is already loved! A stunning piece of craftsmanship which will remain with us for many years.",
    "testimonial-slide-5-name": "Duncan Wells, Somerset",
    "testimonial-slide-5-image": "shopify://shop_images/avatar-image_4ad86ad1-a30b-45ed-8821-9bde0f3a3a22.png",
