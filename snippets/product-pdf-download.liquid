<div class="single-cta product__single-cta">
	<div class="single-cta__text-container">
		<h5 class="h5 m-b-10">
			{%- if product.metafields.custom_fields["text_section_title"] != blank -%}
				{{ product.metafields.custom_fields["text_section_title"] }}
			{%- else -%}
				About The {{ product.title }}
			{%- endif -%}
		</h5>
		{% if product.metafields.custom_fields["text_section_content"] != blank %}
			<p class="single-cta__text">{{ product.metafields.custom_fields["text_section_content"] | newline_to_br }}</p>
		{% else %}
			{% if product_desc_intro != blank %}
				{% comment %}
				Workaround to remove erroneous content from old method
				{% endcomment %}
				{% if product_desc_intro contains '<div' %}
					{% assign product_desc_intro_split = product_desc_intro | split: '<div' %}
					<p class="single-cta__text">{{ product_desc_intro_split[0] | newline_to_br }}</p>
				{% else %}
					<p class="single-cta__text">{{ product_desc_intro | newline_to_br }}</p>
				{% endif %}
			{% endif %}
		{% endif %}
		{% if product.metafields.custom_fields["text_section_link_url"] != blank %}
			<a class="secondary-text-link main-button secondary-button" href="{{ product.metafields.custom_fields["text_section_link_url"] | downcase }}">
				{%- if product.metafields.custom_fields["text_section_link_text"] != blank -%}
					{{ product.metafields.custom_fields["text_section_link_text"] }} >
				{%- else -%}
					Request PDF Specification >
				{%- endif -%}
			</a>
		{% else %}
			<p data-overlay-target="#request-pdf" class="secondary-text-link main-button secondary-button overlay-trigger">
				{%- if product.metafields.custom_fields["text_section_link_text"] != blank -%}
					{{ product.metafields.custom_fields["text_section_link_text"] }} >
				{%- else -%}
					Request PDF Specification >
				{%- endif -%}
			</p>
		{% endif %}
	</div>
</div>