<div class="js-component__slick product__slider slick-hide slick-arrows" data-slick='
	{
		"slidesToShow": 1,
		"slidesToScroll": 1,
		"centerPadding": "100px",
		"infinite": true,
		"centerPadding": 0,
		"centerMode": true,
		"variableWidth": true,
		"rows": 0,
		"draggable": true,
		"arrows": true,
		"nextArrow": "<button type=\"button\" class=\"slick-next\"></button>",
		"prevArrow": "<button type=\"button\" class=\"slick-prev\"></button>",
		"responsive": [{
			"breakpoint": 768,
			"settings": {
				"rows": 0,
				"slidesToShow": 1,
				"arrows": false
			}
		}]
	}'>
	{% for block in section.blocks %}
		{% if block.type == 'slider' %}
			{% capture child %}
				<div class="image-overlay"></div>
				<div class="single-cta__text-container">
					{% if block.settings.title %}<h3 class="h5">{{ block.settings.title }}</h3>{% endif %}
					{% if block.settings.content %}<p>{{ block.settings.content | newline_to_br }}</p>{% endif %}
					{% if block.settings.link-url %}
						<a class="main-button" href="{{ block.settings.link-url | downcase }}">{{ block.settings.link-title }}</a>
					{% endif %}
				</div>
			{% endcapture %}

			{% assign cta-classes = 'single-cta' %}
			{% if section.settings.full == true %}
				{% assign cta-classes = 'single-cta--full-width single-cta' %}
			{% endif %}

			{% if block.settings.image != blank %}
				<div>
				{% include 'background-image-element' with image: block.settings.image, classes: cta-classes %}
				</div>
			{% endif %}
		{% endif %}
	{% endfor %}
</div>