<style>#section-images_{{ images_index }} { background-color: {{background_colour_array[images_index]}} }</style>
<div id="section-images_{{ images_index }}" class="block-images content-block__standard">
	<div class="block-images__container article-content grid">
		{% assign image_2 = image_2_array[images_index] %}
		{% if image_1_array[images_index] != blank %}
			<div class="grid__item grid__item--gutterless {% if image_2 != blank %}small--one-whole one-half block-images--padding-right{% else %}one-whole{% endif %}">
				{% if force_1x1_aspect_ratio_array[images_index] %}
