						style="background-image: url({{image_1_array[images_index]}})"
						class="block-images__background-image">
					</div>
				{% else %}
					<img class="block-images__image" src="{{image_1_array[images_index]}}">
				{% endif %}
			</div>
			{% if image_2 != blank %}
				<div class="grid__item grid__item--gutterless small--one-whole one-half block-images--padding-left">
					{% if force_1x1_aspect_ratio_array[images_index] %}
						<div 
							style="background-image: url({{image_2}})"
							class="block-images__background-image block-images--padding-left">
						</div>
					{% else %}
						<img class="block-images__image" src="{{image_2}}">
					{% endif %}
				</div>
			{% endif %}
		{% endif %}
	</div>
</div>