{% comment %}
Pass the following to create a standard header
title - Header title
title-class - Heading class
description - Header content
link - Button link
link-text - Button text
image - header image
{% endcomment %}

{% capture child %}
	<div class="image-overlay"></div>
	{% if title-class != blank %}
		<{{title-class}} class="standard-header__title">{{ title }}</{{title-class}}>
	{% else %}
		<h1 class="standard-header__title">{{ title }}</h1>
	{% endif %}
	{% if description != blank %}
		<p class="standard-header__description">{{ description }}</p>
	{% endif %}
	{% if link != blank %}
		<a href="{{ link | downcase }}" class="main-button">{{ link-text }}</a>
	{% endif %}
{% endcapture %}

{% if image != blank %}
<div class="standard-header">
	{% include 'background-image-element' with child: child, image: image, classes: 'flex-center' %}
</div>
{% endif %}