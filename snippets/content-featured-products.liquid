{% if featured_products_background_array[featured_products_index] != blank %}
	<style> #section-featured_{{ featured_products_index }} { background-color: {{featured_products_background_array[featured_products_index]}};}</style>
{% endif %}
<div id="section-featured_{{ featured_products_index }}" class="article-content block-featured">
	{% if sp_products_title_array[featured_products_index] != blank %}<h4>{{ sp_products_title_array[featured_products_index] }}</h4>{% endif %}
	<div class="js-component__slick slick-hide slick-arrows" data-slick='
	  	{
	  		"slidesToShow": {% if slides %}{{ slides }}{% else %}4{% endif %},
	  		"slidesToScroll": {% if slides %}{{ slides }}{% else %}4{% endif %},
	  		"infinite": false,
	  		"variableWidth": false,
	  		"arrows": true,
	  		"nextArrow": "<button type=\"button\" class=\"slick-next {% if full_arrow == true %}slick-arrow-full{% endif %}\"></button>",
	  		"prevArrow": "<button type=\"button\" class=\"slick-prev {% if full_arrow == true %}slick-arrow-full{% endif %}\"></button>",
	  		"responsive": [
	  			{
		  			"breakpoint": 768,
		  			"settings": {
		  				"arrows": false,
		  				"slidesToShow": 1.2,
		  				"slidesToScroll": 1
	  			}
	  		}]
	  	}'>
	  		{% assign featured_products_array_split = featured_products_array[featured_products_index] | split: '|' %}
	  		{% for featured_product in featured_products_array_split %}
	  			{% assign product = all_products[featured_product] %}
	  			{% if product != blank %}
	  				{% include 'product-block' %}
	  			{% endif %}
	  		{% endfor %}
	  	</div>
</div>