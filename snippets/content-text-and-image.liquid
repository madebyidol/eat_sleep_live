<div class="article-content block-text-image grid grid--gutterless content-block__standard" id="text-and-image_{{ text_and_image_index }}">
	<div class="block-text-image__container">
		{% if side_by_side_array[text_and_image_index] != 'Image right, text left' %}
			<div class="large--one-half one-whole article-content__standard grid__item grid__item--gutterless block-text-image__image block-text-image__image--left">
				{% if text_and_image_image_array[text_and_image_index] != blank %}<img src="{{ text_and_image_image_array[text_and_image_index] }}">{% endif %}
			</div>
			{% if sp_text_image_bg_array[text_and_image_index] != blank %}
				<style>#text-and-image_{{ text_and_image_index }} .block-text-image__text { background-color: {{sp_text_image_bg_array[text_and_image_index]}}; }</style>
			{% endif %}
			<div class="large--one-half one-whole article-content__standard grid__item grid__item--gutterless block-text-image__text">
				{% if text_and_image_title_array[text_and_image_index] != blank %}<h3>{{text_and_image_title_array[text_and_image_index]}}</h3>{% endif %}
				<p>{{ text_and_image_text_array[text_and_image_index] | newline_to_br }}</p>
				{% if text_and_image_link_text_array[text_and_image_index] != blank and text_and_image_link_url_array[text_and_image_index] != blank %}
					<a class="main-button secondary-button secondary-text-link" href="{{ text_and_image_link_url_array[text_and_image_index] | downcase }}">{{text_and_image_link_text_array[text_and_image_index]}} ></a>
				{% endif %}
			</div>
		{% else %}
			<div class="large--hide one-whole article-content__standard grid__item grid__item--gutterless block-text-image__image">
				{% if text_and_image_image_array[text_and_image_index] != blank %}<img src="{{text_and_image_image_array[text_and_image_index]}}">{% endif %}
			</div>
			{% if sp_text_image_bg_array[text_and_image_index] != blank %}
				<style>#text-and-image_{{ text_and_image_index }} .block-text-image__text { background-color: {{sp_text_image_bg_array[text_and_image_index]}}; }</style>
			{% endif %}
			<div class="large--one-half one-whole article-content__standard grid__item grid__item--gutterless block-text-image__text block-text-image__text--right">
				{% if text_and_image_title_array[text_and_image_index] != blank %}<h3>{{text_and_image_title_array[text_and_image_index]}}</h3>{% endif %}
				<p>{{ text_and_image_text_array[text_and_image_index] | newline_to_br }}</p>
				{% if text_and_image_link_text_array[text_and_image_index] != blank and text_and_image_link_url_array[text_and_image_index] != blank %}
					<a class="main-button secondary-button secondary-text-link" href="{{ text_and_image_link_url_array[text_and_image_index] | downcase }}">{{text_and_image_link_text_array[text_and_image_index]}} ></a>
				{% endif %}
			</div>
			<div class="large--one-half medium--hide small--hide article-content__standard grid__item grid__item--gutterless block-text-image__image block-text-image__image--right">
				{% if text_and_image_image_array[text_and_image_index] != blank %}<img src="{{text_and_image_image_array[text_and_image_index]}}">{% endif %}
			</div>
		{% endif %}
	</div>
</div>