<div class="site-header__dropdown site-header__image-dropdown">
	{% for i in (1..6) %}
	{% assign title_key = 'collection_images_title_' | append: i %}
	{% assign image_key = 'collection_images_image_' | append: i %}
	{% assign link_key = 'collection_images_link_' | append: i %}
	{% if title_key != blank and image_key != blank %}
	<div class="one-sixth site-header__image-container">
		<a href="/collections/{{ block.settings[link_key] | downcase }}">
			<div class="site-header__image" style="background-image: url({{ block.settings[image_key].src | image_url: '300x'}});">
				<div class="site-header__image-text-container">    
					<p>{{ block.settings[title_key] }}</p>
				</div>
			</div>
		</a>
	</div>
	{% endif %}
	{% endfor %}
</div>