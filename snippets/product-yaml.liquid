{% if product.metafields.custom_fields["you_may_also_like"] != blank %}
<div class="block-featured product__yaml">
	{% if section.settings.yaml-title != blank %}
		<div class="section-title"><h4>{{ section.settings.yaml-title }}</h4></div>
	{% endif %} 
	{% assign product_refs = product.metafields.custom_fields["you_may_also_like"] | split: "|" %}
  <div class="js-component__slick slick-hide slick-arrows" data-slick='
  	{
  		"slidesToShow": 3,
  		"slidesToScroll": 3,
  		"infinite": false,
  		"draggable": true,
  		"rows": false,
  		"arrows": true,
  		"nextArrow": "<button type=\"button\" class=\"slick-next\"></button>",
  		"prevArrow": "<button type=\"button\" class=\"slick-prev\"></button>",
  		"responsive": [{
  			"breakpoint": 768,
  			"settings": {
  				"slidesToShow": 1.2,
          "slidesToScroll": 1,
  				"arrows": false
  			}
  		}]
  	}'>
  	{% for product_handle in product_refs %}
  		{% assign product_ref = all_products[product_handle] %}
  		{% if product_ref != blank %}
  			<div class="product-block">
		        <a href="{{ product_ref.url | downcase }}">
					{% include 'image-element' with image_object: product_ref.featured_image, fade_in: true %}
					<h5>{{product_ref.title}}</h5>
					<p class="product-block__price">{% if product_ref.price_varies %}From {% endif %}{{ product_ref.price_min | money }}</p>
	      		</a>
  			</div>
  		{% endif %}
  	{% endfor %}
  </div>
</div>
{% endif %}