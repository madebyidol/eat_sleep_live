<div class="article-share">
	<div class="grid grid--gutterless large--flex">
		<div class="large--one-third grid__item grid__item--gutterless flex article-share__pagination">
			{% if blog.previous_article != blank %}
				<a class="secondary-button secondary-text-link" href="{{ blog.previous_article | downcase }}">{% include 'blog-prev-arrow' %}</a>
			{% else %}
				<a class="secondary-button secondary-text-link">{% include 'no-blog-prev-arrow' %}</a>
			{% endif%}
		</div>
		<div class="large--one-third grid__item grid__item--gutterless flex flex-center article-share__share-container">
				<p>Share</p>
				<div class="article-share__social-icon" data-href="{{ shop.url }}{{ article.url | downcase }}"><a target="_blank" href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Fwww.eatsleeplive.co.uk%2Fblogs%2Ffeatures%2Feastside-blog&amp;src=sdkpreparse" class="fb-xfbml-parse-ignore flex">{% include 'social-facebook-icon' %}</a></div>
				<a target="_blank" rel="canonical" class="twitter-share-button article-share__social-icon flex"
				  href="https://twitter.com/intent/tweet?url={{ shop.url | url_encode }}{{ article.url | downcase | url_encode }}&text={{ article.title | url_encode}}">
				{% include 'social-twitter-icon' %}</a>
				<a class="article-share__social-icon flex" href="http://pinterest.com/pin/create/button/?url={{ shop.url | url_encode }}{{ article.url | downcase  | url_encode}}&description={{ article.title | url_encode}}">{% include 'social-pinterest-icon' %}</a>
				
		</div>
		<div class="large--one-third grid__item grid__item--gutterless flex article-share__pagination article-share__pagination--right">
			{% if blog.next_article != blank %}
				<a class="main-button secondary-button secondary-text-link" href="{{ blog.next_article | downcase }}">{% include 'blog-next-arrow' %}</a>
			{% else %}
				<a class="secondary-button secondary-text-link">{% include 'no-blog-next-arrow' %}</a>
			{% endif %}
		</div>
	</div>
</div>