{% if settings.offer_banner_annimation == true %}

  <script>

    let currentScroll = 0;
    let isScrollingDown = true;

    let tween = gsap.to(".marquee__part", {xPercent: -100, repeat: -1, duration: 29, ease: "linear"}).totalProgress(0.5);

    gsap.set(".marquee__inner", {xPercent: -16});

    window.addEventListener("scroll", function(){
      
      if ( window.pageYOffset > currentScroll ) {
        isScrollingDown = true;
      } else {
        isScrollingDown = false;
      }
      
      gsap.to(tween, {
        timeScale: isScrollingDown ? 1 : -1
      });
      
      currentScroll = window.pageYOffset
    });


  </script>

{% endif %}