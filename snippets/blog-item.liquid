<a class="grid__item large--one-third {% unless recommendation == true %}medium--one-half{% endunless %} small--one-whole m-b-60 hide-fade-in" href="{{ article_item.url | downcase }}">
	<div>
		{% if section.settings.same-size == true %}
			{% include 'background-image-element' with image: article_item.image, classes: 'blogs_blog-image blogs_blog-background-image' %}
		{% else %}
			{% include 'image-element' with image_object: article_item.image, classes: 'blogs_blog-image' %}
		{% endif %}
		{% if recommendation == true %}
			<div class="blogs__byline hide small--show medium--show">
				<p class="blogs__byline-text blogs__recommended-date"><p>{{ article_item.published_at | date: format: 'abbreviated_date' }}</p></p>
			</div>
		{% endif %}
		<p class="blogs__blog-title">{{ article_item.title }}</p>
		<div class="blogs__byline flex">
			{% if section.settings.image != blank %}
				{% include 'image-element' with image_object: section.settings.image, classes: 'blogs__byline-icon' %}
			{% elsif article_item.user.image != blank %}
				<img class="blogs__byline-icon" src="https://cdn.shopify.com/s/files/1/1230/4400/files/avatar_250x250_crop_center_1080x_6dbb2290-ccfe-4d60-a228-9b61643f9aa8.jpg?v=1741432212" alt="Picture of Mark the author" width="250px" height="250px">
			{% endif %}
			<p class="blogs__byline-text">BY <span>{% if section.settings.byline != blank %}{{ section.settings.byline }}{% else %}{{ article_item.author }}{% endif %}</span><span class="small--hide medium--hide"> | {{ article_item.published_at | date: format: 'abbreviated_date' }}</span></p>
		</div>
	</div>
</a>
