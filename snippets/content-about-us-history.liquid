{% if shop.metafields.custom_fields["about_us_history_slider"] != blank %}
  {% assign history_image_array = shop.metafields.custom_fields["history_image"] | split: separator %}
  {% assign history_title_array = shop.metafields.custom_fields["history_title"] | split: separator %}
  {% assign history_description_array = shop.metafields.custom_fields["history_description"] | split: separator %}
  {% assign about_us_slides = shop.metafields.custom_fields["about_us_history_slider"] | split: "," %}

  <div class="article-content block-featured">
  	{% if page.metafields.custom_fields["about_us_history_title"] != blank %}<h4>{{ page.metafields.custom_fields["about_us_history_title"] }}</h4>{% endif %}
  	<div class="js-component__slick slick-hide slick-arrows" data-progress-bar="#history-slider-{{au_history_position_check}}" data-slick='
  	  	{
  	  		"slidesToShow": 3,
  	  		"slidesToScroll": 3,
  	  		"infinite": false,
  	  		"variableWidth": false,
  	  		"arrows": true,
  	  		"nextArrow": "<button type=\"button\" class=\"slick-next {% if full_arrow == true %}slick-arrow-full{% endif %}\"></button>",
  	  		"prevArrow": "<button type=\"button\" class=\"slick-prev {% if full_arrow == true %}slick-arrow-full{% endif %}\"></button>",
  	  		"responsive": [
  	  			{
  		  			"breakpoint": 768,
  		  			"settings": {
  		  				"arrows": false,
  		  				"slidesToShow": 1.2,
  		  				"slidesToScroll": 1
  	  			}
  	  		}]
  	  	}'>
	      {% for slide in about_us_slides %}
	        {% assign slides_index = slide | plus: 0 %}
	  		<div class="product-block">
	  			<img src="{{ history_image_array[slides_index] }}" alt="{{ history_title_array[slides_index] }}">
  				<h5 class="product-block__title about-us__history-title m-t-20 m-b-10">{{ history_title_array[slides_index] }}</h5>
  				<p class="product-block__price about-us__history-desc">{{ history_description_array[slides_index] }}</p>
	  		</div>
	      {% endfor %}
  	</div>
  	<div class="slick-progress-bar m-t-45">
  		<div id="history-slider-{{au_history_position_check}}" class="slick-progress-bar-value"></div>
  	</div>
  </div>
{% else %}
<p>Ensure history slides have been added on <a href="https://customfields.bonify.io/dashboard/eat-sleep-live-2.myshopify.com/globals">custom fields</a></p>
{% endif %}