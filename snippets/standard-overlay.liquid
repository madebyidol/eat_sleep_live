<!-- 
Assign overlay_title for the title 
Assign overlay_content for the content 
Assign a unique ID to overlay_id 

To show overlay, add overlay-trigger class to button 
As well as overlay ID (with #) to data-overlay-target attribute
-->


<div id="{{ overlay_id }}" data-overlay-target="#{{ overlay_id }}" class="standard-overlay Fixed standard-overlay--hide overlay-close">
	<div class="standard-overlay__container p-r-40 p-l-40 p-t-35 p-b-45">
		<div class="flex m-0 flex-align-center">
			<p class="standard-overlay__bold-title m-0">{{ overlay_title }}</p>
			<img class="overlay-close  standard-overlay__close" alt="close icon" src="{{ 'close-icon-black.svg' | asset_url }}" alt="Close overlay" data-overlay-target="#{{ overlay_id }}">
		</div>
		<div>
			{{ overlay_content }}
		</div>
	</div>
</div>