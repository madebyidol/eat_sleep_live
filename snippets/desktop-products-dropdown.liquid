<div class="site-header__dropdown site-header__products-dropdown">
	{% for i in (1..6) %}
	{% assign menu_key = 'products_menu_' | append: i %}
	{% assign products_key = 'products_product_' | append: i %}
	{% assign hide_title_key = 'products_text_' | append: i %}
	{% assign link_list = block.settings[menu_key] %}
	{% assign product = block.settings[products_key] %}
	{% assign hide_title = block.settings[hide_title_key] %}

		{% if link_list != blank %}
			{% assign dropdown_menu = linklists[link_list] %}
			<div class="one-sixth">
				<p class="site-header__dropdown-links-title">{% unless hide_title == true %}{{ dropdown_menu.title }} {% endunless %}</p>
				<ul class="site-header__dropdown-links">
					{% for link in dropdown_menu.links %}
						<li><a href="{{ link.url | downcase }}">{{ link.title | escape }}</a></li>
					{% endfor %}
				</ul>
			</div>
		{% elsif product != blank %}
			{% assign product = all_products[product] %}
			<div class="one-sixth site-header__product-container">
				{% include 'product-block' %}
			</div>
		{% else %}
			<div class="one-sixth"></div>
		{% endif %}
	{% endfor %}
</div>