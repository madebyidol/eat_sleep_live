{% comment %}
  Reusable Slider Arrows Snippet
  
  Usage:
  {% render 'slider-arrows', 
    slider_class: 'my-slider',
    prev_class: 'custom-prev',
    next_class: 'custom-next'
  %}
  
  Parameters:
  - slider_class: Required. The class name of the slider container (used for styling specificity)
  - prev_class: Optional. Additional class for prev arrow
  - next_class: Optional. Additional class for next arrow
{% endcomment %}

{% assign slider_class = slider_class | default: 'slider' %}
{% assign prev_class = prev_class | default: '' %}
{% assign next_class = next_class | default: '' %}

<button class="slider-arrow slider-arrow-prev {{ prev_class }}" aria-label="Previous slide">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="15 18 9 12 15 6"></polyline>
  </svg>
</button>

<button class="slider-arrow slider-arrow-next {{ next_class }}" aria-label="Next slide">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="9 18 15 12 9 6"></polyline>
  </svg>
</button>

<style>
  /* Base slider arrow styles */
  .{{ slider_class }} .slider-arrow {
    display: flex;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #ddd;
    background: #fff;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    z-index: 10;
    padding: 0;
  }

  .{{ slider_class }} .slider-arrow:hover {
    background: #f5f5f5;
    border-color: #999;
  }

  .{{ slider_class }} .slider-arrow:active {
    transform: scale(0.95);
  }

  .{{ slider_class }} .slider-arrow:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .slider-arrow:disabled:hover {
    background: #fff;
    border-color: #ddd;
    transform: none;
  }

  .slider-arrow.is-disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .slider-arrow svg {
    display: block;
  }

  .slider-arrow {
    position: absolute;
  }

  .slider-arrow.slider-arrow-prev {
    left: -16px;
  }

  .slider-arrow.slider-arrow-next {
    right: -16px;
  }

</style>
