<div class="page-banner">
  {% if child != blank and banner_image != blank %}

    {% if cta-classes == blank %}
      {% assign cta-classes = 'single-cta--full-width single-cta' %}
    {% endif %}

    <div style="background-image: url('{{ banner_image }}')" class="{{ cta-classes }} background-image">
      {{ child }}    
    </div>

  {% elsif banner_video != blank and child != blank %}

    <div class="background-video background-image__video single-cta">
      {{ child }}
      <div class="background-video__container">
        <video autoplay loop muted playsinline>
          <source src="{{ banner_video }}" type="video/mp4">
        </video>
      </div>
    </div>

  {% else %}
    {% if banner_title %}<div class="content-block__standard"><h1 class="h1">{{ banner_title }}</h1></div>{% endif %}
  {% endif %} 
</div>