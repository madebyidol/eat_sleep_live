{%- if is_product -%}
	{% assign img_url = image_object | img_url: '526x526', crop: 'center', scale: 2 %}
{%- else -%}
	{% assign img_url = image_object | img_url: '1080x' %}
{%- endif -%}

<img class="lazyload {% if fade_in == true %}lazyload-fade{% endif %} {{ classes }}"
	{{image_style}}
	src="data:image/png;base64,"
	data-src="{{ img_url }}"
	data-widths="[100, 240, 260, 400, 600, 800]"
	data-aspectratio="{{ image_object.aspect_ratio }}"
	data-sizes="auto"
	data-parent-fit="contain"
	alt="{{ image_object.alt | escape }}"
	width="{{ image_object.width }}"
	height="{{ image_object.height }}"
    {% if id %}id="{{ id }}"{% endif %}>