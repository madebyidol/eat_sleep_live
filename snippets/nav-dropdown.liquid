<div class="site-header__navigation-item-dropdown">

  <div class="site-header__navigation-item-header">
    <button class="mobile-back">
      <img src="{{ 'chevron-right-new.svg' | asset_url }}" alt="next-icon" width="24" height="24" loading="lazy">
    </button>
    <span>{{ link.title }}</span>
  </div>

  <div class="site-header__navigation-item-dropdown-inner site-header__navigation-item-dropdown-inner--tabbed wrapper">

    {% if link.links %}

      {% comment %} Left sidebar: second-level links act as tab triggers {% endcomment %}
      <ul class="site-header__nav-tabs">
        {% for childlink in link.links %}
          <li class="site-header__nav-tab {% if forloop.first %}is-active{% endif %}"
              data-tab="{{ link.handle }}-{{ forloop.index }}">
            <a href="{{ childlink.url }}" class="caps mobile-next site-header__nav-tab-label{% if childlink.links.size > 0 %} has-children{% endif %}">
              <span class="caps ">{{ childlink.title }}</span>
              {% if childlink.links.size > 0 %}
                <img class="mobile-next-arrow" src="{{ 'chevron-right-new.svg' | asset_url }}" alt="next-icon" width="24" height="24" loading="lazy">
              {% endif %}
            </a>

            {% if childlink.links.size > 0 %}
              <div class="site-header__navigation-item-dropdown site-header__navigation-level-3">
                <div class="site-header__navigation-item-header">
                  <button class="mobile-back">
                    <img src="{{ 'chevron-right-new.svg' | asset_url }}" alt="back-icon" width="24" height="1248" loading="lazy">
                  </button>
                  <span>{{ childlink.title }}</span>
                </div>
                <div class="site-header__navigation-item-dropdown-inner">
                  <ul class="site-header__navigation-grandchild-list site-header__navigation-grandchild-list--mobile">
                    {% for grandchild in childlink.links %}
                      {% assign grandchild-collection = collections[grandchild.object.handle] %}
                      <li class="site-header__navigation-grandchild-item">
                        <a href="{{ grandchild.url }}">
                          {% if grandchild-collection.metafields.custom.collection_icon != blank %}
                            <img src="{{ grandchild-collection.metafields.custom.collection_icon | image_url: width: 48, height: 48 }}" alt="{{ grandchild.title }}" width="24" height="24" loading="lazy">
                          {% endif %}
                          {{ grandchild.title }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </div>
            {% endif %}

          </li>
        {% endfor %}

        {% comment %} CTA button from block settings, shown at bottom of sidebar {% endcomment %}
        {% for block in blocks %}
          {% if block.settings.nav_link == link.title and block.settings.lower_button_url != blank %}
            <li class="site-header__nav-tab site-header__nav-tab--cta">
              <a href="{{ block.settings.lower_button_url }}" class="site-header__navigation-button">
                <span>{{ block.settings.lower_button_label }}</span>
                <svg width="1em" height="1em" viewBox="0 0 16 16" fill="#ffffff" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/></svg>
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      {% comment %} Right panel: grandchild links shown per active tab {% endcomment %}
      <div class="site-header__nav-panels">
        {% for childlink in link.links %}
          <div class="site-header__nav-panel {% if forloop.first %}is-active{% endif %}"
               data-panel="{{ link.handle }}-{{ forloop.index }}">

            {% if childlink.links %}
              <ul class="site-header__navigation-grandchild-list">
                {% for grandchild in childlink.links %}
                  {% assign grandchild-collection = collections[grandchild.object.handle] %}
                  <li class="site-header__navigation-grandchild-item">
                    <a href="{{ grandchild.url }}">
                      {% if grandchild-collection.metafields.custom.collection_icon != blank %}
                        <img src="{{ grandchild-collection.metafields.custom.collection_icon | image_url: width: 48, height: 48 }}" alt="{{ grandchild.title }}" width="24" height="24" loading="lazy">
                      {% endif %}
                      {{ grandchild.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}

          </div>
        {% endfor %}

        {% comment %} Optional dropdown image block in the right panel {% endcomment %}
        {% for block in blocks %}
          {% if block.type == "dropdown_image" and block.settings.nav_link == link.title %}
            <a href="{{ block.settings.button_url | default: '#' }}" class="site-header__navigation-image">
              <img
                data-swap="{{ block.settings.nav_image | image_url: width: 527, height: 330, crop: 'center' }}"
                class="swapimg"
                alt="{{ link.title }}"
              >
              {% if block.settings.button_label != blank %}
                <span class="main-button site-header__navigation-image-label">
                  <span>{{ block.settings.button_label }}</span>
                  <svg width="1em" height="1em" viewBox="0 0 16 16" fill="#ffffff" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/></svg>
                </span>
              {% endif %}
            </a>
          {% endif %}
        {% endfor %}

      </div>

    {% endif %}

  </div>

</div>

<style>
  /* Two-panel tabbed layout */
  .site-header__navigation-item-dropdown-inner--tabbed {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 0;
    padding-top: 40px !important;
    padding-bottom: 40px;
  }

  /* Left sidebar */
  .site-header__nav-tabs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 24px;
    flex-direction: column;
    border-right: 1px solid #e8e5e0;
    min-width: 160px;
    flex-shrink: 0;
  }

  .site-header__nav-tab {
    margin: 0;
  }

  .site-header__nav-tab-label {
    display: block;
    text-decoration: none;
    color: inherit;
    font-size: 16px;
    font-family: Lexend Exa, sans-serif;
    letter-spacing: 1px;
    text-transform: uppercase;
    white-space: nowrap;
    transition: color 0.15s ease, background 0.15s ease;
    cursor: pointer;
    color: var(--esl-olive);
  }

  @media screen and (min-width: 1081px) {
    .site-header__nav-tab.is-active .site-header__nav-tab-label,
    .site-header__nav-tab:hover .site-header__nav-tab-label {
      color: #9f5130;
    }
  }

  .site-header__nav-tab--cta {
    margin-top: auto;
    padding: 16px 20px 0 0;
  }

  /* Right panel */
  .site-header__nav-panels {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 16px;
    padding-left: 24px;
    position: relative;
  }

  @media screen and (max-width: 1080px) {
    .site-header__nav-panels {
      display: none;
    }
    .site-header__nav-tab--cta {
      padding-top: 40px;
    }
    .site-header__nav-tab--cta .site-header__navigation-button {
      margin-left: 0;
      margin-right: 0;
      width: fit-content;
    }
  }

  .site-header__nav-panel {
    display: none;
  }

  .site-header__nav-panel.is-active {
    display: block;
  }

  /* Grandchild link grid */
  .site-header__navigation-grandchild-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    max-width: 746px;
  }

  .site-header__navigation-grandchild-item a {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: inherit;
    font-size: 15px;
    transition: color 0.15s ease;
    white-space: nowrap;
    padding: 12px 0;
  }

  .site-header__navigation-grandchild-item a:hover {
    color: #9f5130;
  }

  /* Mobile: hide tab panel structure, show flat list */
  @media (max-width: 1080px) {
    .site-header__navigation-item-dropdown-inner--tabbed {
      flex-direction: column;
    }

    .site-header__nav-tabs {
      border-right: none;
      min-width: 0;
    }

    .site-header__nav-panel {
      display: block;
    }

    .site-header__navigation-grandchild-list {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (function() {
    var dropdowns = document.querySelectorAll('.site-header__navigation-item-dropdown-inner--tabbed');

    dropdowns.forEach(function(dropdown) {
      var tabs = dropdown.querySelectorAll('.site-header__nav-tab:not(.site-header__nav-tab--cta)');

      tabs.forEach(function(tab) {
        var label = tab.querySelector('.site-header__nav-tab-label');
        var panelId = tab.dataset.tab;
        var panel = dropdown.querySelector('[data-panel="' + panelId + '"]');

        // Desktop: hover to switch panels (only if this tab has children)
        tab.addEventListener('mouseenter', function() {
          if (!panel || !panel.querySelector('.site-header__navigation-grandchild-item')) return;
          // Deactivate all
          dropdown.querySelectorAll('.site-header__nav-tab').forEach(function(t) {
            t.classList.remove('is-active');
          });
          dropdown.querySelectorAll('.site-header__nav-panel').forEach(function(p) {
            p.classList.remove('is-active');
          });
          // Activate this tab and its panel
          tab.classList.add('is-active');
          panel.classList.add('is-active');
        });
      });
    });
  })();
</script>
