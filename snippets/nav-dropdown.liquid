<div class="site-header__navigation-item-dropdown">

  <div class="site-header__navigation-item-header">
    <button class="mobile-back">
      <img src="{{ 'chevron-right-new.svg' | asset_url }}" alt="next-icon" width="18" height="18" loading="lazy">
    </button>
    <span>{{ link.title }}</span>
  </div>

  <div class="site-header__navigation-item-dropdown-inner site-header__navigation-item-dropdown-inner--tabbed">

    {% if link.links %}

      {% comment %} Left sidebar: second-level links act as tab triggers {% endcomment %}
      <ul class="site-header__nav-tabs">
        {% for childlink in link.links %}
          <li class="site-header__nav-tab {% if forloop.first %}is-active{% endif %}"
              data-tab="{{ link.handle }}-{{ forloop.index }}">
            <a href="{{ childlink.url }}" class="mobile-next site-header__nav-tab-label">
              {{ childlink.title }}
            </a>
          </li>
        {% endfor %}

        {% comment %} CTA button from block settings, shown at bottom of sidebar {% endcomment %}
        {% for block in blocks %}
          {% if block.settings.nav_link == link.title and block.settings.lower_button_url != blank %}
            <li class="site-header__nav-tab site-header__nav-tab--cta">
              <a href="{{ block.settings.lower_button_url }}" class="site-header__navigation-button">
                <span>{{ block.settings.lower_button_label }}</span>
                <svg width="1em" height="1em" viewBox="0 0 16 16" fill="#ffffff" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/></svg>
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      {% comment %} Right panel: grandchild links shown per active tab {% endcomment %}
      <div class="site-header__nav-panels">
        {% for childlink in link.links %}
          <div class="site-header__nav-panel {% if forloop.first %}is-active{% endif %}"
               data-panel="{{ link.handle }}-{{ forloop.index }}">

            {% if childlink.links %}
              <ul class="site-header__navigation-grandchild-list">
                {% for grandchild in childlink.links %}
                  <li class="site-header__navigation-grandchild-item">
                    <a href="{{ grandchild.url }}">
                      {{ grandchild.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}

          </div>
        {% endfor %}

        {% comment %} Optional dropdown image block in the right panel {% endcomment %}
        {% for block in blocks %}
          {% if block.type == "dropdown_image" and block.settings.nav_link == link.title %}
            <div class="site-header__navigation-image">
              <img
                data-swap="{{ block.settings.nav_image | image_url: width: 527, height: 330, crop: 'center' }}"
                class="swapimg"
                alt="{{ link.title }}"
              >
              {% if block.settings.button_url != blank %}
                <a href="{{ block.settings.button_url }}">
                  <span>{{ block.settings.button_label }}</span>
                  <svg width="1em" height="1em" viewBox="0 0 16 16" fill="#ffffff" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/></svg>
                </a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}

      </div>

    {% endif %}

  </div>

</div>

<style>
  /* Two-panel tabbed layout */
  .site-header__navigation-item-dropdown-inner--tabbed {
    display: flex;
    align-items: stretch;
    gap: 0;
  }

  /* Left sidebar */
  .site-header__nav-tabs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    border-right: 1px solid #e8e5e0;
    min-width: 160px;
    flex-shrink: 0;
  }

  .site-header__nav-tab {
    margin: 0;
  }

  .site-header__nav-tab-label {
    display: block;
    padding: 14px 20px;
    text-decoration: none;
    color: inherit;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: color 0.15s ease, background 0.15s ease;
    cursor: pointer;
  }

  .site-header__nav-tab.is-active .site-header__nav-tab-label,
  .site-header__nav-tab:hover .site-header__nav-tab-label {
    color: #9f5130;
  }

  .site-header__nav-tab--cta {
    margin-top: auto;
    padding: 16px 20px;
  }

  /* Right panel */
  .site-header__nav-panels {
    flex: 1;
    padding: 24px 32px;
    position: relative;
  }

  .site-header__nav-panel {
    display: none;
  }

  .site-header__nav-panel.is-active {
    display: block;
  }

  /* Grandchild link grid */
  .site-header__navigation-grandchild-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px 24px;
  }

  .site-header__navigation-grandchild-item a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    text-decoration: none;
    color: inherit;
    font-size: 0.9rem;
    transition: color 0.15s ease;
  }

  .site-header__navigation-grandchild-item a:hover {
    color: #9f5130;
  }

  /* Mobile: hide tab panel structure, show flat list */
  @media (max-width: 1080px) {
    .site-header__navigation-item-dropdown-inner--tabbed {
      flex-direction: column;
    }

    .site-header__nav-tabs {
      border-right: none;
      border-bottom: 1px solid #e8e5e0;
      min-width: 0;
    }

    .site-header__nav-panel {
      display: block;
    }

    .site-header__navigation-grandchild-list {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (function() {
    var dropdowns = document.querySelectorAll('.site-header__navigation-item-dropdown-inner--tabbed');

    dropdowns.forEach(function(dropdown) {
      var tabs = dropdown.querySelectorAll('.site-header__nav-tab:not(.site-header__nav-tab--cta)');

      tabs.forEach(function(tab) {
        var label = tab.querySelector('.site-header__nav-tab-label');
        var panelId = tab.dataset.tab;
        var panel = dropdown.querySelector('[data-panel="' + panelId + '"]');

        // Desktop: hover to switch panels
        tab.addEventListener('mouseenter', function() {
          // Deactivate all
          dropdown.querySelectorAll('.site-header__nav-tab').forEach(function(t) {
            t.classList.remove('is-active');
          });
          dropdown.querySelectorAll('.site-header__nav-panel').forEach(function(p) {
            p.classList.remove('is-active');
          });
          // Activate this tab and its panel
          tab.classList.add('is-active');
          if (panel) panel.classList.add('is-active');
        });
      });
    });
  })();
</script>
