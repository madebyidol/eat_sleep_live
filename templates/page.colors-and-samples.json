        "c8cdc304-2db0-497f-9613-ec667b2efb34": {
          "type": "faq",
          "settings": {
            "question": "Are the colour samples free and will they fit through the letterbox?",
            "answer": "Our colour samples are free, we send them out to you by 1st class post. And yes! We package our colour samples in a nice, letter box friendly package."
          }
        },
        "df715761-66aa-4cc4-bcd3-09a4de62aa57": {
          "type": "faq",
          "settings": {
            "question": "Can you match the wood colour to my existing Eat Sleep Live furniture?",
            "answer": "Please email photos of your existing furniture to info@eatsleeplive.co.uk and we can look into this for you."
          }
        },
        "40b0d4d9-f39f-42e9-bddb-2a01ca925785": {
          "type": "faq",
          "settings": {
            "question": "Are the colours that are sent to me in the sample box accurate?",
            "answer": "Please take the colour samples and photos on our website as a guide, as no two beams are the same, they all have their own individuality with tones/colours/imperfections which is all part of the character. Plus, this is what makes each piece unique to you!"
          }
        },
        "6a81da56-f066-4ed8-8687-a7a961737107": {
          "type": "faq",
          "settings": {
            "question": "Do you offer colours that are not displayed on your website?",
            "answer": "We currently offer six colour options, if any of the colours are not quite what you are looking for, we do offer a service where we would leave your furniture unfinished for you to apply the colour yourselves."
          }
        },
