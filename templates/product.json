          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/image_1fdf3524-b5e0-4416-80e5-fa88c7db061b.png",
            "title": "Lorem ipsum dolor sit amet, consectur adipiscing elit",
            "content": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nulla ut quam euismod, commodo orci sed, placerat nisi. Ut porta at justo et consectetur. In hac habitasse platea dictumst.</p>"
